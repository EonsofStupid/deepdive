[267127.135553, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[7C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m60\u001b[16G\u001b[38;5;231m  \u001b[19G (\u001b[38;5;141mNone\u001b[38;5;231m, \u001b[38;5;141mNone\u001b[38;5;231m)\u001b[33G=> {}         \u001b[48G \r\u001b[7C\u001b[1B\u001b[38;5;77m61\u001b[20G\u001b[38;5;231m_ => {                  \r\u001b[7C\u001b[1B\u001b[38;5;77m62\u001b[16G\u001b[38;5;231m \u001b[24G\u001b[38;5;148mreturn\u001b[31G\u001b[38;5;231m(StatusCode::BAD_REQUEST,\u001b[57G\u001b[38;5;186m\"input_tokens and\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;186m output_tokens must be given together\"\u001b[38;5;231m)\r\u001b[7C\u001b[1B\u001b[38;5;77m63\u001b[20G\u001b[38;5;231m   \u001b[24G \u001b[26G  .\u001b[38;5;148minto_response\u001b[38;5;231m();\r\u001b[7C\u001b[1B\u001b[38;5;77m64\u001b[16G\u001b[38;5;231m \u001b[20G}\r\u001b[7C\u001b[1B\u001b[38;5;77m65\u001b[16G\u001b[38;5;231m}    \u001b[22G                  \u001b[41G                  \u001b[60G \r\u001b[7C\u001b[1B\u001b[38;5;77m66\u001b[16G\u001b[38;5;197mif\u001b[19G\u001b[38;5;81mlet\u001b[38;5;231m Some(ms) = req.latency_ms {           \u001b[62G   \r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[20G\u001b[38;5;231msig = sig.\u001b[38;5;148mlatency_ms\u001b[38;5;231m(ms);\r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[16G\u001b[38;5;231m}\u001b[20G \u001b[22G  \u001b[25G \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[24G\u001b[38;5;231m      \u001b[31G                         \u001b[57G                 \r\u001b[6C\u001b[1B\u001b[38;5;77m770\u001b[12G\u001b[38;5;231m    \u001b[38;5;197mmatch\u001b[38;5;231m sig.\u001b[38;5;148memit\u001b[38;5;231m(sink.\u001b[38;5;148mas_ref\u001b[38;5;231m()).\u001b[38;5;197mawait\u001b[52G\u001b[38;5;231m{\r\u001b[7C\u001b[1B\u001b[38;5;77m71\u001b[20G\u001b[38;5;148mOk\u001b[38;5;231m(())\u001b[27G=> (              \r\u001b[7C\u001b[1B\u001b[38;5;77m72\u001b[20G\u001b[38;5;231m \u001b[24GStatusCode::OK,\r\u001b[7C\u001b[1B\u001b[38;5;77m73\u001b[16G