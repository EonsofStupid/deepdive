[302592.378951, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B\u001b[38;5;231m●\u001b[3G\u001b[39mAll\u001b[7Gapplied\u001b[15Gand\u001b[19Gverified.\u001b[29GSummary\u001b[37Gof\u001b[40Gwhat\u001b[45Gchanged\u001b[53Gin\u001b[56G\u001b[38;5;153mstatusline-pxpipe.sh\u001b[39m:\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mMechanical fixes (1, 2, 5, 10)\u001b[22m\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCache keyed per config\u001b[22m — filename\u001b[39Gnow includes a \u001b[38;5;153mcksum\u001b[60G\u001b[39mof\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mPXPIPE_STATUS_URL|PXPIPE_EVENTS\u001b[39m, so ov\u001b[43Gridden\u001b[51Gest runs and the real\u001b[73G\u001b[K\r\u001b[2C\u001b[1Bstatusline ea\u001b[17Gh g\u001b[21Gt th\u001b[26Gir own\u001b[33Gcache. V\u001b[42Grified: the\u001b[54Gup/down\u001b[62Gtest\u001b[67Gabove\u001b[73Gproduced\r\u001b[2C\u001b[1Btwo distinct cache files with independent\u001b[45Gstates.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mAtomic cache write\u001b[22m — writ\u001b[31G to\u001b[35G\u001b[38;5;153m$CACHE.$$\u001b[45G\u001b[39mthen\u001b[50G\u001b[38;5;153mmv -f\u001b[39m;\u001b[57Gtorn\u001b[62Greads\u001b[68Gunder\r\u001b[2C\u001b[1Bconcurrent repaints are gone.\u001b[33G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mBounded scan\u001b[22m — \u001b[38;5;153mtail -c 2MiB\u001b[39m before the grep, so \u001b[56G <100ms budget survives\r\u001b[2C\u001b[1Blog growth; a line tor\u001b[26G by the byte cut (and any other\u001b[58Ggarbage\u001b[66Gline) is\u001b[75G\u001b[K\r\u001b[3C\u001b[1Bkipp\u001b[9Gd by \u001b[38;5;153mfromjson?\u001b[24G\u001b[39minstead\u001b[32Gof\u001b[35Gpoisoning\u001b[45Gthe\u001b[49Gwhole\u001b[55G\u001b[38;5;153mjq\u001b[58G\u001b[39mslurp\u001b[64G—\u001b[66Gverified\u001b[75Gwith\u001b[80Ga\r\u001b[2C\u001b[1Bsynthetic torn line.\u001b[24G\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[38;5;153m\u001b[1m/tmp/claude-${UID}\u001b[24G\u001b[22m\u001b[39minstead\u001b[32Gof\u001b[35Ghardcoded\u001b[45G\u001b[38;