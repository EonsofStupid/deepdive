[301687.721238, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mStatus:\u001b[13G\u001b[22mreal\u001b[18GHTTP\u001b[23Gcheck\u001b[29G—\u001b[31G\u001b[38;5;153mcurl -fsS --max-time 1\u001b[54G\u001b[39mGET\u001b[58Gon\r\u001b[1B \u001b[3G\u001b[38;5;153mhttp://127.0.0.1:47821/\u001b[39m (the\u001b[32Gdashboard is pxpipe's only\u001b[59G2xx route;\u001b[70G\u001b[38;5;153m/health\u001b[39m,\r\u001b[2C\u001b[1B\u001b[38;5;153m/api/status\u001b[39m etc. all 404).\u001b[30GGreen\u001b[36G\u001b[38;5;153m●\u001b[38G\u001b[39mon\u001b[41G2xx,\u001b[46Gred\u001b[50G\u001b[38;5;153m●\u001b[52G\u001b[39motherwise.\u001b[63G\u001b[38;5;153mPXPIPE_STATUS_URL\r\u001b[2C\u001b[1B\u001b[39moverrides,\u001b[14Gmatching\u001b[23Gthe\u001b[27G\u001b[38;5;153mINFISICAL_STATUS_URL\u001b[48G\u001b[39mpattern.\r\u001b[2C\u001b[1B- \u001b[1mTokens saved today:\u001b[25G\u001b[22mthere's\u001b[33Gno\u001b[36Gstats\u001b[42GAPI\u001b[46Gand\u001b[50Gno\u001b[53Gprecomputed\u001b[65Gfield\u001b[71Gin\u001b[74Gthe\r\u001b[2C\u001b[1Bevents, so it sums today's (UTC) lines from \u001b[38;5;153m~/.pxpipe/events.jsonl\u001b[39m:\r\u001b[2C\u001b[1B\u001b[38;5;153mbaseline_tokens − (input_tokens + cache_create_tokens + cache_read_tokens)\r\u001b[2C\u001b[1B\u001b[39monly for lin\u001b[16Gs with \u001b[38;5;153mbaseline_probe_status == \"ok\"\u001b[39m, clamped at 0, rendered as\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mk\u001b[39m/\u001b[38;5;153mM\u001b[39m. Omitted ent\u001b[20Grely if the file is missing/unreadable\u001b[59Gor\u001b[62Gthe\u001b[66Gsum\u001b[70Gis 0.\u001b[76GNote\r\u001b[2C\u001b[1Bit's an approximation\u001b[25G— it cou\u001b[34Gts c\u001b[39Gche-read tokens at par \u001b[63Gven though\u001b[77Gy're\r\u001b[2C\u001b[1Bbilled cheaper, so\u001b[23Ghe true cost\u001b[36Gsaving is somewhat higher than the\u001b[71Gtoken\r\u001b[2C\u001b[1Bfigure shown.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mSpeed:\u001b[12G\u001b[22msam\u001b[16G 5s cache as the reference\u001b[K\r\u001b[2C\u001b[1B(\u001b[38;5;153m/tmp/claude-1000/pxpipe-status.cache\u001b[39m). Measured: 15ms c\u001b[60Gld, 5m\u001b[67G warm, 18ms\u001b[K\r\u001b[2C\u001b[1Bcold\u001b[8Gwith the proxy down (connection-r\u001b[42Gfuse\u001b[48Gon loopback is instant; a\u001b[74G\u001b[3mhung\u001b[23m\u001b[K\r\u001b[2C\u001b[1Bproxy would cost up to\u001b[56Gndow).\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[301687.728042, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[4C\u001b[1B\u001b[1mToken\u001b[11G saved today:\u001b[22m there's no stats API and no precomputed\u001b[65Gfield\u001b[71Gin\u001b[74Gthe\r\u001b[2C\u001b[1Bevents, so it sums today's (UTC) lines\u001b[42Gfrom \u001b[38;5;153m~/.pxpipe/events.jsonl\u001b[39m:\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mb\u001b[5Gseline_tokens − (input_tokens + cache_create_tokens + cache_read\u001b[70Gtokens)\u001b[39m,\u001b[K\r\u001b[3C\u001b[1Bnly for lines w\u001b[20Gth\u001b[23G\u001b[38;5;153mbaseline_probe_status == \"ok\"\u001b[39m, clamped\u001b[62Gat\u001b[65G0,\u001b[68Grendered\u001b[77Gas\r\u001b[2C\u001b[1B\u001b[38;5;153mk\u001b[39m/\u001b[38;5;153mM\u001b[39m. Omitted entirely\u001b[25Gif the file is missing/unreadable or the sum is 0. Note\r\u001b[2C\u001b[1Bit's an\u001b[11Gapproximation — it\u001b[30Gcounts cache-\u001b[44Gead tokens at par even though\u001b[74Gthey're\r\u001b[2C\u001b[1Bbilled cheaper, so the true cost saving is somewhat higher than the token\u001b[K\r\u001b[2C\u001b[1Bfigure show\u001b[15G.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mSpeed:\u001b[22m same 5s cache as the reference\u001b[K\r\u001b[2C\u001b[1B(\u001b[38;5;153m/tmp/claude-1000/pxpipe-status.cache\u001b[39m). M\u001b[46Gsured: 15ms\u001b[58Gcold, 5ms warm,\u001b[74G18ms\u001b[K\r\u001b[2C\u001b[1Bco\u001b[6Gd wit\u001b[12G th\u001b[16G proxy down (connection-refu\u001b[45Ged on loopback is instant; a \u001b[3mhung\r\u001b[2C\u001b[1B\u001b[23mproxy would cost\u001b[20Gup\u001b[23Gto\u001b[26Gthe\u001b[30G1s\u001b[33Gcurl\u001b[38Gcap\u001b[42Gonce\u001b[47Gper\u001b[51G5s\u001b[54Gwindow).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mVerified states\u001b[22m\u001b[K\r\u001b[2C\u001b[1B- Up: \u001b[38;5;153m⚡ pxpipe ●(green) · 908.2k saved\u001b[39m — the counter moved\u001b[63Gbetween runs\u001b[K\r\u001b[2C\u001b[1B(772.8k → 908.2k) becaus\u001b[56Gs are landing\u001b[70Gin\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
