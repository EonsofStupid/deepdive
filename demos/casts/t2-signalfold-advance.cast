[267113.561467, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[5C\u001b[1B\u001b[38;5;167m\u001b[48;5;52m 353 -\u001b[38;5;231m    let platform = match Platform::boot(cfg) {                \r\u001b[8C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m4\u001b[19G\u001b[38;5;242mBoot \u001b[25Ggainst the \u001b[37Gaemon-owned warehouse handle when\u001b[71Gmai\r\u001b[11C\u001b[1Bn() ope\u001b[20Ged\u001b[23Git (DuckDB singl\u001b[40G-writer —\r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[19G\u001b[38;5;242mONE handle, \u001b[32Ghared with /signal/fold); fall back to sel\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mf-opening, which reports the same\r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[16G\u001b[38;5;242m// failure honestly through BrainState::Failed.\u001b[64G\u001b[38;5;231m   \r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[16G\u001b[38;5;81mlet\u001b[20G\u001b[38;5;231mboot\u001b[26G \u001b[38;5;197mmatch\u001b[38;5;231m metrics {      \r\u001b[7C\u001b[1B\u001b[38;5;77m58\u001b[16G\u001b[38;5;231m  \u001b[20G\u001b[38;5;148mSome\u001b[38;5;231m(m)\u001b[28G=>\u001b[31GPlatform::\u001b[38;5;148mboot_with_metrics\u001b[38;5;231m(cfg,\u001b[64Gm),\r\u001b[7C\u001b[1B\u001b[38;5;77m59\u001b[16G\u001b[38;5;231m   \u001b[20G\u001b[38;5;141mNone\u001b[38;5;231m => Platform::\u001b[38;5;148mboot\u001b[38;5;231m(cfg),\r\u001b[5C\u001b[1B\u001b[38;5;77m 360 +\u001b[38;5;231m    };                                                        \r\u001b[5C\u001b[1B\u001b[38;5;77m 361 +\u001b[38;5;231m    \u001b[38;5;81mlet\u001b[38;5;231m platform = \u001b[38;5;197mmatch\u001b[38;5;231m boot {                               \r\u001b[8C\u001b[1B\u001b[49m\u001b[2m2\u001b[20G\u001b[22m\u001b[38;5;148mOk\u001b[38;5;231m(p) => {\r\u001b[5C\u001b[1B\u001b[2m 363 \u001b[22m             *state.\u001b[38;5;148mwrite\u001b[38;5;231m().\u001b[38;5;148munwrap\u001b[38;5;231m() = BrainState::Ready;\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;5;231m\u001b[2m 364 \u001b[22m             p\u001b[39m\