e referenc\u001b[42G\u001b[K\r\u001b[2C\u001b[1B(\u001b[38;5;153m/tmp/claude-1000/pxpipe\u001b[56G\u001b[39ms cold,\u001b[64G5ms\u001b[68Gwarm,\u001b[74G18ms\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
