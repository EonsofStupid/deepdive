[301686.625301, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B- \u001b[1mStatus:\u001b[22m real HTTP check — \u001b[38;5;153mcurl -fsS --max-time 1\u001b[54G\u001b[39mGET on\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mhttp://127.0.0.1:47821/\u001b[39m (the dashboard is pxpipe's only 2xx\u001b[63Groute; \u001b[38;5;153m/health\u001b[39m,\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m/api/status\u001b[39m e\u001b[18G. all 404). Green \u001b[38;5;153m●\u001b[39m on 2xx, red \u001b[38;5;153m●\u001b[39m otherwise.\u001b[63G\u001b[38;5;153mPXPIPE_STATUS_URL\r\u001b[2C\u001b[1B\u001b[39moverrides, matching the \u001b[38;5;153mINFISICAL_STATUS_URL\u001b[39m pattern.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mTokens saved today:\u001b[22m there's no\u001b[36Gstat\u001b[42GAPI and no precomputed field\u001b[71Gin\u001b[74Gthe\r\u001b[2C\u001b[1Bevents, so it sums today's (UTC) lines from \u001b[38;5;153m~/.pxpipe/events.jsonl\u001b[39m:\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mbaseline_tokens − (input_tokens + cache_create_tokens + cache_read_tokens)\u001b[39m,\u001b[K\r\u001b[2C\u001b[1Bonly\u001b[8Gfor lines w\u001b[20Gth \u001b[38;5;153mbaseline_probe_status == \"ok\"\u001b[39m, clamped\u001b[62Gat 0, rendered as\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mk\u001b[39m/\u001b[38;5;153mM\u001b[39m.\u001b[8GOmitted entirely\u001b[25Gif \u001b[29Ghe file\u001b[37Gis missing/unr\u001b[52Gadable o\u001b[62Gth\u001b[65G sum is 0. Note\u001b[K\r\u001b[2C\u001b[1Bit's an approximation — it coun\u001b[35Gs cache-read tokens\u001b[55Gat pa\u001b[62Geve\u001b[69Gough they're\r\u001b[2C\u001b[1Bb\u001b[5Glled\u001b[10Gc\u001b[12Geaper,\u001b[19Gso\u001b[22Gthe\u001b[26Gtrue\u001b[31Gcost\u001b[36Gsaving\u001b[43Gis\u001b[46Gsomewhat\u001b[55Ghigher\u001b[62Gthan\u001b[67Gthe\u001b[71Gtoken\r\u001b[2C\u001b[1Bfigure shown.\u001b[17G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mSpeed:\u001b[22m same 5s cache as the reference\u001b[43G\u001b[K\r\u001b[2C\u001b[1B(\u001b[38;5;153m/tmp/claude-