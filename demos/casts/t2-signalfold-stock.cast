[268364.784426, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m3\u001b[13G\u001b[22m\u001b[38;5;242mshares between its sink\u001b[37Gand the platform (D\u001b[57GckDB single-write\r\u001b[10C\u001b[1Br — ONE handle per process).\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m4\u001b[11G\u001b[22m\u001b[38;5;148mclyffy-telemetry\u001b[38;5;231m = { path = \u001b[38;5;186m\"../../clyffy-telemetry\"\u001b[38;5;231m }\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;167m\u001b[48;5;52m 15 -\u001b[38;5;231mclyffy-storage = { path = \"../../clyffy-storage\" }             \r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 15 +\u001b[38;5;148mclyffy-storage\u001b[38;5;231m = { path = \u001b[38;5;186m\"../../clyffy-storage\"\u001b[38;5;231m\u001b[48;5;28m,\u001b[48;5;22m \u001b[48;5;28mfeatures = [\u001b[38;5;186m\"\r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m    +\u001b[38;5;186m\u001b[48;5;28mduckdb\"\u001b[38;5;231m] \u001b[48;5;22m}                                                     \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 16 \u001b[22m \u001b[38;5;148mtokio\u001b[38;5;231m = { workspace = \u001b[38;5;141mtrue\u001b[38;5;231m, features = [\u001b[38;5;186m\"rt-multi-thread\"\u001b[38;5;231m, \u001b[38;5;186m\"net\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m    \u001b[22m \u001b[38;5;186m\"\u001b[38;5;231m, \u001b[38;5;186m\"sync\"\u001b[38;5;231m, \u001b[38;5;186m\"time\"\u001b[38;5;231m] }\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m7\u001b[16G\u001b[22m\u001b[38;5;148m-stream\u001b[38;5;231m = \u001b[38;5;186m\"0.1\"\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m18\u001b[11G\u001b[22m\u001b[38;5;148maxum\u001b[38;5;231m = \u001b[38;5;186m\"0.8\u001b[23G\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;246m●\u001b[3G\u001b[39m\u001b[1mUpdate\u001b[22m(\u001b]8;id=1m2odyr;file:///home/hades/clyffy/landing/study/t2/a/interfaces/clyffy-brain/src/main.rs\u0007