[267124.376626, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[8C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m7\u001b[12G\u001b[38;5;242m#[derive(Deserialize)]\u001b[38;5;231m                                        \r\u001b[6C\u001b[1B\u001b[38;5;77m638\u001b[12G\u001b[38;5;81mstruct\u001b[38;5;231m \u001b[38;5;148mFoldReq\u001b[27G\u001b[38;5;231m{\r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// Lifecycle transition — a [`FoldPhase`] tag (e.g. `bran\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mch_opened`, `decision_established`).\r\u001b[7C\u001b[1B\u001b[38;5;77m40\u001b[16G\u001b[38;5;231mphase: \u001b[38;5;148mString\u001b[38;5;231m,                                            \r\u001b[6C\u001b[1B\u001b[38;5;77m641\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// The\u001b[24Gfold tree's node id this event belongs to.\r\u001b[8C\u001b[1B\u001b[38;5;77m2\u001b[16G\u001b[38;5;231mbr\u001b[19Gnch_id: \u001b[38;5;148mString\u001b[38;5;231m,\r\u001b[8C\u001b[1B\u001b[38;5;77m3\u001b[20G\u001b[38;5;242mW\u001b[22Gich harness ra\u001b[37G the branch\u001b[49G— a [`Fo\u001b[58GdEngine`] tag (e\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242m.g. `claude`, `codex`).\r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;231mengine: \u001b[38;5;148mString\u001b[38;5;231m,                                           \r\u001b[6C\u001b[1B\u001b[38;5;77m645\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// Attribution scope; defaults to `clyffy` (mirrors the `\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mclyffy signal fold` CLI).\r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[16G\u001b[38;5;242m#[serde(default)]\u001b[38;5;231m                                         \r\u001b[6C\u001b[1B\u001b[38;5;77m647\u001b[12G\u001b[38;5;231m    scope: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[16G\u001b[38;5;242m/// Th\u001b[23G parent 