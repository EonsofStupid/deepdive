[590.373131, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1moption.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BThis is\u001b[11Gthe\u001b[15Ggenuinely\u001b[25Gcutting-edge\u001b[38Gone:\u001b[43Gthe\u001b[47GIETF\u001b[52Gstandardized\u001b[65Gtunneling\u001b[75G\u001b[3minside\r\u001b[2C\u001b[1B\u001b[23man HTTP/3 connection.\u001b[25GYour vision — \"connection starts as HTTP a\u001b[68Gd\u001b[K\r\u001b[2C\u001b[1Bimmediately becomes the b\u001b[29Gidge\" —\u001b[37Gis n\u001b[42Gt a metaphor here;\u001b[61Gthe s\u001b[67Gme\u001b[70GQUIC\r\u001b[2C\u001b[1Bconnection that did\u001b[27Ghan\u001b[31Gshake\u001b[37G\u001b[3mis\u001b[40G\u001b[23mthe\u001b[44Gtunnel. Bonus tha\u001b[62G matters to you\r\u001b[2C\u001b[1Bspecifically: QUIC \u001b[1mconnection migration + multipath\u001b[22m means a\u001b[63Gweak/dropping\u001b[K\r\u001b[2C\u001b[1Bclient link migrates without tearing the session down. Maturity fo\u001b[70G\u001b[K\r\u001b[2C\u001b[1Bself-hosted\u001b[15Gembedding \u001b[26Gs the\u001b[32Gopen question — that's what spur 1\u001b[67Gis verifying.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[590.389788, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1BThis is\u001b[11Gthe\u001b[15Ggenuinely\u001b[25Gcutting-edge\u001b[38Gone:\u001b[43Gthe\u001b[47GIETF\u001b[52Gstandardized\u001b[65Gtunneling\u001b[75G\u001b[3minside\r\u001b[2C\u001b[1B\u001b[23man HTTP/3 connection.\u001b[25GYour vision — \"connection starts as HTTP a\u001b[68Gd\u001b[K\r\u001b[2C\u001b[1Bimmediately becomes the b\u001b[29Gidge\" —\u001b[37Gis n\u001b[42Gt a metaphor here;\u001b[61Gthe s\u001b[67Gme\u001b[70GQUIC\r\u001b[2C\u001b[1Bconnection that did\u001b[27Ghan\u001b[31Gshake\u001b[37G\u001b[3mis\u001b[40G\u001b[23mthe\u001b[44Gtunnel. Bonus tha\u001b[62G matters to you\r\u001b[2C\u001b[1Bspecifically: QUIC \u001b[1mconnection migration + multipath\u001b[22m means a\u001b[63Gweak/dropping\u001b[K\r\u001b[2C\u001b[1Bclient link migrates without tearing the session down. Maturity fo\u001b[70G\u001b[K\r\u001b[2C\u001b[1Bself-hosted\u001b[15Gembedding \u001b[26Gs the\u001b[32Gopen question — that's what spur 1\u001b[67Gis verifying.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2\u001b[5G\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA virtual\u001b[13Gethernet\u001b[22Gnetwo\u001b[55Gunning\u001b[62Gon\u001b[65Gclyffy\u001b[72G(that's\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
