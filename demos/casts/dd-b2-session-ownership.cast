[347.976113, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[48;5;237m  \u001b[38;5;231mit evolve into estate moves, and dispatches where we preflight and connect \u001b[39m   \r\u001b[1B  \u001b[38;5;231mqr code\u001b[11Gscan we can deploy via phone\u001b[39m                                         \r\u001b[1B\u001b[49m\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[39m That evolves cleanly — and it tells me the schema decision: \u001b[1mattachment becomes\r\u001b[2C\u001b[1Ba first-class entity from day one\u001b[22m,\u001b[38Geven\u001b[43Gthough\u001b[50Gv1\u001b[53Gpolicy\u001b[60Genforces\u001b[69Gexactly\u001b[77Gone\r\u001b[1B \u001b[3Glive\u001b[8Gattach.\u001b[16GConcretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153msession\u001b[39m ←→\u001b[16G\u001b[38;5;153mattachment\u001b[39m ←→\u001b[30G\u001b[38;5;153mdevice\u001b[37G\u001b[39min\u001b[40Gthe\u001b[44Gconnectome\u001b[55Gschema.\u001b[63GV1\u001b[66Gships\u001b[72Gwith\u001b[77Ga\r\u001b[2C\u001b[1Bpolicy\u001b[10Gknob\u001b[15G(\u001b[38;5;153mmax_live_attachments = 1\u001b[39m),\u001b[43Gnot\u001b[47Ga\u001b[49Ghardcoded\u001b[59Gassumption.\u001b[71GEstate\r\u001b[2C\u001b[1Bmoves and\u001b[13Gphone dispatch then become\u001b[40G\u001b[3mpolicy and ceremony changes, not schema \r\u001b[2C\u001b[1Bmigrations\u001b[23m — which is exactly the trap we're avoi\u001b[53Ging by deciding thi\u001b[73G now.\r\u001b[2C\u001b[1B- \u001b[1mAttachment gets a \u001b[38;5;153mrole\u001b[39m field\u001b[22m now: \u001b[38;5;153mprimary\u001b[39m (full data plane — the\u001b[K\r\u001b[2C\u001b[1Bdevstation),\u001b[16G\u001b[38;5;153mdispatcher\u001b[39m (\u001b[29Gontrol-plane\u001b[42Gonly — what the phone is),\u001b[69G\u001b[38;5;153mspectator\r\u001b[2C\u001b[1B\u001b[39m(read-only, reserved). A phone\u001b[34Gdispatch never needs \u001b[56Ghe QUIC\u001b[64Gfast path;\u001b[75Git\r\u001b[2C\u001b[1Bn\u001b[5Geds \u001b[10Ghe HTTP/3 control plane to preflight\u001b[47Gand fire. So \"d\u001b[63Gploy via phone\"\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[348.376397, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[3G\u001b[39mThat\u001b[8Gevolves\u001b[16Gcleanly\u001b[24G—\u001b[26Gand\u001b[30Git\u001b[33Gtells\u001b[39Gme\u001b[42Gthe\u001b[46Gschema\u001b[53Gdecision:\u001b[63G\u001b[1mattachment becomes\r\u001b[1B\u001b[22m \u001b[3G\u001b[1ma first-class entity from day one\u001b[22m, ev\u001b[41Gn thoug\u001b[49G v1\u001b[53Gpol\u001b[57Gcy enforces exactly one\u001b[K\r\u001b[2C\u001b[1Blive attach. Concretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[38;5;153msession\u001b[13G\u001b[39m←→\u001b[16G\u001b[38;5;153mattachment\u001b[27G\u001b[39m←→\u001b[30G\u001b[38;5;153mdevice\u001b[37G\u001b[39min\u001b[40Gthe\u001b[44Gconnectome\u001b[55Gschema.\u001b[63GV1\u001b[66Gships\u001b[72Gwith\u001b[77Ga\r\u001b[2C\u001b[1Bpolicy knob (\u001b[38;5;153mmax_liv\u001b[24G_attachments = 1\u001b[39m), not a hardcoded assumption. Estate\u001b[K\r\u001b[2C\u001b[1Bm\u001b[5Gves and phone dispatch then become \u001b[3mpolicy and ceremony changes, not schema \r\u001b[2C\u001b[1Bmigrations\u001b[23m — which is exactly\u001b[33Gthe trap we're avoiding by deciding this now.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mAttachment gets a \u001b[38;5;153mrole\u001b[39m field\u001b[22m now: \u001b[38;5;153mprimary\u001b[39m (full data plane — the\u001b[K\r\u001b[2C\u001b[1Bdevstation), \u001b[38;5;153mdispatcher\u001b[39m (control-plane only\u001b[47G— what the\u001b[59Gho\u001b[64Gis), \u001b[38;5;153mspectator\r\u001b[2C\u001b[1B\u001b[39m(read-only, reserved). A phone disp\u001b[39Gtch \u001b[44Gever\u001b[49Gneeds the QUIC\u001b[64Gfast\u001b[69Gpath; it\u001b[K\r\u001b[2C\u001b[1Bne\u001b[6Gds the HTTP/3 control\u001b[29Gla\u001b[34Gto \u001b[38Greflight and fire. So \"deploy vi\u001b[71G phone\"\r\u001b[2C\u001b[1Bcost\u001b[9Galmost nothing extra o\u001b[32G the\u001b[37Gt\u001b[39Ganspor\u001b[47Gsi\u001b[50Ge — branch 1's design\u001b[72Galready\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
