[31656.266283, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[K\r\u001b[2C\u001b[1Bship/no-ship gate is the\u001b[28G\u001b[1mLAN leg\u001b[22m, which \u001b[44Geeds the devs\u001b[58Gation online. Hone\u001b[77Gt\r\u001b[2C\u001b[1Bnumbers and\u001b[15Gthe\u001b[19Gproposed\u001b[28Gre-anchor\u001b[38Gare\u001b[42Gin\u001b[45G\u001b[38;5;153mJOURNAL.md\u001b[39m;\u001b[57Gthe\u001b[61Grecalibration\u001b[75Gis\r\u001b[2C\u001b[1Byour call.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[38;5;153m\u001b[1mclyffy signal fold\u001b[39m core-dumps\u001b[22m (SIGABRT) — signa\u001b[54Gs are\u001b[60Gqueue\u001b[66G to\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m;\u001b[40Gthe\u001b[44Gcrash\u001b[50Gis\u001b[53Glogged\u001b[60Gas\u001b[63Ga\u001b[65Gdefect\u001b[72Gfor\u001b[76Gthe\r\u001b[2C\u001b[1Bfold's\u001b[10Gwork\u001b[15Glist.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNo\u001b[6G exercised: a live \u001b[38;5;153m/converse\u001b[39m turn (brain booted \u001b[38;5;153mready\u001b[39m;\u001b[61Gthe\u001b[65Gpath\u001b[70Gis\r\u001b[2C\u001b[1Buntouched\u001b[13Gby\u001b[16Gthis\u001b[21Gchange\u001b[28G—\u001b[30Gverify\u001b[37Gwhen\u001b[42Gconvenient).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BWhe\u001b[7G you've verified and are\u001b[32Gsatisfied, \u001b[1mexit this session\u001b[22m — that triggers\u001b[K\r\u001b[2C\u001b[1Bbran\u001b[8Gh 4\u001b[12G(deployment-shape),\u001b[32Gthe\u001b[36Glast\u001b[41Gone\u001b[45Gbefore\u001b[52Gthe\u001b[56Gterminal\u001b[65Gfold\u001b[70Gback\u001b[75Gin\u001b[78Gthe\r\u001b[2C\u001b[1Bsource.\r\u001b[1B \u001b[3G                    \u001b[27G\u001b[48;5;237m\u001b[38;5;231m Jump to bottom (ctrl+End) ↓ \u001b[39m\u001b[49m\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
