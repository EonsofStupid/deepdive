[574.138687, "o", "\u001b(B\u000f\u001b[<u\u001b[>1u\u001b[>4;2m\u001b[?1000h\u001b[?1002h\u001b[?1003h\u001b[?1006h"]
[574.434104, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[57C\u001b[22B \u001b[38;5;246m4m 0\u001b[39m\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[574.790599, "o", "\u001b]0;⠐ dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR brief) then begin\u0007"]
[574.908364, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[61C\u001b[22B\u001b[38;5;246m1\u001b[70G3\u001b[72G5\u001b[39m\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[575.340673, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[K\r\u001b[2C\u001b[1BSo the shape I think you're actually describing is: \u001b[1mHTTP handshake\u001b[70G→ in\u001b[75Gapp \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1msecure tunnel (pick 1, 2, or 3) → terminates at the cluster edge → rkyv-framed\r\u001b[2C\u001b[1Bingestion stream inside it\u001b[22m — with local mode going direct over the LAN\u001b[74Gand\r\u001b[2C\u001b[1Bnetworked\u001b[13Gmode\u001b[18Gtraversing\u001b[29GNAT/relay\u001b[39Gthrough\u001b[47Gthe\u001b[51Gsame\u001b[56Gtunnel\u001b[63Gidentity.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BD\u001b[5Ges edge-\u001b[14Germination match your intent, or do you specifically want DevPulse\r\u001b[2C\u001b[1Bto be a\u001b[11Gcitize\u001b[18G o\u001b[21G the fabric's broadcast domain? And of the three b\u001b[72Gidg\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bflavor\u001b[10G — borin\u001b[19G-fast WireG\u001b[31Gard, b\u001b[38Geeding-edge MASQUE, or true-L2 ZeroTier\u001b[78G—\r\u001b[2C\u001b[1Bw\u001b[5Gi\u001b[7Gh\u001b[9Gsmells right? (The\u001b[28Gspurs\u001b[34Gwill\u001b[39Greport\u001b[46Gback\u001b[51Gwith\u001b[56Gmaturity\u001b[65Gverdicts\u001b[74Gto\r\u001b[2C\u001b[1Bcheck\u001b[9Gus\u001b[12Geither\u001b[19Gway.)\r\u001b[1B\u001b[K\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[575.361007, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[48;5;237m\u001b[38;5;239m❯ linux and windows and mac, we want to have a secure protocol like a vpn brid…\u001b[39m \r\u001b[26C\u001b[11B\u001b[38;5;231m Jump to bottom (ctrl+End) ↓ \u001b[39m\u001b[49m\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[575.3621, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BSo the shape I think you're actually describing is: \u001b[1mHTTP handshake\u001b[70G→ in\u001b[75Gapp \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1msecure tunnel (pick 1, 2, or 3) → terminates at the cluster edge → rkyv-framed\r\u001b[2C\u001b[1Bingestion stream inside it\u001b[22m — with local mode going direct over the LAN\u001b[74Gand\r\u001b[2C\u001b[1Bnetworked\u001b[13Gmode\u001b[18Gtraversing\u001b[29GNAT/relay\u001b[39Gthrough\u001b[47Gthe\u001b[51Gsame\u001b[56Gtunnel\u001b[63Gidentity.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BD\u001b[5Ges edge-\u001b[14Germination match your intent, or do you specifically want DevPulse\r\u001b[2C\u001b[1Bto be a\u001b[11Gcitize\u001b[18G o\u001b[21G the fabric's broadcast domain? And of the three b\u001b[72Gidg\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bflavor\u001b[10G — borin\u001b[19G-fast WireG\u001b[31Gard, b\u001b[38Geeding-edge MASQUE, or true-L2 ZeroTier\u001b[78G—\r\u001b[2C\u001b[1Bw\u001b[5Gi\u001b[7Gh\u001b[9Gsmells right? (The\u001b[28Gspurs\u001b[34Gwill\u001b[39Greport\u001b[46Gback\u001b[51Gwith\u001b[56Gmaturity\u001b[65Gverdicts\u001b[74Gto\r\u001b[2C\u001b[1Bcheck\u001b[9Gus\u001b[12Geither\u001b[19Gway.)\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[575.388135, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bwire\u001b[8Gas\u001b[11Gyour\u001b[16GNCCL\u001b[21Grails.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BSo the shape I think you're actually describing is: \u001b[1mHTTP handshake\u001b[70G→ in\u001b[75Gapp \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1msecure tunnel (pick 1, 2, or 3) → terminates at the cluster edge → rkyv-framed\r\u001b[2C\u001b[1Bingestion stream inside it\u001b[22m — with local mode going direct over the LAN\u001b[74Gand\r\u001b[2C\u001b[1Bnetworked\u001b[13Gmode\u001b[18Gtraversing\u001b[29GNAT/relay\u001b[39Gthrough\u001b[47Gthe\u001b[51Gsame\u001b[56Gtunnel\u001b[63Gidentity.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BD\u001b[5Ges edge-\u001b[14Germination match your intent, or do you specifically want DevPulse\r\u001b[2C\u001b[1Bto be a\u001b[11Gcitize\u001b[18G o\u001b[21G the fabric's broadcast domain? And of the three b\u001b[72Gidg\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bflavor\u001b[10G — borin\u001b[19G-fast WireG\u001b[31Gard, b\u001b[38Geeding-edge MASQUE, or true-L2 ZeroTier\u001b[78G—\r\u001b[2C\u001b[1Bw\u001b[5Gi\u001b[7Gh\u001b[9Gsmells right? (The\u001b[56Gmaturity\u001b[65Gverdicts\u001b[74Gto\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
