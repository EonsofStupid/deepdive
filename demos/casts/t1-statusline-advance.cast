[301746.675839, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mare there any obvious gotchas or improvements we should capture for our \r\u001b[1B\u001b[39m  \u001b[38;5;231mbaseline?\u001b[39m                                                                     \r\u001b[1B\u001b[49m\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[3G\u001b[39mYes\u001b[7G— a handful worth\u001b[25Gwriting\u001b[33Gdown.\u001b[39GGrouped\u001b[47Gby\u001b[50Gwhether\u001b[58Gthey'd\u001b[65Gbite\u001b[70Gsilently\u001b[79Gor\r\u001b[2C\u001b[1Bare\u001b[7Gjust\u001b[12Gupgrades:\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mGotchas (real, would bite)\r\u001b[2C\u001b[1B\u001b[22m\u001b[K\r\u001b[2C\u001b[1B1. \u001b[1mCache ignores env overrides.\u001b[22m The\u001b[39Gcache file\u001b[50Gisn't keyed by\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mPXPIPE_STATUS_URL\u001b[39m/\u001b[38;5;153mPXPIPE_EVENTS\u001b[39m, so a t\u001b[43Gst run wi\u001b[53Gh\u001b[55Gan\u001b[58Goverride (exactly\u001b[76Gwhat\r\u001b[2C\u001b[1BI did)\u001b[10Gpoisons\u001b[22Greal s\u001b[29Gatusline's view for up\u001b[52Gto\u001b[55G5s\u001b[58G—\u001b[60Gand\u001b[64Gvice\u001b[69Gversa.\u001b[76GFix:\r\u001b[2C\u001b[1Bfold a hash of the URL into the cach\u001b[41Gfilenam\u001b[49G.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mCache write isn't atomic.\u001b[22m Multiple co\u001b[44Gcurrent Claud\u001b[59Gsessions repaint\r\u001b[2C\u001b[1Bsimultaneously; \u001b[38;5;153mprintf > file\u001b[39m can be torn mid-read. The \u001b[38;5;153m|| true\u001b[67G\u001b[39mon \u001b[38;5;153mread\u001b[39m\u001b[K\r\u001b[2C\u001b[1Btolerates\u001b[13Git\u001b[16G(falls\u001b[23Gthrough\u001b[31Gto\u001b[34Grecompute),\u001b[46Gbut\u001b[50Gthe\u001b[54Gclean\u001b[60Gfix\u001b[64Gis\u001b[67Gwrite-to-temp\r\u001b[2C\u001b[1B+ \u001b[38;5;153mmv\u001b[39m.             \u001b[22G     \u001b[56G\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
