[267122.075547, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B\u001b[38;5;246m  ⎿  \u001b[39mAdded \u001b[1m16\u001b[22m lines, removed \u001b[1m1\u001b[22m line\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m72\u001b[12G\u001b[22m        Backend::\u001b[38;5;148mRing\u001b[38;5;231m(url) => \u001b[38;5;148mformat!\u001b[38;5;231m(\u001b[38;5;186m\"ring:{url}\"\u001b[38;5;231m),\r\u001b[7C\u001b[1B\u001b[2m73\u001b[12G\u001b[22m    };\r\u001b[7C\u001b[1B\u001b[2m74\u001b[12G\u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 175 +\u001b[38;5;231m    \u001b[38;5;242m// The daemon owns the ONE DuckDB writer handle on the `me\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;242mtrics` warehouse: opened up front and\u001b[38;5;231m                         \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;5;77m\u001b[48;5;22m 176 +\u001b[38;5;231m    \u001b[38;5;242m// shared BOTH ways — into the brain actor (`Platform::boo\r\u001b[1B\u001b[49m\u001b[39m     \u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;242mt_with_metrics`) and into the\u001b[38;5;231m                                 \r\u001b[5C\u001b[1B\u001b[38;5;77m 177 +\u001b[38;5;231m    \u001b[38;5;242m// `/signal/fold` sink. The organ-as-service seam: while c\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;242mlyffy-brain runs it holds the DuckDB\u001b[38;5;231m                          \r\u001b[5C\u001b[1B\u001b[38;5;77m 178 +\u001b[38;5;231m    \u001b[38;5;242m// single-writer lock, so hooks/CLI land their fold signal\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242ms THROUGH the daem\u001b[31Gn inst\u001b[38Gad of failing\u001b[38;5;231m                       \r\u001b[6C\u001b[1B\u001b[38;5;77m179\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m//\u001b[19Gagainst a l\u001b[31Gcked file. If the warehouse can't open, /si\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mgnal\u001b[17Gfold 503s honestly\u001b[36Gand \u001b[41Ghe acto\u001b[4