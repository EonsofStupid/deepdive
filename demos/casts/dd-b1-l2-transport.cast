[692.332517, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gcontroller. Your DAC fabri\u001b[30G stays sealed; the bridge \u001b[57Ghou\u001b[61Gd terminate\u001b[73Gat\r\u001b[3C\u001b[1Blyffy's edge.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mPost-quantum is free on the QUIC path.\u001b[45G\u001b[22mX25519+ML-KEM\u001b[59Ghybrid\u001b[66Gis\u001b[69Gdefault\u001b[77Gin\r\u001b[2C\u001b[1B2026 TLS/QUIC stacks (rustls included). On the WireGuard path it requires\u001b[77Gthe\r\u001b[2C\u001b[1BRosenpass/PSK-rotation dance\u001b[32G(pre-1.0, experimental even\u001b[60Gin NetBi\u001b[69Gd).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mProposed decision\r\u001b[2C\u001b[1B\u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1m\"Layer 2\" becomes the second layer of the connection — a QUIC-native secure \r\u001b[2C\u001b[1Bdata plane that the HTTP handshake\u001b[38Gupgrades i\u001b[49Gto, not literal ethernet \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mbridging.\u001b[22m Concretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[692.698763, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[13B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[692.801118, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[4Glyffy's edge.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mPost-quantum is free on the QUIC path.\u001b[45G\u001b[22mX25519+ML-KEM\u001b[59Ghybrid\u001b[66Gis\u001b[69Gdefault\u001b[77Gin\r\u001b[2C\u001b[1B2026 TLS/QUIC stacks (rustls included). On the WireGuard path it requires\u001b[77Gthe\r\u001b[2C\u001b[1BRosenpass/PSK-rotation dance\u001b[32G(pre-1.0, experimental even\u001b[60Gin NetBi\u001b[69Gd).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mProposed decision\r\u001b[2C\u001b[1B\u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1m\"Layer 2\" becomes the second layer of the connection — a QUIC-native secure \r\u001b[2C\u001b[1Bdata plane that the HTTP handshake\u001b[38Gupgrades i\u001b[49Gto, not literal ethernet \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mbridging.\u001b[22m Concretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1BHTTP/3 (\u001b[38;5;153mclyffy.local:8787\u001b[39m, mDNS discovery\u001b[45G— unchanged contract).\u001b[K\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
