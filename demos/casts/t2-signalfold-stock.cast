[268411.922854, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[6G\u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;242mnnection; `None` (warehouse didn't open)\u001b[38;5;231m                      \r\u001b[5C\u001b[1B\u001b[38;5;77m 271 +\u001b[38;5;242m/// falls back to `Platform::boot`, which re-attempts and repo\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;242mrts the storage error as the brain state.\u001b[38;5;231m                     \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 272 \u001b[22m \u001b[38;5;81mfn\u001b[38;5;231m \u001b[38;5;148mbrain_actor\u001b[38;5;231m(\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 273 \u001b[22m     cfg: ClyffyConfig,\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 274 \u001b[22m     rx: mpsc::Receiver<Job>,\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m75\u001b[16G\u001b[22mstate\u001b[22G Arc<RwLock<B\u001b[36GainState>>,\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m76\u001b[16G\u001b[22mbackend: Backend,\r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 277 +\u001b[38;5;231m    metrics: \u001b[38;5;148mOption\u001b[38;5;231m<Arc<Analytics>>,                          \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 278 \u001b[22m ) {\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;5;231m\u001b[2m 279 \u001b[22m     \u001b[38;5;81mlet\u001b[38;5;231m rt = \u001b[38;5;197mmatch\u001b[38;5;231m tokio::runtime::Builder::\u001b[38;5;148mnew_current_thread\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m     \u001b[22m ().\u001b[38;5;148menable_all\u001b[38;5;231m().\u001b[38;5;148mbuild\u001b[38;5;231m() {\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;5;231m\u001b[2m 280 \u001b[22m         \u001b[38;5;148mOk\u001b[38;5;231m(rt) => rt,\u001b[39m\u001b[K\r\u001b[9C\u001b[2B\u001b[38;5;174mrap\u001b[39m\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
