[701.80242, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gs\u001b[5Gssions) perfectly.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEdge termination.\u001b[22m The tunnel lands on clyffy-01's LAN\u001b[59Gface; the DAC fabric\r\u001b[2C\u001b[1Bn\u001b[5Gver sees a client MAC.\u001b[28GIf\u001b[31GDevPulse\u001b[40Gever\u001b[45Gneeds\u001b[51Gdiscovery-style\u001b[67Gbroadcast\r\u001b[2C\u001b[1Bsemantics, we solve\u001b[23Git with an\u001b[34GmDNS reflector, not bridging.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCrypto:\u001b[22m hybrid X25519+ML-KEM (ru\u001b[38Gtls default), devic\u001b[58G-keypair\u001b[67Genrollment\u001b[78Gvia\r\u001b[2C\u001b[1Bthe HTTP control plane, and\u001b[32G \u001b[1mhash-chained tamper-evident session ledger in \r\u001b[2C\u001b[1Bconnec\u001b[11Gme\u001b[22m — the\u001b[20Gblockchain-shaped property you asked for, without cons\u001b[76Gsus\u001b[K\r\u001b[2C\u001b[1Bov\u001b[6Grhead.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mHonesty gate (no-reward-hacking):\u001b[22m befo\u001b[44Ge we declare\u001b[57Gvictory, the\u001b[70GQUIC fast\r\u001b[2C\u001b[1Bpath gets\u001b[13Gbenchmarked\u001b[25Gagainst\u001b[33Ga\u001b[35Gplain\u001b[41Grkyv-over-TCP\u001b[55Gstream\u001b[62Gon\u001b[65Gthe\u001b[69Gsame\u001b[74GLAN.\u001b[79GIf\r\u001b[2C\u001b[1Bit can't hold ~wire-speed on the local path, th\u001b[51G f\u001b[54Gllback candidate is\u001b[K\r\u001b[2C\u001b[1Bembedd\u001b[10Gd WireGuard via NepTUN+smo\u001b[37Gtcp\u001b[41G— kept alive in the n\u001b[63Gtes, not built\u001b[79G\u001b[K\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[702.273827, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G- \u001b[1mEdge termination.\u001b[22m The\u001b[27Gtunnel\u001b[34Glands\u001b[40Gon\u001b[43Gclyffy-01's\u001b[55GLAN\u001b[59Gface;\u001b[65Gthe\u001b[69GDAC\u001b[73Gfabric\r\u001b[2C\u001b[1Bnever sees a client\u001b[23GMAC. If DevPulse\u001b[40Gever needs di\u001b[54Gcovery-style broadcast\u001b[K\r\u001b[2C\u001b[1Bs\u001b[5Gmantics,\u001b[14Gwe solve\u001b[23Git with\u001b[31Gan mDNS r\u001b[41Gflector, not bridging.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCrypto:\u001b[22m hybrid X25519+ML-KEM\u001b[34G(rustls d\u001b[44Gfault), device-keypair\u001b[67Genrollment\u001b[78Gvia\r\u001b[2C\u001b[1Bthe HTTP cont\u001b[17Gol\u001b[20Gplane, and a \u001b[1mhash-chained tamper-evident session ledger in \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mconnectome\u001b[22m — the\u001b[20Gb\u001b[22Gockch\u001b[28Gin-shaped property you asked for, without consensus\r\u001b[2C\u001b[1Boverhead.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mHonesty gate (no-reward-hacking):\u001b[39G\u001b[22mbefore\u001b[46Gwe\u001b[49Gdeclare\u001b[57Gvictory,\u001b[66Gthe\u001b[70GQUIC\u001b[75Gfast\r\u001b[2C\u001b[1Bpath gets benchmarked against a plain rkyv-over-TCP stream on the same LAN. If\r\u001b[2C\u001b[1Bit can'\u001b[11G hold ~wi\u001b[21Ge-speed on the \u001b[37Gocal path, the fallback ca\u001b[64Gdidate is\u001b[74G\u001b[K\r\u001b[2C\u001b[1Bembedded\u001b[12GWireGuard via NepTUN+smo\u001b[37Gt\u001b[39Gp — kept\u001b[48Galive in the\u001b[61Gnotes, not built.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat this supersedes:\u001b[25G\u001b[22mthe\u001b[29Graw-ethernet/AF_PACKET/AF_XDP/RoCE\u001b[64Gcandidates\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
