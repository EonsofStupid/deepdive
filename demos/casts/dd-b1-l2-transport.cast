[693.272276, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G2026 TLS/QUIC stacks\u001b[24G(rustls\u001b[32Gincluded).\u001b[43GOn\u001b[46Gthe\u001b[50GWireGuard\u001b[60Gpath\u001b[65Git\u001b[68Grequires\u001b[77Gthe\r\u001b[2C\u001b[1BRosenpass/PSK-rotation dance (pre-1.0, experimental even in NetBir\u001b[70G).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mProposed decision\u001b[22m\u001b[K\r\u001b[2C\u001b[2B\u001b[1m\"Layer 2\" becomes the second layer of the connection — a QUIC-native secure \r\u001b[2C\u001b[1Bdata plane that the HTTP handshake upgrades into, not literal ethernet \r\u001b[2C\u001b[1Bbridging.\u001b[22m Concretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1BHTTP/3\u001b[10G(\u001b[38;5;153mclyffy.local:8787\u001b[39m,\u001b[30GmDNS\u001b[35Gdiscovery\u001b[45G—\u001b[47Gunchanged\u001b[57Gcontract).\r\u001b[2C\u001b[1BEnrollment/auth happens there, then the \u001b[3msame connection\u001b[59G\u001b[23mop\u001b[62Gns dedicated\u001b[K\r\u001b[2C\u001b[1Bstreams + unreliable datagrams as the fast path: rkyv\u001b[57Gzero-copy frames,\u001b[75Gno\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[693.742938, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3GRosenpass/PSK-rotation dance\u001b[32G(pre-1.0, experimental even\u001b[60Gin NetBi\u001b[69Gd).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mProposed decision\r\u001b[2C\u001b[1B\u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1m\"Layer 2\" becomes the second layer of the connection — a QUIC-native secure \r\u001b[2C\u001b[1Bdata plane that the HTTP handshake\u001b[38Gupgrades i\u001b[49Gto, not literal ethernet \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mbridging.\u001b[22m Concretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1BHTTP/3 (\u001b[38;5;153mclyffy.local:8787\u001b[39m, mDNS discovery\u001b[45G— unchanged contract).\u001b[K\r\u001b[2C\u001b[1BEnrollment/auth happens there, then th\u001b[42G \u001b[3msame connection\u001b[23m opens dedicated\r\u001b[2C\u001b[1Bst\u001b[6Geams + unreliable datagrams\u001b[34Gas the fast path: rkyv zero-copy frames,\u001b[75Gno\r\u001b[2C\u001b[1BJSON, no per-request\u001b[24Goverhe\u001b[31Gd.\u001b[34GThis is the\u001b[46Gli\u001b[49Geral \"goes from HTTP to the\u001b[K\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
