[302592.398016, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B \u001b[3G\u001b[38;5;246mRan \u001b[1m2\u001b[22m shell commands \u001b[39m\u001b[K\r\u001b[2B\u001b[38;5;231m●\u001b[3G\u001b[39mAll applied and verified. Summary\u001b[37Gof\u001b[40Gwhat\u001b[45Gchanged\u001b[53Gin\u001b[56G\u001b[38;5;153mstatusline-pxpipe.sh\u001b[39m:\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mMechanical fixes (1, 2, 5, 10)\u001b[22m\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCache keyed per config\u001b[22m — filenam\u001b[38G now \u001b[44Gncludes a\u001b[54G\u001b[38;5;153mcksum\u001b[39m of\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mPXPIPE_STATUS_URL|PXPIPE_EVENTS\u001b[39m, so ov\u001b[42Grridden test\u001b[55Gruns\u001b[60Gand\u001b[64Gthe\u001b[68Greal\r\u001b[2C\u001b[1Bstatusline each get thei\u001b[28G own cache. Verified:\u001b[50Gthe up/d\u001b[59Gw\u001b[62Gt\u001b[64Gst abov\u001b[72G produced\r\u001b[2C\u001b[1Btwo distinct c\u001b[18Gche fil\u001b[26Gs with\u001b[33Gindependent\u001b[45Gstates.\r\u001b[4C\u001b[1B\u001b[1mAtomic ca\u001b[15Ghe write\u001b[22m — write to \u001b[38;5;153m$CACHE.$$\u001b[39m then\u001b[50G\u001b[38;5;153mmv -f\u001b[39m;\u001b[57Gtorn reads under\u001b[K\r\u001b[2C\u001b[1Bc\u001b[5Gncu\u001b[9Grent repa\u001b[20Gts a\u001b[25Ge\u001b[27Ggone.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mBounded scan\u001b[22m — \u001b[38;5;153mtail -c 2MiB\u001b[39m bef\u001b[37Gre the grep, s\u001b[52G the <100ms\u001b[64Gbudget survives\u001b[80G\u001b[K\r\u001b[2C\u001b[1Blog growth; a line torn\u001b[27Gby\u001b[30Gthe\u001b[34Gbyte\u001b[39Gcut\u001b[43G(and\u001b[48Gany\u001b[52Gother\u001b[58Ggarbage\u001b[66Gline)\u001b[72Gis\r\u001b[2C\u001b[1Bskipped by \u001b[38;5;153mfromjson?\u001b[35G\u001b[39mpoisoning\u001b[45Gthe whole\u001b[55G\u001b[38;5;153mjq\u001b[58G\u001b[39mslurp\u001b[64G—\u001b[66Gverified\u001b[75Gwith\u001b[80Ga\r\u001b[2C\u001b[1Bsynthetic\u001b[13Gtorn\u001b[18Gline.\r\u001b[2C\u001b[1B- \u001b[38;5;153m\u001b[1m/tmp/claude-${UID}\u001b[22m\u001b[39m ins\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
