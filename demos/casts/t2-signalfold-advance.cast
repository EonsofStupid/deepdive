[267123.5906, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[6C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m356\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m// failure honestly through BrainState::Failed.\r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[16G\u001b[38;5;81mlet\u001b[38;5;231m boot = \u001b[38;5;197mmatch\u001b[38;5;231m metrics {                                \r\u001b[6C\u001b[1B\u001b[38;5;77m358\u001b[12G\u001b[38;5;231m        \u001b[38;5;148mSome\u001b[38;5;231m(m) => Platform::\u001b[38;5;148mboot_with_metrics\u001b[38;5;231m(cfg,\u001b[64Gm),\r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[16G\u001b[38;5;231m    \u001b[38;5;141mNone\u001b[38;5;231m => Platform::\u001b[38;5;148mboot\u001b[38;5;231m(cfg),               \r\u001b[7C\u001b[1B\u001b[38;5;77m60\u001b[16G\u001b[38;5;231m}; \u001b[20G    \u001b[25G \u001b[27G     \u001b[33G       \u001b[41G \r\u001b[7C\u001b[1B\u001b[38;5;77m61\u001b[16G\u001b[38;5;81mlet\u001b[20G\u001b[38;5;231mplatform =\u001b[31G\u001b[38;5;197mmatch\u001b[38;5;231m boot {                    \u001b[64G   \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 362 \u001b[22m         \u001b[38;5;148mOk\u001b[38;5;231m(p) => {\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 363 \u001b[22m             *state.\u001b[38;5;148mwrite\u001b[38;5;231m().\u001b[38;5;148munwrap\u001b[38;5;231m() = BrainState::Ready;\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 364 \u001b[22m             p\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;114m●\u001b[3G\u001b[39m\u001b[1mUpdate\u001b[22m(\u001b]8;id=1rj0eus;file:///home/hades/clyffy/landing/study/t2/b/interfaces/clyffy-brain/src/main.rs\u0007interfaces/clyffy-brain/src/main.rs\u001b]8;;\u0007)\u001b[K\r\u001b[1B\u001b[38;5;246m  ⎿  \u001b[39mAdded \u001b[1m153\u001b[22m lines\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 631 \u001b[22m     Sse::\u001b[38;5;148mnew\u001b[38;5;231m(stream).\u001b[38;5;148mkeep_alive\u001b[38;5;231m(KeepAlive::\u001b[38;5;148