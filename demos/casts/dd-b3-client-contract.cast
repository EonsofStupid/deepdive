[29891.585599, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bper-stream cursors), det\u001b[28Gch\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153mPOST /v1/sessions/{id}/preflight\u001b[39m,\u001b[39G\u001b[38;5;153m/bypass/arm\u001b[39m,\u001b[52G\u001b[38;5;153m/bypass/disarm\r\u001b[27C\u001b[1Bwork-\u001b[34Gtems\u001b[39G\u001b[39m(dispatch ceremony — what the\u001b[69Gphone\u001b[75GQR\r\u001b[2C\u001b[1Bflow calls)\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153mGET /capabilities\u001b[23G\u001b[39mgrows\u001b[29Ga\u001b[31G\u001b[38;5;153mcontract_version\u001b[48G\u001b[39m+\u001b[50Gfeature\u001b[58Gflags\u001b[64G→\u001b[66Gthis\u001b[71Gis\u001b[74Ghow\u001b[78Gwe\r\u001b[2C\u001b[1Bversion the whole thing without breaking old\u001b[48Gcli\u001b[52Gn\u001b[54Gs.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m2. Data plane (QUIC streams after attach).\u001b[46G\u001b[22mProposed\u001b[55Gstream\u001b[62Gmap:\u001b[67Gone\r\u001b[2C\u001b[1Bclient→server \u001b[1mingestion stre\u001b[32Gm\u001b[22m per source (FlatBuffers frames, idempotent\r\u001b[2C\u001b[1Bframe keys), one server→client\u001b[34G\u001b[1moutbox stream\u001b[22m (results replayed\u001b[66Gfro\u001b[70G your\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[29891.601658, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B- \u001b[38;5;153mPOST /v1/sessions/{id}/preflight\u001b[39m,\u001b[39G\u001b[38;5;153m/bypass/arm\u001b[39m,\u001b[52G\u001b[38;5;153m/bypass/disarm\r\u001b[27C\u001b[1Bwork-\u001b[34Gtems\u001b[39G\u001b[39m(dispatch ceremony — what the\u001b[69Gphone\u001b[75GQR\r\u001b[2C\u001b[1Bflow calls)\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153mGET /capabilities\u001b[23G\u001b[39mgrows\u001b[29Ga\u001b[31G\u001b[38;5;153mcontract_version\u001b[48G\u001b[39m+\u001b[50Gfeature\u001b[58Gflags\u001b[64G→\u001b[66Gthis\u001b[71Gis\u001b[74Ghow\u001b[78Gwe\r\u001b[2C\u001b[1Bversion the whole thing without breaking old\u001b[48Gcli\u001b[52Gn\u001b[54Gs.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m2. Data plane (QUIC streams after attach).\u001b[46G\u001b[22mProposed\u001b[55Gstream\u001b[62Gmap:\u001b[67Gone\r\u001b[2C\u001b[1Bclient→server \u001b[1mingestion stre\u001b[32Gm\u001b[22m per source (FlatBuffers frames, idempotent\r\u001b[2C\u001b[1Bframe keys), one server→client\u001b[34G\u001b[1moutbox stream\u001b[22m (results replayed\u001b[66Gfro\u001b[70G your\u001b[K\r\u001b[2C\u001b[1Battach cursor), datagrams r\u001b[31Gserved for lossy\u001b[48Gnicetie\u001b[57G(progr\u001b[64Gss ticks,\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[29891.609267, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bflow calls)\u001b[K\r\u001b[4C\u001b[1B\u001b[38;5;153mGET /capabilitie\u001b[22G\u001b[39m grows a \u001b[38;5;153mcon\u001b[35Gract_version\u001b[39m + feature\u001b[58Gflags → this is how\u001b[78Gwe\r\u001b[2C\u001b[1Bversion the\u001b[15Gwhole\u001b[21Gthing\u001b[27Gwithout\u001b[35Gbreaking\u001b[44Gold\u001b[48Gclients.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m2. Data plane (QUIC streams after attach).\u001b[22m Proposed stream\u001b[62Gmap:\u001b[67Gone\r\u001b[2C\u001b[1Bclient→server\u001b[17G\u001b[1mingestion stream\u001b[34G\u001b[22mper\u001b[38Gsource\u001b[45G(FlatBuffers\u001b[58Gframes,\u001b[66Gidempotent\r\u001b[2C\u001b[1Bframe keys), one server→client \u001b[1moutbox stream\u001b[22m (re\u001b[52Gult\u001b[56G \u001b[59Gplayed from\u001b[71Gyour\r\u001b[2C\u001b[1Battach cu\u001b[13Gso\u001b[16G), datagrams reserv\u001b[36Gd\u001b[38Gf\u001b[40Gr lossy niceti\u001b[55Gs (p\u001b[60Gogress ticks,\u001b[K\r\u001b[2C\u001b[1Btyping/VH1-styl\u001b[21Gtatus) that are legal to drop.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[29891.627176, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1m2. Data plane (QUIC streams after attach).\u001b[46G\u001b[22mProposed\u001b[55Gstream\u001b[62Gmap:\u001b[67Gone\r\u001b[2C\u001b[1Bclient→server \u001b[1mingestion stream\u001b[22m per source (FlatBuffe\u001b[56Gs\u001b[59Gr\u001b[61Gmes,\u001b[66Gidempotent\u001b[K\r\u001b[2C\u001b[1Bframe keys), one server→client \u001b[1moutbox stream\u001b[48G\u001b[22m(results\u001b[57Greplayed\u001b[66Gfrom\u001b[71Gyour\r\u001b[2C\u001b[1Battach\u001b[10Gcursor),\u001b[19Gdatagrams\u001b[29Greserved\u001b[38Gfor\u001b[42Glossy\u001b[48Gniceties\u001b[57G(progress\u001b[67Gticks,\r\u001b[2C\u001b[1Btyping/VH1-style status) that are legal to\u001b[46Gd\u001b[50G.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. The first real fork in the r\u001b[35Gad — whe\u001b[45G does \u001b[38;5;153m/converse\u001b[39m live?\u001b[22m\u001b[K\r\u001b[2C\u001b[1B- \u001b[1m(a) Converse moves onto the fast path too\u001b[22m o\u001b[49Gce attached — HTTP keeps\u001b[74Gonly\r\u001b[2C\u001b[1Bbootstrap/ceremony. One contract,\u001b[37Geverything session-scoped,\u001b[64Greplayable\u001b[75Gfrom\r\u001b[2C\u001b[1Bthe\u001b[7Goutbox\u001b[14G(a\u001b[17Gdropped\u001b[25Gclient\u001b[32Gre-attaches\u001b[44Gand\u001b[48Gsees\u001b[53Gthe\u001b[57Ganswer\u001b[64Git\u001b[67Gmissed\u001b[74G—\u001b[76Gwhich\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[29900.003624, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bclient→server \u001b[1mingestion stre\u001b[32Gm\u001b[22m per source (FlatBuffers frames, idempotent\r\u001b[2C\u001b[1Bframe keys), one server→client\u001b[34G\u001b[1moutbox stream\u001b[22m (results replayed\u001b[66Gfro\u001b[70G your\u001b[K\r\u001b[2C\u001b[1Battach cursor), datagrams r\u001b[31Gserved for lossy\u001b[48Gnicetie\u001b[57G(progr\u001b[64Gss ticks,\u001b[K\r\u001b[2C\u001b[1Btyping/VH1-style s\u001b[23Gtus) that ar\u001b[36G legal to drop.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. The first real fork in the road — where does \u001b[38;5;153m/converse\u001b[39m live?\r\u001b[2C\u001b[1B\u001b[22m- \u001b[1m(a) Converse moves onto\u001b[33Gfast\u001b[38Gpat\u001b[42G too\u001b[22m once attached — HTTP\u001b[68Gkeeps\u001b[74Gonly\r\u001b[2C\u001b[1Bbootstrap/ceremony. One contract, everything session-scoped, replayable from\r\u001b[2C\u001b[1Bthe outbox (a dropped clie\u001b[31G re-attaches a\u001b[46Gd\u001b[50Ge\u001b[52G the answer\u001b[64Git missed — which\r\u001b[2C\u001b[1Bis y\u001b[9Gr neutral-s\u001b[21Gace\u001b[25Grequirem\u001b[34Gnt working for chat, not just\u001b[65Gngestion).\u001b[76G\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
