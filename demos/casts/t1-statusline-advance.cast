[301685.095772, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bonly for li\u001b[15Ges\u001b[18Gwith\u001b[23G\u001b[38;5;153mbaseline_probe_status == \"ok\"\u001b[39m,\u001b[54Gclamped\u001b[62Gat\u001b[65G0,\u001b[68Grendered\u001b[77Gas\r\u001b[2C\u001b[1B\u001b[38;5;153mk\u001b[39m/\u001b[38;5;153mM\u001b[39m. Omitted entirely if the file is missing/unreadable\u001b[59Gor\u001b[62Gthe\u001b[66Gsum\u001b[70Gis 0.\u001b[76GNote\r\u001b[2C\u001b[1Bit's an approximation — it counts cache-r\u001b[46Gd tokens at\u001b[58Gpar even though\u001b[74Gthey're\r\u001b[2C\u001b[1Bbi\u001b[6Gled c\u001b[12Geap\u001b[16Gr, so the true cost saving i\u001b[45G somewhat higher than the token\u001b[K\r\u001b[2C\u001b[1Bfigure shown.\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mSpeed:\u001b[12G\u001b[22msame\u001b[17G5s\u001b[20Gcache\u001b[26Gas\u001b[29Gthe\u001b[33Greference\r\u001b[2C\u001b[1B(\u001b[38;5;153m/tmp/claude-1000/pxpipe-status.cache\u001b[39m).\u001b[43GMeasured:\u001b[53G15ms\u001b[58Gcold,\u001b[64G5ms\u001b[68Gwarm,\u001b[74G18ms\r\u001b[2C\u001b[1Bcold with the proxy down (connection-refused on loopback is\u001b[63Ginstant; a \u001b[3mhung\r\u001b[2C\u001b[1B\u001b[23mproxy would cost up to the 1s curl cap once pe\u001b[50G 5s window).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mVerified states\r\u001b[4C\u001b[1B\u001b[22mUp: \u001b[38;5;153m⚡ pxpipe ●(green) · 908.2k saved\u001b[39m — the counter moved betwe\u001b[69Gn\u001b[71Gruns\u001b[K\r\u001b[2C\u001b[1B(772.8k → 908.2k) because this very session's requests are\u001b[62Glanding\u001b[70Gin\r\u001b[2C\u001b[1B\u001b[38;5;153mevents.jsonl\u001b[39m, which\u001b[23Gis a ni\u001b[33Glive confirmation the parse is reading the real\r\u001b[2C\u001b[1Bfile.\u001b[K\r\u001b[2C\u001b[1B-\u001b[5GDown\u001b[10G(closed\u001b[18Gport\u001b[23G4789\u001b[56Gll\u001b[59Gshows\u001b[65Gsaved\u001b[71Gcount.\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
