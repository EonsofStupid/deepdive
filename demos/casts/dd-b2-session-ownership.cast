[354.500421, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G- \u001b[1mEstate move = detach + attach\u001b[22m,\u001b[36Gnot\u001b[40Gcopy.\u001b[46GBecause\u001b[54Gthe\u001b[58Gsession\u001b[66Gis\r\u001b[2C\u001b[1Breconstructable from connectome al\u001b[38Gne (the\u001b[46Gr\u001b[49Gon\u001b[52Gtruction rule), moving\u001b[75Gfrom\r\u001b[2C\u001b[1Bd\u001b[5Gvsta\u001b[10Gion to the Wind\u001b[26Gws box is: \u001b[38Gld\u001b[41Ga\u001b[43Gtachment ends, new device attaches,\u001b[K\r\u001b[2C\u001b[1Boutbox replays from \u001b[3mthat device's\u001b[37G\u001b[23mlast-seen cursor. Per-attachment cursor\r\u001b[2C\u001b[1Bno\u001b[6G per-session — that's the one schema d\u001b[45Gtail the estate move forces.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mQR ceremony\u001b[22m: the QR encod\u001b[31Gs a short-liv\u001b[45Gd boo\u001b[51Gstrap token + clyffy's\r\u001b[2C\u001b[1Bendpoint + key\u001b[18Gfingerprint. Phone scans → hits \u001b[51Ghe HTTP co\u001b[62Gtrol plane →\r\u001b[4C\u001b[1Brolls its own device keypair (branch 1's enrollment flow, unchanged) →\u001b[76Ggets\r\u001b[2C\u001b[1Ba \u001b[38;5;153mdispatcher\u001b[39m attachment. Preflight = dry-run \u001b[49Geport over the control plane\u001b[K\r\u001b[2C\u001b[1B(\"this will run X against Y, estimate\u001b[41G Z\") →\u001b[48Gyou confirm\u001b[60G→ clyffy runs it,\r\u001b[2C\u001b[1Bsess\u001b[8Gon goes Adrift-w\u001b[25Gth-work, results\u001b[42Gland in the outbox for whatever\u001b[74Gdevice\r\u001b[2C\u001b[1Battaches n\u001b[14Gxt. Tha\u001b[22G last pa\u001b[31Gt is the neutral-spac\u001b[54Gmodel paying off: the phone\r\u001b[2C\u001b[1Bdoesn't have to stay connected to k\u001b[39Gep the di\u001b[51Gtch running.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BSo:\u001b[7G\u001b[1mv1 = single-device sessions; the ledger is born multi-attach.\u001b[69G\u001b[22mDispatches\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[355.049732, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gdevstation to the Windows box is: \u001b[38Gld attachment \u001b[53Gnds,\u001b[58Gn\u001b[60Gw device\u001b[69Gattaches,\r\u001b[2C\u001b[1Boutbox \u001b[11Gepl\u001b[15Gys from \u001b[3mthat device's\u001b[23m last-se\u001b[45Gn cursor. Per-attachment cursors,\u001b[K\r\u001b[2C\u001b[1Bnot per-session —\u001b[21Gthat's the one schem\u001b[42G detail \u001b[51Gh\u001b[53G e\u001b[56Gtat\u001b[60G move forces.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mQR ceremony\u001b[22m:\u001b[18Gthe QR encodes a short-liv\u001b[45Gd\u001b[47Gbootstrap token + clyffy's\u001b[K\r\u001b[2C\u001b[1Bendpoint + key fingerprin\u001b[29G. Phone scans\u001b[43G→ hits\u001b[54GHTTP control plane →\r\u001b[2C\u001b[1Benrolls its own d\u001b[21Gvice keypair (branch 1's enr\u001b[50Gllment\u001b[57Gflow,\u001b[63Gun\u001b[66Ghanged)\u001b[74G→\u001b[76Ggets\r\u001b[2C\u001b[1Ba \u001b[38;5;153mdispatcher\u001b[39m attachment. Preflight = dry-run report over the control plane\r\u001b[2C\u001b[1B(\"this w\u001b[12Gll\u001b[15Gru\u001b[19GX against Y, estim\u001b[38Gted\u001b[42GZ\")\u001b[46G→ y\u001b[50Gu co\u001b[55Gfirm → clyffy runs\u001b[74Git,\u001b[K\r\u001b[2C\u001b[1Bsession goes\u001b[16GAdrift-wi\u001b[26Gh-work, results land in the outbox for whatever device\r\u001b[2C\u001b[1Bat\u001b[6Gaches next. That last part is the neutral-space model\u001b[60Gpaying off: the phone\r\u001b[2C\u001b[1Bdoe\u001b[7Gn't\u001b[11Ghave\u001b[16Gto stay connected\u001b[34Gto keep\u001b[42Gthe d\u001b[48Gspatch running.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BS\u001b[5G: \u001b[1mv1 = single-device sessions; the ledger is born multi-attach.\u001b[69G\u001b[22mDispatches\r\u001b[2C\u001b[1Band\u001b[7Gestate\u001b[14Gmoves\u001b[20Gare\u001b[24Glater\u001b[30Gceremonies\u001b[41Gon\u001b[44Gan\u001b[47Galready-correct\u001b[63Gschema.\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
