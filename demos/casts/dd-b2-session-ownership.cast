[350.952879, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G-\u001b[5G\u001b[38;5;153msession\u001b[13G\u001b[39m←→\u001b[16G\u001b[38;5;153mattachment\u001b[27G\u001b[39m←→\u001b[30G\u001b[38;5;153mdevice\u001b[37G\u001b[39min\u001b[40Gthe\u001b[44Gconnectome\u001b[55Gschema.\u001b[63GV1\u001b[66Gships\u001b[72Gwith\u001b[77Ga\r\u001b[2C\u001b[1Bpolicy knob (\u001b[38;5;153mmax_liv\u001b[24G_attachments = 1\u001b[39m), not a hardcoded assumption. Estate\u001b[K\r\u001b[2C\u001b[1Bm\u001b[5Gves and phone dispatch then become \u001b[3mpolicy and ceremony changes, not schema \r\u001b[2C\u001b[1Bmigrations\u001b[23m — which is exactly\u001b[33Gthe trap we're avoiding by deciding this now.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mAttachment gets a \u001b[38;5;153mrole\u001b[39m field\u001b[22m now: \u001b[38;5;153mprimary\u001b[39m (full data plane — the\u001b[K\r\u001b[2C\u001b[1Bdevstation), \u001b[38;5;153mdispatcher\u001b[39m (control-plane only\u001b[47G— what the\u001b[59Gho\u001b[64Gis), \u001b[38;5;153mspectator\r\u001b[2C\u001b[1B\u001b[39m(read-only, reserved). A phone disp\u001b[39Gtch \u001b[44Gever\u001b[49Gneeds the QUIC\u001b[64Gfast\u001b[69Gpath; it\u001b[K\r\u001b[2C\u001b[1Bne\u001b[6Gds the HTTP/3 control\u001b[29Gla\u001b[34Gto \u001b[38Greflight and fire. So \"deploy vi\u001b[71G phone\"\r\u001b[2C\u001b[1Bcost\u001b[9Galmost nothing extra o\u001b[32G the\u001b[37Gt\u001b[39Ganspor\u001b[47Gsi\u001b[50Ge — branch 1's design\u001b[72Galready\r\u001b[2C\u001b[1Bsplit\u001b[9Gcontrol from data.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEstate move = detach + attach\u001b[22m,\u001b[36Gnot\u001b[40Gcopy.\u001b[46GBecause\u001b[54Gthe\u001b[58Gsession\u001b[66Gis\r\u001b[2C\u001b[1Breconstructable from connectome al\u001b[38Gne (the\u001b[46Gr\u001b[49Gon\u001b[52Gtruction rule), moving\u001b[75Gfrom\r\u001b[2C\u001b[1Bd\u001b[5Gvsta\u001b[10Gion to the Wind\u001b[26Gws box is: \u001b[38Gld\u001b[41Ga\u001b[43Gtachment ends, new device attaches,\u001b[K\r\u001b[2C\u001b[1Boutbox replays from \u001b[3mthat device's\u001b[37G\u001b[23mlast-seen cursor. Per-attachment cursor\r\u001b[2C\u001b[1Bno\u001b[6G per-session — that's the one schema d\u001b[45Gtail the estate move forces.\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[351.246486, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gpolicy knob (\u001b[38;5;153mmax_liv\u001b[24G_attachments = 1\u001b[39m), not a hardcoded assumption. Estate\u001b[K\r\u001b[2C\u001b[1Bm\u001b[5Gves and phone dispatch then become \u001b[3mpolicy and ceremony changes, not schema \r\u001b[2C\u001b[1Bmigrations\u001b[23m — which is exactly\u001b[33Gthe trap we're avoiding by deciding this now.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mAttachment gets a \u001b[38;5;153mrole\u001b[39m field\u001b[22m now: \u001b[38;5;153mprimary\u001b[39m (full data plane — the\u001b[K\r\u001b[2C\u001b[1Bdevstation), \u001b[38;5;153mdispatcher\u001b[39m (control-plane only\u001b[47G— what the\u001b[59Gho\u001b[64Gis), \u001b[38;5;153mspectator\r\u001b[2C\u001b[1B\u001b[39m(read-only, reserved). A phone disp\u001b[39Gtch \u001b[44Gever\u001b[49Gneeds the QUIC\u001b[64Gfast\u001b[69Gpath; it\u001b[K\r\u001b[2C\u001b[1Bne\u001b[6Gds the HTTP/3 control\u001b[29Gla\u001b[34Gto \u001b[38Greflight and fire. So \"deploy vi\u001b[71G phone\"\r\u001b[2C\u001b[1Bcost\u001b[9Galmost nothing extra o\u001b[32G the\u001b[37Gt\u001b[39Ganspor\u001b[47Gsi\u001b[50Ge — branch 1's design\u001b[72Galready\r\u001b[2C\u001b[1Bsplit\u001b[9Gcontrol from data.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEstate move = detach + attach\u001b[22m,\u001b[36Gnot\u001b[40Gcopy.\u001b[46GBecause\u001b[54Gthe\u001b[58Gsession\u001b[66Gis\r\u001b[2C\u001b[1Breconstructable from connectome al\u001b[38Gne (the\u001b[46Gr\u001b[49Gon\u001b[52Gtruction rule), moving\u001b[75Gfrom\r\u001b[2C\u001b[1Bd\u001b[5Gvsta\u001b[10Gion to the Wind\u001b[26Gws box is: \u001b[38Gld\u001b[41Ga\u001b[43Gtachment ends, new device attaches,\u001b[K\r\u001b[2C\u001b[1Boutbox replays from \u001b[3mthat device's\u001b[37G\u001b[23mlast-seen cursor. Per-attachment cursor\r\u001b[2C\u001b[1Bno\u001b[6G per-session — that's the one schema d\u001b[45Gtail the estate move forces.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mQR ceremony\u001b[22m: the QR encod\u001b[31Gs a short-liv\u001b[45Gd boo\u001b[51Gstrap token + clyffy's\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
