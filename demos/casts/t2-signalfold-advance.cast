[267123.574495, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 352 +\u001b[38;5;231m    metrics: \u001b[38;5;148mOption\u001b[38;5;231m<Arc<Analytics>>,                          \r\u001b[6C\u001b[1B\u001b[49m\u001b[2m353\u001b[12G\u001b[22m)\u001b[14G{\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;167m\u001b[48;5;52m 353 -\u001b[38;5;231m    let platform = match Platform::boot(cfg) {                \r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 354 +\u001b[38;5;231m    \u001b[38;5;242m// Boot against the daemon-owned warehouse handle when mai\r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;242mn() opened it (DuckDB single-writer —\u001b[38;5;231m                         \r\u001b[1B\u001b[49m\u001b[39m     \u001b[38;5;77m\u001b[48;5;22m 355 +\u001b[38;5;231m    \u001b[38;5;242m// ONE handle, shared with /signal/fold); fall back to sel\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;242mf-opening, which reports the same\u001b[38;5;231m                             \r\u001b[5C\u001b[1B\u001b[38;5;77m 356 +\u001b[38;5;231m    \u001b[38;5;242m// failure honestly through BrainState::Failed.\u001b[38;5;231m           \r\u001b[5C\u001b[1B\u001b[38;5;77m 357 +\u001b[38;5;231m    \u001b[38;5;81mlet\u001b[38;5;231m boot = \u001b[38;5;197mmatch\u001b[38;5;231m metrics {                                \r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[16G\u001b[38;5;231m    \u001b[38;5;148mSome\u001b[38;5;231m(m) => Platform::\u001b[38;5;148mboot_with_metrics\u001b[38;5;231m(cfg,\u001b[64Gm),\r\u001b[5C\u001b[1B\u001b[38;5;77m 359 +\u001b[38;5;231m        \u001b[38;5;141mNone\u001b[38;5;231m => Platform::\u001b[38;5;148mboot\u001b[38;5;231m(cfg),                          \r\u001b[5C\u001b[1B\u001b[38;5;77m 360 +\u001b[38;5;231m    };                                                        \r\u001b[7C\u001b[1B\u001b[38;5;77m61\u001b[16G\u001b[38;5;81mlet\u001b[38;5;231m platform = \u001b[38;5;19