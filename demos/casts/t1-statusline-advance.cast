[302617.649802, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bso it must stay GET.\u001b[K\r\u001b[4C\u001b[1B\u001b[1mLocal day (4)\u001b[22m — \"today\" is now\u001b[36Gthe local \u001b[47Galendar\u001b[55Gday converted\u001b[69Gto\u001b[72Ga UTC\u001b[K\r\u001b[2C\u001b[1Brange\u001b[9G(\u001b[38;5;153mdate -u -d \"$(date +%F) 00:00\"\u001b[41G\u001b[39m→\u001b[43G+1\u001b[46Gday),\u001b[52Ggrep\u001b[57Gpre-filters\u001b[69Gon\u001b[72Gboth\r\u001b[2C\u001b[1Bpossible UTC date\u001b[21Gprefixes, jq does the exa\u001b[47Gt range\u001b[55Gcompare. No more\u001b[72G8pm-local\r\u001b[3C\u001b[1Beset.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCost-weighted metric (7)\u001b[22m — actual\u001b[39G= \u001b[38;5;153minput + 1.25·cache_create + \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m0.1·cache_read\u001b[39m;\u001b[19Gbaseline\u001b[28G=\u001b[30Gnon-cacheable\u001b[44Gat\u001b[47G1.0\u001b[51Gplus\u001b[56G\u001b[38;5;153mbaseline_cacheable_tokens\r\u001b[2C\u001b[1B\u001b[39mweighted by the cache phase the request actually hit (0.1 if it was\u001b[71Gmostly\u001b[78Ga\r\u001b[2C\u001b[1Bread, else 1.25\u001b[19G— i.e. same cache lifecycle\u001b[47Gassumed without pxpipe). Rendered\u001b[K\r\u001b[3C\u001b[1Bith a \u001b[38;5;153m~\u001b[12G\u001b[39mto\u001b[15Gflag it's\u001b[25Gan estimate. Effect on real data: today went fr\u001b[73Gm 908k\r\u001b[3C\u001b[1Baw tokens\u001b[14Gto \u001b[1m~219k cost-weighted\u001b[37G\u001b[22m— the honest number, since most raw\u001b[K\r\u001b[2C\u001b[1B\"savings\" were cache reads.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mNegatives rendered, not clamp\u001b[36G (8)\u001b[22m —\u001b[43Ga lo\u001b[48Ging day shows red \u001b[38;5;153m· ~-4.0k saved\r\u001b[2C\u001b[1B\u001b[39m(ver\u001b[8Gfied\u001b[14Gith\u001b[18Ga synth\u001b[26Gtic day\u001b[34Gwhere\u001b[40Gthe\u001b[44Gproxy\u001b[50Gcost\u001b[55Gmore\u001b[60Gthan\u001b[65Gbaseline).\r\u001b[2C\u001b[1B\u001b[38;5;153mprobe_status != \"ok\"\u001b[39m and out-of-range\u001b[41Glines are excluded (also\u001b[66Gverified).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mProxy-global caveat (9\u001b[56G\u001b[22mblock \u001b[63Glong\u001b[68Gide the\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[302617.667679, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Brange\u001b[9G(\u001b[38;5;153mdate -u -d \"$(date +%F) 00:00\"\u001b[41G\u001b[39m→\u001b[43G+1\u001b[46Gday),\u001b[52Ggrep\u001b[57Gpre-filters\u001b[69Gon\u001b[72Gboth\r\u001b[2C\u001b[1Bpossible UTC date\u001b[21Gprefixes, jq does the exa\u001b[47Gt range\u001b[55Gcompare. No more\u001b[72G8pm-local\r\u001b[3C\u001b[1Beset.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCost-weighted metric (7)\u001b[22m — actual\u001b[39G= \u001b[38;5;153minput + 1.25·cache_create + \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m0.1·cache_read\u001b[39m;\u001b[19Gbaseline\u001b[28G=\u001b[30Gnon-cacheable\u001b[44Gat\u001b[47G1.0\u001b[51Gplus\u001b[56G\u001b[38;5;153mbaseline_cacheable_tokens\r\u001b[2C\u001b[1B\u001b[39mweighted by the cache phase the request actually hit (0.1 if it was\u001b[71Gmostly\u001b[78Ga\r\u001b[2C\u001b[1Bread, else 1.25\u001b[19G— i.e. same cache lifecycle\u001b[47Gassumed without pxpipe). Rendered\u001b[K\r\u001b[3C\u001b[1Bith a \u001b[38;5;153m~\u001b[12G\u001b[39mto\u001b[15Gflag it's\u001b[25Gan estimate. Effect on real data: today went fr\u001b[73Gm 908k\r\u001b[3C\u001b[1Baw tokens\u001b[14Gto \u001b[1m~219k cost-weighted\u001b[37G\u001b[22m— the honest number, since most raw\u001b[K\r\u001b[2C\u001b[1B\"savings\" were cache reads.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mNegatives rendered, not clamp\u001b[36G (8)\u001b[22m —\u001b[43Ga lo\u001b[48Ging day shows red \u001b[38;5;153m· ~-4.0k saved\r\u001b[2C\u001b[1B\u001b[39m(ver\u001b[8Gfied\u001b[14Gith\u001b[18Ga synth\u001b[26Gtic day\u001b[34Gwhere\u001b[40Gthe\u001b[44Gproxy\u001b[50Gcost\u001b[55Gmore\u001b[60Gthan\u001b[65Gbaseline).\r\u001b[2C\u001b[1B\u001b[38;5;153mprobe_status != \"ok\"\u001b[39m and out-of-range\u001b[41Glines are excluded (also\u001b[66Gverified).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mProxy-global caveat (9)\u001b[22m — docum\u001b[37Gnted in the header block \u001b[63Glong\u001b[68Gide the\r\u001b[2C\u001b[1Bcost-weighting semantics\u001b[28Gand the wedged-proxy 1s tradeoff (item 6,\u001b[K\r\u001b[2C\u001b[1Bdeliberately left as doc\u001b[56G\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[302617.67388, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[3C\u001b[1Beset.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCost-weighted metric (7)\u001b[22m — actual\u001b[39G= \u001b[38;5;153minput + 1.25·cache_create + \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m0.1·cache_read\u001b[39m;\u001b[19Gbaseline\u001b[28G=\u001b[30Gnon-cacheable\u001b[44Gat\u001b[47G1.0\u001b[51Gplus\u001b[56G\u001b[38;5;153mbaseline_cacheable_tokens\r\u001b[2C\u001b[1B\u001b[39mweighted by the cache phase the request actually hit (0.1 if it was\u001b[71Gmostly\u001b[78Ga\r\u001b[2C\u001b[1Bread, else 1.25\u001b[19G— i.e. same cache lifecycle\u001b[47Gassumed without pxpipe). Rendered\u001b[K\r\u001b[3C\u001b[1Bith a \u001b[38;5;153m~\u001b[12G\u001b[39mto\u001b[15Gflag it's\u001b[25Gan estimate. Effect on real data: today went fr\u001b[73Gm 908k\r\u001b[3C\u001b[1Baw tokens\u001b[14Gto \u001b[1m~219k cost-weighted\u001b[37G\u001b[22m— the honest number, since most raw\u001b[K\r\u001b[2C\u001b[1B\"savings\" were cache reads.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mNegatives rendered, not clamp\u001b[36G (8)\u001b[22m —\u001b[43Ga lo\u001b[48Ging day shows red \u001b[38;5;153m· ~-4.0k saved\r\u001b[2C\u001b[1B\u001b[39m(ver\u001b[8Gfied\u001b[14Gith\u001b[18Ga synth\u001b[26Gtic day\u001b[34Gwhere\u001b[40Gthe\u001b[44Gproxy\u001b[50Gcost\u001b[55Gmore\u001b[60Gthan\u001b[65Gbaseline).\r\u001b[2C\u001b[1B\u001b[38;5;153mprobe_status != \"ok\"\u001b[39m and out-of-range\u001b[41Glines are excluded (also\u001b[66Gverified).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mProxy-global caveat (9)\u001b[22m — docum\u001b[37Gnted in the header block \u001b[63Glong\u001b[68Gide the\r\u001b[2C\u001b[1Bcost-weighting semantics\u001b[28Gand the wedged-proxy 1s tradeoff (item 6,\u001b[K\r\u001b[2C\u001b[1Bdeliberately left as documented-not-fixed).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mState after verification\u001b[56G\u001b[22m\u001b[38;5;153mved\u001b[39m,\u001b[61Gdown\u001b[66G=\u001b[68Gred\u001b[72Gdot\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[302618.059029, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B- \u001b[1mCost-weighted metric (7)\u001b[30G\u001b[22m—\u001b[32Gactual\u001b[39G=\u001b[41G\u001b[38;5;153minput + 1.25·cache_create + \r\u001b[2C\u001b[1B0.1·cache_read\u001b[39m; baseline =\u001b[30Gnon-cacheable at 1.0 plus \u001b[38;5;153mbaseline_cacheable_tokens\r\u001b[2C\u001b[1B\u001b[39mweighted by the\u001b[19Gc\u001b[21Gche phase the request ac\u001b[46Gually hit\u001b[56G(0.1 if it was mostly a\u001b[K\r\u001b[2C\u001b[1Br\u001b[5Gad, \u001b[10Glse 1.25\u001b[19G— i.\u001b[24G. s\u001b[28Gm\u001b[31Gcache lifecycle \u001b[48Gssumed without pxpipe). Rendered\r\u001b[2C\u001b[1Bwith a \u001b[38;5;153m~\u001b[39m to flag it's an estimat\u001b[36G. E\u001b[40Gfect on real \u001b[54Gata: today went from 908k\u001b[K\r\u001b[2C\u001b[1Braw tokens to \u001b[1m~219k cost-weighted\u001b[22m — th\u001b[42G honest number, since most raw\u001b[K\r\u001b[2C\u001b[1B\"savings\" were cache reads.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mNegatives rendered, not clamped (8)\u001b[41G\u001b[22m—\u001b[43Ga\u001b[45Glosing\u001b[52Gday\u001b[56Gshows\u001b[62Gred\u001b[66G\u001b[38;5;153m· ~-4.0k saved\r\u001b[2C\u001b[1B\u001b[39m(verified with a synthetic day where the pr\u001b[47Gxy cost more than baseline).\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mprobe_status != \"ok\"\u001b[39m and out-of-range lines are excluded\u001b[60G(also verifi\u001b[73Gd).\r\u001b[2C\u001b[1B- \u001b[1mProxy-global caveat (9)\u001b[22m — d\u001b[33Gcume\u001b[38Gt\u001b[40Gd \u001b[44G the header block al\u001b[65Gngside the\u001b[K\r\u001b[2C\u001b[1Bcost-weighting semantics and the wedged-proxy\u001b[49G1s tradeoff (item 6,\u001b[K\r\u001b[2C\u001b[1Bdeliberately left \u001b[22Gs documented-not-fixed).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mState after verification:\u001b[29G\u001b[22mup\u001b[32G=\u001b[34Ggreen\u001b[40G+\u001b[42Gdim\u001b[46G\u001b[38;5;153m~219.4k saved\u001b[39m,\u001b[61Gdown\u001b[66G=\u001b[68Gred\u001b[72Gdot\r\u001b[2C\u001b[1B(saved still shown), emp\u001b[56G composed\u001b[66Gwi\u001b[69Ging line\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[302618.074989, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[38;5;153m0.1·cache_read\u001b[39m; baseline =\u001b[30Gnon-cacheable at 1.0 plus \u001b[38;5;153mbaseline_cacheable_tokens\r\u001b[2C\u001b[1B\u001b[39mweighted by the\u001b[19Gc\u001b[21Gche phase the request ac\u001b[46Gually hit\u001b[56G(0.1 if it was mostly a\u001b[K\r\u001b[2C\u001b[1Br\u001b[5Gad, \u001b[10Glse 1.25\u001b[19G— i.\u001b[24G. s\u001b[28Gm\u001b[31Gcache lifecycle \u001b[48Gssumed without pxpipe). Rendered\r\u001b[2C\u001b[1Bwith a \u001b[38;5;153m~\u001b[39m to flag it's an estimat\u001b[36G. E\u001b[40Gfect on real \u001b[54Gata: today went from 908k\u001b[K\r\u001b[2C\u001b[1Braw tokens to \u001b[1m~219k cost-weighted\u001b[22m — th\u001b[42G honest number, since most raw\u001b[K\r\u001b[2C\u001b[1B\"savings\" were cache reads.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mNegatives rendered, not clamped (8)\u001b[41G\u001b[22m—\u001b[43Ga\u001b[45Glosing\u001b[52Gday\u001b[56Gshows\u001b[62Gred\u001b[66G\u001b[38;5;153m· ~-4.0k saved\r\u001b[2C\u001b[1B\u001b[39m(verified with a synthetic day where the pr\u001b[47Gxy cost more than baseline).\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mprobe_status != \"ok\"\u001b[39m and out-of-range lines are excluded\u001b[60G(also verifi\u001b[73Gd).\r\u001b[2C\u001b[1B- \u001b[1mProxy-global caveat (9)\u001b[22m — d\u001b[33Gcume\u001b[38Gt\u001b[40Gd \u001b[44G the header block al\u001b[65Gngside the\u001b[K\r\u001b[2C\u001b[1Bcost-weighting semantics and the wedged-proxy\u001b[49G1s tradeoff (item 6,\u001b[K\r\u001b[2C\u001b[1Bdeliberately left \u001b[22Gs documented-not-fixed).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mState after verification:\u001b[29G\u001b[22mup\u001b[32G=\u001b[34Ggreen\u001b[40G+\u001b[42Gdim\u001b[46G\u001b[38;5;153m~219.4k saved\u001b[39m,\u001b[61Gdown\u001b[66G=\u001b[68Gred\u001b[72Gdot\r\u001b[2C\u001b[1B(saved still shown), empty/missing events = dot only, composed\u001b[66Gwi\u