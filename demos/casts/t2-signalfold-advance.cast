[267124.013158, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 634 +\u001b[38;5;242m/// `POST /signal/fold` body — one branch-fold lifecycle trans\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;242mition. `phase`/`engine`/`lane` are\u001b[38;5;231m                            \r\u001b[5C\u001b[1B\u001b[38;5;77m 635 +\u001b[38;5;242m/// STRINGS on the wire but validated against the typed enums \r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;242m(`FoldPhase`/`FoldEngine`/`DecisionLane`)\u001b[38;5;231m                     \r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[16G\u001b[38;5;242mbefore anything touches the warehouse — there is no s\u001b[71Gi\u001b[73Gg\r\u001b[11C\u001b[1Bly path in.\u001b[38;5;231m                       \r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[12G\u001b[38;5;242m#[derive(Deserialize)]\u001b[38;5;231m                                        \r\u001b[6C\u001b[1B\u001b[38;5;77m638\u001b[12G\u001b[38;5;81mstruct\u001b[38;5;231m \u001b[38;5;148mFoldReq\u001b[38;5;231m {                         \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// Lifec\u001b[26Gcle transition — a [`FoldPhase`] tag (e.g. `bran\r\u001b[11C\u001b[1Bch_opened`, `decision_established`).\r\u001b[7C\u001b[1B\u001b[38;5;77m40\u001b[12G\u001b[38;5;231m    phase: \u001b[38;5;148mString\u001b[38;5;231m,    \r\u001b[7C\u001b[1B\u001b[38;5;77m41\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// The fold tree's node id this event belongs to.\r\u001b[7C\u001b[1B\u001b[38;5;77m42\u001b[16G\u001b[38;5;231mbranch_id: \u001b[38;5;148mString\u001b[38;5;231m,                                        \r\u001b[6C\u001b[1B\u001b[38;5;77m643\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// Which harness ran the branch — a [`FoldEngine`] tag (e\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242m.g. `claude`, `codex`).\r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;231mengine: \u001b[38;5;148