[29885.515722, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1mWhat this branch must decide — the client contract.\u001b[55G\u001b[22mHere's\u001b[62Gthe\u001b[66Gshape\u001b[72GI\r\u001b[2C\u001b[1Bpropose, with the real decision points\u001b[42Gflagged for\u001b[54Gyou:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m1. Control plane (stays HTTP on 8787).\u001b[22m Bootstrap + ceremony\u001b[63Gonly:\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153mPOST /v1/devices/enroll\u001b[39m (device\u001b[37Gkeypair\u001b[45Gregistration,\u001b[59Gbranch\u001b[66G1\u001b[68Gflow)\r\u001b[21C\u001b[1B (create), \u001b[38;5;153mPOST /v1/se\u001b[46Gions/{id}/\u001b[57Gttach\u001b[39m (returns\u001b[72Grole\u001b[77G+\r\u001b[2C\u001b[1Bper-stream cursors), detach\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153mPOST /v1/sessions/{id}/preflight\u001b[39m,\u001b[39G\u001b[38;5;153m/bypass/arm\u001b[39m,\u001b[52G\u001b[38;5;153m/bypass/disarm\r\u001b[4C\u001b[1BPOST /v1/session\u001b[22G/{id}/work-i\u001b[35Gems\u001b[39m (dispatch ceremony\u001b[58G— what the phone QR\u001b[78G\u001b[K\r\u001b[2C\u001b[1Bflow calls)\u001b[15G\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
