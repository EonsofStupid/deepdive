[60.781457, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Binput box.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat I broke: I passed a ~900-character topic string.\u001b[22m Claude Code's TUI has\r\u001b[2C\u001b[1Bpaste\u001b[9Gde\u001b[13Gction —\u001b[21Gwh\u001b[24Gn that many\u001b[36Gcharacters arrive in one burst, it doesn't\r\u001b[2C\u001b[1Brender them a\u001b[17G typed text; it collaps\u001b[41Gs th\u001b[46Gm into\u001b[53Ga colored \u001b[38;5;153m[Pasted text #1]\r\u001b[2C\u001b[1B\u001b[39mattachment ch\u001b[17Gp. That's\u001b[27Gthe\u001b[31Gpersistent\u001b[42Gcolored\u001b[50Gblob\u001b[55Gyou're\u001b[62Gseeing,\u001b[70Gand\u001b[74Git\r\u001b[2C\u001b[1Bbehaves\u001b[11Glike\u001b[16Gan\u001b[19Gattachment\u001b[30Ginstead\u001b[38Gof\u001b[41Gtyped\u001b[47Gtext,\u001b[53Gwhich\u001b[59Gis\u001b[62Gwhy\u001b[66Git\u001b[69Glingers\r\u001b[2C\u001b[1Bafter Enter. Your previous dives worked\u001b[43Gbecause\u001b[51Gthe\u001b[55Gtopics\u001b[62Gwere\u001b[67Gshort\r\u001b[2C\u001b[1Bone-liners\u001b[14G— short enough that\u001b[34Gsend-keys reads as normal typing, \u001b[69Gxactly \"as\r\u001b[2C\u001b[1Bif you\u001b[10Gtyped\u001b[16Git out.\"\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mThe fix (not done yet, waiting on you):\u001b[22m\u001b[K\r\u001b[2C\u001b[1B1. Put the full task detail in a per-branch \u001b[1mCOSTAR brief file\u001b[22m under the dive\r\u001b[2C\u001b[1Bfolder (e.g. \u001b[38;5;153m~/.de\u001b[22Gpdive\u001b[55Griefs/l2-transport.md\u001b[39m)\u001b[78G—\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[60.800681, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B(\u001b[38;5;153mspawn-branch.sh\u001b[39m)\u001b[21Gis\u001b[24Guntouched\u001b[34G—\u001b[36Git\u001b[39Gstages\u001b[46Gthe\u001b[50Gprompt\u001b[57Gthe\u001b[61Gsame\u001b[66Gway\u001b[70Git\u001b[73Galways\r\u001b[2C\u001b[1Bhas:\u001b[8G\u001b[38;5;153mtmux send-keys -l \"<topic text>\"\u001b[39m,\u001b[42Gliterally\u001b[52Gtyping\u001b[59Gthe\u001b[63Gtopic\u001b[69Ginto\u001b[74Gthe\r\u001b[2C\u001b[1Binput box.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat I broke: I passed a ~900-character topic string.\u001b[22m Clau\u001b[62Ge Code's TUI has\u001b[K\r\u001b[2C\u001b[1Bpaste d\u001b[11Gtection — when that\u001b[31Gmany characters arrive in one burst, it doesn't\r\u001b[2C\u001b[1Br\u001b[5Gnder them as typed text;\u001b[31Gt collapses them in\u001b[51Go\u001b[53Ga colored \u001b[38;5;153m[Pasted text #1]\r\u001b[3C\u001b[1B\u001b[39mt\u001b[6Gachment chip. That's the per\u001b[35Gistent colored blob\u001b[55Gy\u001b[57Gu're\u001b[62Gs\u001b[64Geing, and\u001b[74Git\r\u001b[2C\u001b[1Bbehaves like\u001b[16Gan a\u001b[21Gtachment instead of typed text,\u001b[53Gwhich is why it lingers\u001b[K\r\u001b[2C\u001b[1Ba\u001b[5Gter Enter.\u001b[16GYour previous\u001b[30Gdives\u001b[36Gworked\u001b[43Gbecause\u001b[51Gthe\u001b[55Gtopics\u001b[62Gwere\u001b[67Gshort\r\u001b[2C\u001b[1Bone-liners\u001b[14G—\u001b[16Gshort\u001b[22Genough\u001b[29Gthat\u001b[34Gsend-keys\u001b[44Greads\u001b[50Gas\u001b[53Gnormal\u001b[60Gtyping,\u001b[68Gexactly\u001b[76G\"as\r\u001b[2C\u001b[1Bif you typed it out.\"\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mThe fix (not done yet, w\u001b[55G\u001b[22m\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
