[703.68788, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[1mconnectome\u001b[22m — the\u001b[20Gb\u001b[22Gockch\u001b[28Gin-shaped property you asked for, without consensus\r\u001b[2C\u001b[1Boverhead.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mHonesty gate (no-reward-hacking):\u001b[39G\u001b[22mbefore\u001b[46Gwe\u001b[49Gdeclare\u001b[57Gvictory,\u001b[66Gthe\u001b[70GQUIC\u001b[75Gfast\r\u001b[2C\u001b[1Bpath gets benchmarked against a plain rkyv-over-TCP stream on the same LAN. If\r\u001b[2C\u001b[1Bit can'\u001b[11G hold ~wi\u001b[21Ge-speed on the \u001b[37Gocal path, the fallback ca\u001b[64Gdidate is\u001b[74G\u001b[K\r\u001b[2C\u001b[1Bembedded\u001b[12GWireGuard via NepTUN+smo\u001b[37Gt\u001b[39Gp — kept\u001b[48Galive in the\u001b[61Gnotes, not built.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat this supersedes:\u001b[25G\u001b[22mthe\u001b[29Graw-ethernet/AF_PACKET/AF_XDP/RoCE\u001b[64Gcandidates\r\u001b[2C\u001b[1B(killed by cross-platform\u001b[29Gclien\u001b[35Gs) and literal L2 bridging (killed on \u001b[74Gecurity\r\u001b[2C\u001b[1Bgrounds). Ze\u001b[17GTier rejected on licensing + weight. Noth\u001b[62Gpr\u001b[65Gor in the dive\u001b[K\r\u001b[2C\u001b[1Bis overturn\u001b[15Gd.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BIf\u001b[6Gthis\u001b[11Gmatches\u001b[19Gyour\u001b[24Gintent,\u001b[32Ggive\u001b[37Gme\u001b[40Gyour\u001b[45G\"yes\u001b[50G+\u001b[52Gwhy\"\u001b[57Gin\u001b[60Gyour\u001b[65Gown\u001b[69Gwords\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[704.155218, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G- \u001b[1mHonesty gate (no-reward-hacking):\u001b[22m befo\u001b[44Ge we declare\u001b[57Gvictory, the\u001b[70GQUIC fast\r\u001b[2C\u001b[1Bpath gets\u001b[13Gbenchmarked\u001b[25Gagainst\u001b[33Ga\u001b[35Gplain\u001b[41Grkyv-over-TCP\u001b[55Gstream\u001b[62Gon\u001b[65Gthe\u001b[69Gsame\u001b[74GLAN.\u001b[79GIf\r\u001b[2C\u001b[1Bit can't hold ~wire-speed on the local path, th\u001b[51G f\u001b[54Gllback candidate is\u001b[K\r\u001b[2C\u001b[1Bembedd\u001b[10Gd WireGuard via NepTUN+smo\u001b[37Gtcp\u001b[41G— kept alive in the n\u001b[63Gtes, not built\u001b[79G\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat this supersedes:\u001b[22m th\u001b[28G raw-ethernet/AF_PACKET/AF_XDP/RoCE candidates\u001b[K\r\u001b[2C\u001b[1B(killed\u001b[11Gby\u001b[14Gcross-platform\u001b[29Gclients)\u001b[38Gand\u001b[42Gliteral\u001b[50GL2\u001b[53Gbridging\u001b[62G(killed\u001b[70Gon\u001b[73Gsecurity\r\u001b[2C\u001b[1Bgrounds). ZeroTier rejected on lice\u001b[39Gsing + weight. Nothing prior \u001b[69Gn \u001b[72Ghe\u001b[75Gdive\r\u001b[2C\u001b[1Bis ov\u001b[9Grturned.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BIf\u001b[6Gthis matches\u001b[19Gyour\u001b[24Gintent,\u001b[32Ggive\u001b[37Gme\u001b[40Gyour\u001b[45G\"yes\u001b[50G+\u001b[52Gwhy\"\u001b[57Gin\u001b[60Gyour\u001b[65Gown\u001b[69Gwords\r\u001b[2C\u001b[1B(that's\u001b[11Gwhat\u001b[16Ggoes\u001b[21Gin\u001b[24Gthe\u001b[28Gdecision\u001b[37Gnotes\u001b[43Gverbatim),\u001b[54Gand\u001b[58GI'll\u001b[63Gwrite\u001b[69Gthe\r\u001b[2C\u001b[1BDECISIONS.md section\u001b[24G+ build\u001b[32Gnot\u001b[36Gs and we\u001b[45Gclo\u001b[49Ge the bra\u001b[59Gch. Push back anywhere\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
