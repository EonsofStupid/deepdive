[698.511722, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gbridge immediately\" — no second handshake,\u001b[46Gno system VPN config, no admi\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bprompts,\u001b[12Gidentical on Linux/Window\u001b[38G/Mac b\u001b[45Gcaus\u001b[50G it's all\u001b[60Gin-process Rust\u001b[K\r\u001b[2C\u001b[1B(quinn/quiche + rustls).\u001b[28G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mLocal vs networked is the same identity, different path.\u001b[22m Local: direc\u001b[76GQUIC\r\u001b[2C\u001b[1Bover the LAN at\u001b[19Gf\u001b[21Gll \u001b[25Gpeed.\u001b[31GNetworked:\u001b[42GQUIC\u001b[47Gconnection\u001b[58Gmigration\r\u001b[2C\u001b[1B(production-safe today) rides through Wi-Fi drops and NAT rebinding without\u001b[K\r\u001b[2C\u001b[1Btea\u001b[7Ging the session;\u001b[24Ghol\u001b[28G-punching/relay via a\u001b[50G iroh/\u001b[57Goq-style layer\u001b[72Gor\u001b[75Ga\r\u001b[2C\u001b[1Brelay on server1\u001b[20Gwhen di\u001b[28Gect fails. Weak\u001b[44Gconnection survivability is a\u001b[K\r\u001b[2C\u001b[1B\u001b[3mprotocol property\u001b[23m, not bolted on — which\u001b[44Gtees up branch 2 (c\u001b[64Gyffy-owned\u001b[75G\u001b[K\r\u001b[2C\u001b[1Bs\u001b[5Gssions) perfectly.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEdge termination.\u001b[22m The tunnel lands on clyffy-01's LAN\u001b[59Gface; the DAC fabric\r\u001b[2C\u001b[1Bn\u001b[5Gver sees a client MAC.\u001b[28GIf\u001b[31GDevPulse\u001b[40Gever\u001b[45Gneeds\u001b[51Gdiscovery-style\u001b[67Gbroadcast\r\u001b[2C\u001b[1Bsemantics, we solve\u001b[23Git with an\u001b[34GmDNS reflector, not bridging.\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[698.721298, "o", "\u001b]0;⠐ dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR brief) then begin\u0007"]
[698.979197, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gp\u001b[5Gompts, identical on\u001b[25GLinux/Windows/Mac because i\u001b[53G's\u001b[56Gall\u001b[60Gin-process\u001b[71GRust\u001b[K\r\u001b[2C\u001b[1B(quinn/qu\u001b[13Gche + rustls).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mLocal vs networked is the same identity, different path.\u001b[62G\u001b[22mLocal:\u001b[69Gdirect\u001b[76GQUIC\r\u001b[2C\u001b[1Bover the LAN at full speed. Networked: QUIC connection migration\u001b[K\r\u001b[2C\u001b[1B(production-s\u001b[17Gfe today) rides \u001b[34Ghrough Wi-Fi\u001b[47Gdrops and NAT \u001b[62Geb\u001b[65Gnding\u001b[71Gwithout\r\u001b[2C\u001b[1Btearing the \u001b[16Gession; hole-punching/relay v\u001b[46Ga an iroh/noq-style layer or a\u001b[K\r\u001b[2C\u001b[1Br\u001b[5Glay on s\u001b[14Grv\u001b[17Gr1 when direct fa\u001b[35Gls. We\u001b[42Gk-connect\u001b[52Gon survivability is\u001b[72Ga\u001b[K\r\u001b[2C\u001b[1B\u001b[3mprotocol property\u001b[23m, not bolted on — which tees up branch 2 (clyff\u001b[68G-owned\r\u001b[2C\u001b[1Bsessions) perfectly.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEdge termination.\u001b[22m The\u001b[27Gtunnel\u001b[34Glands\u001b[40Gon\u001b[43Gclyffy-01's\u001b[55GLAN\u001b[59Gface;\u001b[65Gthe\u001b[69GDAC\u001b[73Gfabric\r\u001b[2C\u001b[1Bnever sees a client\u001b[23GMAC. If DevPulse\u001b[40Gever needs di\u001b[54Gcovery-style broadcast\u001b[K\r\u001b[2C\u001b[1Bs\u001b[5Gmantics,\u001b[14Gwe solve\u001b[23Git with\u001b[31Gan mDNS r\u001b[41Gflector, not bridging.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCrypto:\u001b[22m hybrid X25519+ML-KEM\u001b[34G(rustls d\u001b[44Gfault), device-keypair\u001b[67Genrollment\u001b[78Gvia\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[699.362855, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[13B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[699.463531, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G(quinn/qu\u001b[13Gche + rustls).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mLocal vs networked is the same identity, different path.\u001b[62G\u001b[22mLocal:\u001b[69Gdirect\u001b[76GQUIC\r\u001b[2C\u001b[1Bover the LAN at full speed. Networked: QUIC connection migration\u001b[K\r\u001b[2C\u001b[1B(production-s\u001b[17Gfe today) rides \u001b[34Ghrough Wi-Fi\u001b[47Gdrops and NAT \u001b[62Geb\u001b[65Gnding\u001b[71Gwithout\r\u001b[2C\u001b[1Btearing the \u001b[16Gession; hole-punching/relay v\u001b[46Ga an iroh/noq-style layer or a\u001b[K\r\u001b[2C\u001b[1Br\u001b[5Glay on s\u001b[14Grv\u001b[17Gr1 when direct fa\u001b[35Gls. We\u001b[42Gk-connect\u001b[52Gon survivability is\u001b[72Ga\u001b[K\r\u001b[2C\u001b[1B\u001b[3mprotocol property\u001b[23m, not bolted on — which tees up branch 2 (clyff\u001b[68G-owned\r\u001b[2C\u001b[1Bsessions) perfectly.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEdge termination.\u001b[22m The\u001b[27Gtunnel\u001b[34Glands\u001b[40Gon\u001b[43Gclyffy-01's\u001b[55GLAN\u001b[59Gface;\u001b[65Gthe\u001b[69GDAC\u001b[73Gfabric\r\u001b[2C\u001b[1Bnever sees a client\u001b[23GMAC. If DevPulse\u001b[40Gever needs di\u001b[54Gcovery-style broadcast\u001b[K\r\u001b[2C\u001b[1Bs\u001b[5Gmantics,\u001b[14Gwe solve\u001b[23Git with\u001b[31Gan mDNS r\u001b[41Gflector, not bridging.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCrypto:\u001b[22m hybrid X25519+ML-KEM\u001b[34G(rustls d\u001b[44Gfault), device-keypair\u001b[67Genrollment\u001b[78Gvia\r\u001b[2C\u001b[1Bthe HTTP cont\u001b[17Gol\u001b[20Gplane, and a \u001b[1mhash-chained tamper-evident session ledger in \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
