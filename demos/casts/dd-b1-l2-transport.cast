[728.023871, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1BDECISIONS.md section\u001b[24G+ build\u001b[32Gnot\u001b[36Gs and we\u001b[45Gclo\u001b[49Ge the bra\u001b[59Gch. Push back anywhere\r\u001b[2C\u001b[1Bi\u001b[5G doe\u001b[10Gn't sit right\u001b[24G— \u001b[27Gsp\u001b[32Gally\u001b[37Gif you t\u001b[46Guly wanted fabric-lev\u001b[68Gl L2\r\u001b[2C\u001b[1Bcitizenship,\u001b[16Gb\u001b[19Gause\u001b[24GI'm explicitly recommending against that.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;246m✻\u001b[3GCogitated for 7m 10s\u001b[24G\u001b[39m\u001b[K\r\u001b[2B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                              \r\u001b[2B\u001b[49m\u001b[38;5;231m●\u001b[39m Locked: \u001b[1medge termination\u001b[22m — the DAC fabric stays sealed, the bridge lands on\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
