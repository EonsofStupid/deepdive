[305265.781679, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B{\u001b[7G\u001b[K\r\u001b[4C\u001b[1B\u001b[36m\"statusLine\"\u001b[39m: {\u001b[K\r\u001b[2C\u001b[1B    \u001b[36m\"type\"\u001b[39m: \u001b[31m\"\u001b[17Gommand\"\u001b[39m,\u001b[K\r\u001b[2C\u001b[1B    \u001b[36m\"command\"\u001b[39m: \u001b[31m\"bash -c 'in=$(cat); a=$(printf %s \\\"$in\\\" | \r\u001b[14C\u001b[1B.claude/statusline-infisical.sh); b=$(pr\u001b[56Gntf %s \\\"$\u001b[68G\\\"\u001b[71G| \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[31mPXPIPE_SEGMENT_ONLY=1 \r\u001b[2C\u001b[1B/home/hades/clyffy/landing/study/t1/a/statusline-pxpipe.sh); printf \\\"%s  %s\\\"\r\u001b[2C\u001b[1B\\\"$a\\\" \\\"$b\\\"'\"\r\u001b[4C\u001b[1B\u001b[39m}\r\u001b[2C\u001b[1B}\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BR\u001b[5Gndered result: \u001b[38;5;153ma  Fable 5  🔐 Infisical ●  ⚡ pxpipe ● 3.3M tok saved\r\u001b[2C\u001b[1B\u001b[39m(tested end-to-end with exactly that command). If you'd rather\u001b[66Gkeep\u001b[K\r\u001b[2C\u001b[1Bsettings.json\u001b[17Gclean,\u001b[24Gthe\u001b[28Gsame\u001b[33Gthree\u001b[39Glines\u001b[45Gcould\u001b[51Glive\u001b[56Gin\u001b[59Ga\u001b[61Gtiny\r\u001b[2C\u001b[1B\u001b[38;5;153mstatusline-combined.sh\u001b[39m wrapper i\u001b[37Gte\u001b[40Gd — say the\u001b[52Gword and I'll add it her\u001b[77G.\r\u001b[2C\u001b[1B    \u001b[8G           \u001b[20G       \u001b[56G\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
