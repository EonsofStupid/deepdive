[302617.018874, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B- \u001b[1mAtomic cache write\u001b[22m — w\u001b[28Gite to \u001b[38;5;153m$CACHE.$$\u001b[39m then\u001b[50G\u001b[38;5;153mmv -f\u001b[39m; t\u001b[59Gr\u001b[62Gr\u001b[64Gads und\u001b[72Gr\u001b[K\r\u001b[2C\u001b[1Bconcurrent rep\u001b[18Gints ar\u001b[26G gone.\u001b[33G\u001b[K\r\u001b[4C\u001b[1B\u001b[1mBounded s\u001b[15Gan\u001b[22m — \u001b[38;5;153mtail -c 2MiB\u001b[39m before the grep,\u001b[50Gso the\u001b[57G<100ms budget survives\r\u001b[2C\u001b[1Bl\u001b[5Gg g\u001b[9Gowth; a l\u001b[20Ge to\u001b[25Gn\u001b[27Gby the\u001b[34Gbyte\u001b[39Gcut\u001b[43G(and\u001b[48Gany\u001b[52Gother\u001b[58Ggarbage\u001b[66Gline)\u001b[72Gis\r\u001b[2C\u001b[1Bskipped by \u001b[38;5;153mfromjson?\u001b[39m instead of p\u001b[37Gisoning the wh\u001b[52Gle \u001b[38;5;153mjq\u001b[39m slurp\u001b[64G— verified with\u001b[80Ga\r\u001b[2C\u001b[1Bsynthetic torn line.\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153m\u001b[1m/tmp/claude-${UID}\u001b[35G\u001b[22m\u001b[39mhardcoded\u001b[45G\u001b[38;5;153m1000\u001b[39m.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mJudgment calls folded in (3, 4, 7, 8, 9)\u001b[22m\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mGET-only warning (3)\u001b[26G\u001b[22m—\u001b[28Gcomment\u001b[36Gat\u001b[39Gthe\u001b[43Gcheck:\u001b[50GHEAD\u001b[55G\u001b[38;5;153m/\u001b[57G\u001b[39mreturns\u001b[65G404\u001b[69Gon\u001b[72Gpxpipe,\r\u001b[2C\u001b[1Bso it must stay GET.\u001b[K\r\u001b[4C\u001b[1B\u001b[1mLocal day (4)\u001b[22m — \"today\" is now\u001b[36Gthe local \u001b[47Galendar\u001b[55Gday converted\u001b[69Gto\u001b[72Ga UTC\u001b[K\r\u001b[2C\u001b[1Brange\u001b[9G(\u001b[38;5;153mdate -u -d \"$(date +%F) 00:00\"\u001b[41G\u001b[39m→\u001b[43G+1\u001b[46Gday),\u001b[52Ggrep\u001b[57Gpre-filters\u001b[69Gon\u001b[72Gboth\r\u001b[2C\u001b[1Bpossible UTC date\u001b[21Gprefixes, jq does the exa\u001b[47Gt range\u001b[55Gcompare. No more\u001b[72G8pm-local\r\u001b[3C\u001b[1Beset.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCost-weighted metric (\u001b[56G\u001b[22m\u001b[38;5;153mche_create + \u001b[39m\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[302617.0427, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[4C\u001b[1B\u001b[1mBounded s\u001b[15Gan\u001b[22m — \u001b[38;5;153mtail -c 2MiB\u001b[39m before the grep,\u001b[50Gso the\u001b[57G<100ms budget survives\r\u001b[2C\u001b[1Bl\u001b[5Gg g\u001b[9Gowth; a l\u001b[20Ge to\u001b[25Gn\u001b[27Gby the\u001b[34Gbyte\u001b[39Gcut\u001b[43G(and\u001b[48Gany\u001b[52Gother\u001b[58Ggarbage\u001b[66Gline)\u001b[72Gis\r\u001b[2C\u001b[1Bskipped by \u001b[38;5;153mfromjson?\u001b[39m instead of p\u001b[37Gisoning the wh\u001b[52Gle \u001b[38;5;153mjq\u001b[39m slurp\u001b[64G— verified with\u001b[80Ga\r\u001b[2C\u001b[1Bsynthetic torn line.\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153m\u001b[1m/tmp/claude-${UID}\u001b[35G\u001b[22m\u001b[39mhardcoded\u001b[45G\u001b[38;5;153m1000\u001b[39m.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mJudgment calls folded in (3, 4, 7, 8, 9)\u001b[22m\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mGET-only warning (3)\u001b[26G\u001b[22m—\u001b[28Gcomment\u001b[36Gat\u001b[39Gthe\u001b[43Gcheck:\u001b[50GHEAD\u001b[55G\u001b[38;5;153m/\u001b[57G\u001b[39mreturns\u001b[65G404\u001b[69Gon\u001b[72Gpxpipe,\r\u001b[2C\u001b[1Bso it must stay GET.\u001b[K\r\u001b[4C\u001b[1B\u001b[1mLocal day (4)\u001b[22m — \"today\" is now\u001b[36Gthe local \u001b[47Galendar\u001b[55Gday converted\u001b[69Gto\u001b[72Ga UTC\u001b[K\r\u001b[2C\u001b[1Brange\u001b[9G(\u001b[38;5;153mdate -u -d \"$(date +%F) 00:00\"\u001b[41G\u001b[39m→\u001b[43G+1\u001b[46Gday),\u001b[52Ggrep\u001b[57Gpre-filters\u001b[69Gon\u001b[72Gboth\r\u001b[2C\u001b[1Bpossible UTC date\u001b[21Gprefixes, jq does the exa\u001b[47Gt range\u001b[55Gcompare. No more\u001b[72G8pm-local\r\u001b[3C\u001b[1Beset.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCost-weighted metric (7)\u001b[22m — actual\u001b[39G= \u001b[38;5;153minput + 1.25·cache_create + \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m0.1·cache_read\u001b[39m;\u001b[19Gbaseline\u001b[28G=\u001b[30Gnon-ca