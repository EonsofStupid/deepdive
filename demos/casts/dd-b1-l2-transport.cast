[696.155209, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1BHTTP/3\u001b[10G(\u001b[38;5;153mclyffy.local:8787\u001b[39m,\u001b[30GmDNS\u001b[35Gdiscovery\u001b[45G—\u001b[47Gunchanged\u001b[57Gcontract).\r\u001b[2C\u001b[1BEnrollment/auth happens there, then the \u001b[3msame connection\u001b[59G\u001b[23mop\u001b[62Gns dedicated\u001b[K\r\u001b[2C\u001b[1Bstreams + unreliable datagrams as the fast path: rkyv\u001b[57Gzero-copy frames,\u001b[75Gno\r\u001b[2C\u001b[1BJSON, no per-request over\u001b[30Gad.\u001b[34GT\u001b[36Gis\u001b[39Gis the literal \"goes from\u001b[65GHTTP to the\r\u001b[2C\u001b[1Bbridge immediately\" — no second handshake,\u001b[46Gno system VPN config, no admi\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bprompts,\u001b[12Gidentical on Linux/Window\u001b[38G/Mac b\u001b[45Gcaus\u001b[50G it's all\u001b[60Gin-process Rust\u001b[K\r\u001b[2C\u001b[1B(quinn/quiche + rustls).\u001b[28G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mLocal vs networked is the same identity, different path.\u001b[22m Local: direc\u001b[76GQUIC\r\u001b[2C\u001b[1Bover the LAN at\u001b[19Gf\u001b[21Gll \u001b[25Gpeed.\u001b[31GNetworked:\u001b[42GQUIC\u001b[47Gconnection\u001b[58Gmigration\r\u001b[2C\u001b[1B(production-safe today) rides through Wi-Fi drops and NAT rebinding without\u001b[K\r\u001b[2C\u001b[1Btea\u001b[7Ging the session;\u001b[24Ghol\u001b[28G-punching/relay via a\u001b[50G iroh/\u001b[57Goq-style layer\u001b[72Gor\u001b[75Ga\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[696.640055, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G-\u001b[5G\u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1BHTTP/3 (\u001b[38;5;153mclyffy.local:8787\u001b[39m, mDNS discovery\u001b[45G— unchanged contract).\u001b[K\r\u001b[2C\u001b[1BEnrollment/auth happens there, then th\u001b[42G \u001b[3msame connection\u001b[23m opens dedicated\r\u001b[2C\u001b[1Bst\u001b[6Geams + unreliable datagrams\u001b[34Gas the fast path: rkyv zero-copy frames,\u001b[75Gno\r\u001b[2C\u001b[1BJSON, no per-request\u001b[24Goverhe\u001b[31Gd.\u001b[34GThis is the\u001b[46Gli\u001b[49Geral \"goes from HTTP to the\u001b[K\r\u001b[2C\u001b[1Bbridge imm\u001b[14Gdiately\" — no s\u001b[30Gcond \u001b[36Gandshake,\u001b[46Gno system VPN\u001b[60Gconfig, no admin\r\u001b[2C\u001b[1Bp\u001b[5Gompts, identical on\u001b[25GLinux/Windows/Mac because i\u001b[53G's\u001b[56Gall\u001b[60Gin-process\u001b[71GRust\u001b[K\r\u001b[2C\u001b[1B(quinn/qu\u001b[13Gche + rustls).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mLocal vs networked is the same identity, different path.\u001b[62G\u001b[22mLocal:\u001b[69Gdirect\u001b[76GQUIC\r\u001b[2C\u001b[1Bover the LAN at full speed. Networked: QUIC connection migration\u001b[K\r\u001b[2C\u001b[1B(production-s\u001b[17Gfe today) rides \u001b[34Ghrough Wi-Fi\u001b[47Gdrops and NAT \u001b[62Geb\u001b[65Gnding\u001b[71Gwithout\r\u001b[2C\u001b[1Btearing the \u001b[16Gession; hole-punching/relay v\u001b[46Ga an iroh/noq-style layer or a\u001b[K\r\u001b[2C\u001b[1Br\u001b[5Glay on s\u001b[14Grv\u001b[17Gr1 when direct fa\u001b[35Gls. We\u001b[42Gk-connect\u001b[52Gon survivability is\u001b[72Ga\u001b[K\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
