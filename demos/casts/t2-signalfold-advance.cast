[267126.736635, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[8C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m1\u001b[20G\u001b[38;5;231m    \u001b[38;5;81mlet\u001b[38;5;231m lane: DecisionLane\u001b[47G=\u001b[49G\u001b[38;5;197mmatch\u001b[55G\u001b[38;5;231ml.\u001b[38;5;148mparse\u001b[38;5;231m()\u001b[65G{\r\u001b[8C\u001b[1B\u001b[38;5;77m2\u001b[24G\u001b[38;5;231m   \u001b[28G\u001b[38;5;148mOk\u001b[38;5;231m(l)\u001b[34G=> l,       \u001b[47G \u001b[49G     \u001b[55G         \u001b[65G \r\u001b[8C\u001b[1B\u001b[38;5;77m3\u001b[28G\u001b[38;5;148mErr\u001b[38;5;231m(e) => \u001b[38;5;148mreturn\u001b[45G\u001b[38;5;231m(StatusCode::BAD_REQUEST,\u001b[71Ge.\u001b[38;5;148mt\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;148mo_string\u001b[38;5;231m()).\u001b[38;5;148minto_\u001b[30Gesponse\u001b[38;5;231m(),    \u001b[45G                         \u001b[71G   \r\u001b[6C\u001b[1B\u001b[38;5;77m734\u001b[12G\u001b[38;5;231m            };              \r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[24G\u001b[38;5;231msig\u001b[28G=\u001b[30Gsig.\u001b[38;5;148mdecision\u001b[38;5;231m(d,\u001b[46Glane);\r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[20G\u001b[38;5;231m}\u001b[24G   \u001b[28G \u001b[30G               \u001b[46G      \r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[20G\u001b[38;5;231m(\u001b[38;5;141mNone\u001b[38;5;231m,\u001b[27G\u001b[38;5;141mNone\u001b[38;5;231m)\u001b[33G=>\u001b[36G{}\r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[20G\u001b[38;5;231m_ => {\u001b[27G     \u001b[33G  \u001b[36G  \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[20G\u001b[38;5;231m \u001b[22G  \u001b[38;5;148mreturn\u001b[31G\u001b[38;5;231m(\r\u001b[7C\u001b[1B\u001b[38;5;77m40\u001b[24G\u001b[38;5;231m    StatusCode::BAD_REQUEST,\r\u001b[8C\u001b[1B\u001b[38;5;77m1\u001b[28G\u001b[38;5;186m\"decision_id and lane must be given together (\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;186ma decision always names its combine lane)\"\u001b[38;5;231m,                