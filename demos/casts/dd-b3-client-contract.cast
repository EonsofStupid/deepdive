[444.813364, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[K\r\u001b[1B  \u001b[38;5;246mSearched for \u001b[1m1\u001b[22m pattern, read \u001b[1m2\u001b[22m files, listed \u001b[1m1\u001b[22m directory, ran \u001b[1m3\u001b[22m shell commands\r\u001b[1B\u001b[39m  \u001b[38;5;246m \u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m  ⎿  $ ls ~/Projects/clyffy/interfaces/ 2>/dev/null && ls \u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[39m Branch 3 open — brief read, branches 1–2 decisions absorbed, fold signal\u001b[K\r\u001b[2C\u001b[1Bqueued\u001b[10G(heads-up,\u001b[21Gnot\u001b[25Ghiding\u001b[32Git:\u001b[36G\u001b[38;5;153mclyffy signal fold\u001b[55G\u001b[39m\u001b[1mcore-dumped\u001b[67G\u001b[22m—\u001b[69GSIGABRT\u001b[77G—\u001b[79Gso\r\u001b[1B \u001b[3GI \u001b[6Gppended the argv li\u001b[26Ge\u001b[28Gto \u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m per the\u001b[K\r\u001b[2C\u001b[1Bfallback;\u001b[13Gthe\u001b[17Gcrash\u001b[23Gitself\u001b[30Gis\u001b[33Gworth\u001b[39Ga\u001b[41Glook\u001b[46Glater,\u001b[53Git's\u001b[58Gnot\u001b[62Ga\u001b[64Glocked-warehouse\r\u001b[1B  message, it's an abort).\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BFiletree-first grounding, verified in-repo:\u001b[47Gthe\u001b[51GBrain\u001b[57GAPI\u001b[61Gtoday\u001b[67Gis\r\u001b[2C\u001b[1B\u001b[38;5;153minterfaces/clyffy-brain/src/main.rs\u001b[39G\u001b[39m(611\u001b[44Glines,\u001b[51Gaxum)\u001b[57Gserving\u001b[65G\u001b[38;5;153mGET /healthz\u001b[39m,\r\u001b[1B \u001b[3G\u001b[38;5;153m/capabilities\u001b[39m, \u001b[38;5;153m/models\u001b[39m, \u001b[38;5;153m/v1/models\u001b[39m, \u001b[38;5;153mPOST /converse\u001b[39m,\u001b[55G\u001b[38;5;153mPOST /research\u001b[39m.\u001b[71GThat's\u001b[78Gthe\r\u001b[1B  surface this branch evolves.\u001b[K\r\u001b[5C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[444.932642, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gbypass\u001b[10Ggate,\u001b[16Gpreflight,\u001b[27Gwork-items.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat this branch must decide — the client contract.\u001b[55G\u001b[22mHere's\u001b[62Gthe\u001b[66Gshape\u001b[72GI\r\u001b[1B  propose, with the real decision points flagged for you:\u001b[K\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m1. Control plane (stays HTTP on 8787).\u001b[22m Bootstrap + ceremony only:\u001b[69G\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[38;5;153mPOST /v1/devices/enroll\u001b[39m (device keypair registration, branch 1 flow)\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153mPOST /v1/sessions\u001b[23G\u001b[39m(cr\u001b[27Gate),\u001b[33G\u001b[38;5;153mPOST /v1/sessions/{id}/attach\u001b[39m (returns role +\u001b[K\r\u001b[2C\u001b[1Bp\u001b[5Gr-stream cursors), detach\r\u001b[2C\u001b[1B-\u001b[5G\u001b[38;5;153mPOST /v1/sessions/{id}/preflight\u001b[39m,\u001b[39G\u001b[38;5;153m/bypass/arm\u001b[39m,\u001b[52G\u001b[38;5;153m/bypass/disarm\r\u001b[2C\u001b[1B\u001b[39m- \u001b[38;5;153mPOST /v1/sessions/{id}/work-items\u001b[39m (dis\u001b[44Gatch ceremo\u001b[56Gy — what the phone\u001b[75GQR\r\u001b[2C\u001b[1Bflow calls)\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153mGET /capabilities\u001b[39m grows a \u001b[38;5;153mc\u001b[33Gntract_version\u001b[39m + feature flags → this\u001b[71Gis how\u001b[78Gwe\u001b[K\r\u001b[2C\u001b[1Bve\u001b[6Gsion\u001b[13Ge whole thing without\u001b[35Gbreaking\u001b[44Gold\u001b[48Gclients.\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[445.044483, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gflow calls)\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[38;5;153mGET /capabilities\u001b[23G\u001b[39mgrows\u001b[29Ga\u001b[31G\u001b[38;5;153mcontract_version\u001b[48G\u001b[39m+\u001b[50Gfeature\u001b[58Gflags\u001b[64G→\u001b[66Gthis\u001b[71Gis\u001b[74Ghow\u001b[78Gwe\r\u001b[2C\u001b[1Bversion the whole thing without breaking old clients.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m2. Data plane (QUIC streams after attach).\u001b[46G\u001b[22mProposed\u001b[55Gstream\u001b[62Gmap:\u001b[67Gone\r\u001b[2C\u001b[1Bclient→server \u001b[1minge\u001b[23Gion\u001b[27Gstream\u001b[22m per source (FlatBuffers frames, idempotent\r\u001b[2C\u001b[1Bframe keys), one server→client \u001b[1moutbox stream\u001b[22m (results repl\u001b[62Gyed\u001b[66Gfrom your\r\u001b[2C\u001b[1Battach cursor), datagrams reserved for lossy niceties (progress ticks,\u001b[K\r\u001b[2C\u001b[1Btyping/VH1-style \u001b[21Gtatus) t\u001b[30Gat\u001b[33Gare\u001b[37Glegal\u001b[43Gto\u001b[46Gdrop.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. The first real fork in the road — where does \u001b[38;5;153m/converse\u001b[39m live?\u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[4C\u001b[1B\u001b[1m(a) Converse moves onto the fast path too\u001b[22m once \u001b[54Gtached — HTTP keep\u001b[74Gonly\u001b[K\r\u001b[2C\u001b[1Bbootstrap/ceremony. O\u001b[25Ge\u001b[27Gcontract, \u001b[38Gverything\u001b[48Gsession-scoped,\u001b[64Greplayable\u001b[75Gfrom\r\u001b[2C\u001b[1Bthe\u001b[7Goutbox\u001b[14G(a\u001b[17Gdropped\u001b[25Gclient\u001b[32Gre-attaches\u001b[44Gand\u001b[48Gsees\u001b[53Gthe\u001b[57Ganswer\u001b[64Git\u001b[67Gmissed\u001b[74G—\u001b[76Gwhich\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
