[981.529264, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G   \u001b[38;5;77m\u001b[48;5;22m  98 +\u001b[38;5;231m- Benchmark harness FIRST: FlatBuffers-over-TCP baseline vs QU\u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;231mIC fast path on the real LAN link                             \r\u001b[2C\u001b[1B\u001b[49m\u001b[39m   \u001b[38;5;77m\u001b[48;5;22m  99 +\u001b[38;5;231m  (devstation↔clyffy-01) before committing the transport inter\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;231mnals.                                                         \r\u001b[2C\u001b[1B\u001b[49m\u001b[39m   \u001b[38;5;77m\u001b[48;5;22m 100 +\u001b[38;5;231m- Relay/hole-punch (networked mode) deferred to its own work i\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;231mtem; local mode ships first.                                  \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;5;77m\u001b[48;5;22m 101 +\u001b[38;5;231m- Open question handed to branch 2: session identity ↔ QUIC co\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;231mnnection identity mapping (a session                          \r\u001b[1B\u001b[49m\u001b[39m     \u001b[38;5;77m\u001b[48;5;22m 102 +\u001b[38;5;231m  must survive a dead connection, not just a migrated one).   \u001b[49m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 103 +\u001b[38;5;231m                                                              \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;5;77m\u001b[48;5;22m 104 +\u001b[38;5;231m---                                                           \u001b[49m\u001b[39m\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
