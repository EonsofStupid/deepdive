[267127.511117, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[8C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m6\u001b[29G\u001b[38;5;186mbr\u001b[32Gnch_id\"\u001b[38;5;231m: req.branch_id,\r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[29G\u001b[38;5;186mengine\"\u001b[38;5;231m: engine\u001b[45G\u001b[38;5;148mtag\u001b[38;5;231m(),    \r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[24G\u001b[38;5;231m})),         \u001b[38G             \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[20G\u001b[38;5;231m)\u001b[24G    \r\u001b[7C\u001b[1B\u001b[38;5;77m80\u001b[20G\u001b[38;5;231m \u001b[24G.\u001b[38;5;148minto_response\u001b[38;5;231m(),\r\u001b[8C\u001b[1B\u001b[38;5;77m1\u001b[20G\u001b[38;5;148mErr\u001b[38;5;231m(e) => {          \r\u001b[8C\u001b[1B\u001b[38;5;77m2\u001b[20G\u001b[38;5;231m    (StatusCode::INTERNAL_SERVER_ERROR,\u001b[60G\u001b[38;5;148mformat!\u001b[38;5;231m(\u001b[38;5;186m\"fold \r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;186msignal not recorded: {e}\"\u001b[38;5;231m)).\u001b[38;5;148minto_response\u001b[38;5;231m()    \u001b[60G              \r\u001b[6C\u001b[1B\u001b[38;5;77m783\u001b[12G\u001b[38;5;231m        }                                  \r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;231m}\u001b[20G \r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[12G\u001b[38;5;231m}\u001b[16G \r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[12G\u001b[38;5;231m \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 787 \u001b[22m \u001b[38;5;242m/// Mirror the CLI: `$CLYFFY_CONFIG` or `<home.root>/clyffy.to\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m   \u001b[12G\u001b[22m\u001b[38;5;242mml`, else defaults.\u001b[32GNever fails to bo\u001b[50Gt.\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m788\u001b[12G\u001b[22m\u001b[38;5;81mfn\u001b[38;5;231m \u001b[38;5;148mload_config\u001b[38;5;231m() -> ClyffyConfig {\u001b[39m\u001b[K\r\u001b[8C\u001b[1B\u001b[38;5;231m\u001b[2m9\u001b[12G\u001b[22m  \u001b[15G \u001b[38;5;81mlet\u001b[38;5;231m path = \