[267124.751872, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[8C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m8\u001b[16G\u001b[38;5;242m/// The parent branch id (omit on the root/source conversa\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mtion).\u001b[38;5;231m                                                        \r\u001b[6C\u001b[1B\u001b[38;5;77m649\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m#[serde(default)]\r\u001b[7C\u001b[1B\u001b[38;5;77m50\u001b[16G\u001b[38;5;231mparent_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m1\u001b[16G\u001b[38;5;242m/// The harness session id backing the branch.\r\u001b[8C\u001b[1B\u001b[38;5;77m2\u001b[16G\u001b[38;5;242m#[serd\u001b[23G(default)]\u001b[38;5;231m                             \r\u001b[8C\u001b[1B\u001b[38;5;77m3\u001b[16G\u001b[38;5;231msession_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;242m/// The decision established/superseded — requires `lane`.\r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[16G\u001b[38;5;242m#[serd\u001b[23G(\u001b[26Gfault)]\u001b[38;5;231m                                         \r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[16G\u001b[38;5;231mdecision_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[16G\u001b[38;5;242m/// The decision's combine lane — a [`DecisionLane`] tag; \r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mrequires `decis\u001b[28Gon_id`.\u001b[38;5;231m                                       \r\u001b[6C\u001b[1B\u001b[38;5;77m658\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m#[serde(default)]\u001b[38;5;231m  \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[16G\u001b[38;5;231mlane: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[7C\u001b[1B\u001b[38;5;77m60\u001b[16G\u001b[38;