[301685.152122, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[38;5;153m/api/status\u001b[39m etc. all 404).\u001b[30GGreen\u001b[36G\u001b[38;5;153m●\u001b[39m on 2xx, red \u001b[38;5;153m●\u001b[39m otherwise. \u001b[38;5;153mPXPIPE_STATUS_URL\r\u001b[2C\u001b[1B\u001b[39moverrides, matching the \u001b[38;5;153mINFISICAL_STATUS_URL\u001b[39m pattern.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mTokens saved today:\u001b[22m there's no stats API and no precomputed\u001b[65Gfield in the\u001b[K\r\u001b[2C\u001b[1Bevents, so it sums today's (UTC) l\u001b[38Gnes from \u001b[38;5;153m~/.pxpipe/events.jsonl\u001b[39m:\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mbaseline_tokens − (input_tokens + cache_create_tokens + cache_read_tokens)\u001b[39m,\u001b[K\r\u001b[2C\u001b[1Bon\u001b[6Gy for lin\u001b[16Gs with \u001b[38;5;153mbaseline_probe_status == \"ok\"\u001b[39m, clamp\u001b[60Gd\u001b[62Gat 0, r\u001b[70Gnder\u001b[75Gd\u001b[77Gas\r\u001b[2C\u001b[1B\u001b[38;5;153mk\u001b[39m/\u001b[38;5;153mM\u001b[39m. Omitted entirely\u001b[25Gif\u001b[28Gthe\u001b[32Gfile\u001b[37Gis\u001b[40Gmissing/unreadable\u001b[59Gor\u001b[62Gthe\u001b[66Gsum\u001b[70Gis 0.\u001b[76GNote\r\u001b[2C\u001b[1Bit's an approximation — it counts cach\u001b[42G-read\u001b[48Gtokens\u001b[55Gat\u001b[58Gpar\u001b[62Geven\u001b[67Gthough\u001b[74Gthey're\r\u001b[2C\u001b[1Bbilled cheaper, so the true cost saving\u001b[43Gis \u001b[47Gom\u001b[50Gwhat higher than the token\u001b[K\r\u001b[2C\u001b[1Bfigure s\u001b[12Gown.\u001b[17G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mSpeed:\u001b[22m same 5s\u001b[20Gcache\u001b[26Gas the\u001b[33Greference\u001b[K\r\u001b[2C\u001b[1B(\u001b[38;5;153m/tmp/claude-1000/pxpipe-status.cache\u001b[39m).\u001b[43GMeasured:\u001b[53G15ms\u001b[58Gcold,\u001b[64G5ms\u001b[68Gwarm,\u001b[74G18ms\r\u001b[2C\u001b[1Bcold with the proxy\u001b[23Gdown\u001b[28G(connection-refused\u001b[48Gon\u001b[51Gloopback\u001b[60Gis\u001b[63Ginstant;\u001b[72Ga\u001b[74G\u001b