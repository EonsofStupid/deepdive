[365.641947, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3GAPI surface owns QUIC/attach/outbox plumbing, capability-packs declare\u001b[K\r\u001b[2C\u001b[1Bwork-item risk classes and branch 2's destructive gate is enforced from\u001b[75Gthose\r\u001b[2C\u001b[1Bdeclarations in the control layer.\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BKilled and named: app-only (both flavors), reduced Lite contract,\u001b[K\r\u001b[2C\u001b[1Btransport-as-pack, dual attachments, handoff-on-close. Open handoffs to\u001b[75Gthe\r\u001b[2C\u001b[1Bfold:\u001b[9Gclient-core/agent\u001b[27Glive\u001b[32GDevPulse-side\u001b[46Gand\u001b[50Gneed\u001b[55Gthe\u001b[59GCOSTAR\u001b[66Ggate\u001b[71Gon\u001b[74G\u001b[3mthat\r\u001b[1B\u001b[23m \u001b[3Gtree, IPC\u001b[13Gframe\u001b[19Gsubset, agent\u001b[33Gupdate\u001b[40Gstory.\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mConfirm the close\u001b[22m, and then exit this session — that fires \u001b[38;5;153mbranch_closed\u001b[39m and\u001b[K\r\u001b[2C\u001b[1Bwakes\u001b[9Gthe\u001b[13Gsource\u001b[20Gto\u001b[23Grun\u001b[27Gthe\u001b[31Gfold\u001b[36Gover\u001b[41Gall\u001b[45Gfour\u001b[50Gbranches.\r\u001b[41C\u001b[2B\u001b[38;5;246mthought for 10s)\u001b[39m\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
