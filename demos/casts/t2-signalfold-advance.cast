[268585.488646, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bis\u001b[6Gthe sharpest finding.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mFresh worktrees have no \u001b[38;5;153mclyffy\u001b[39m binary\u001b[22m — ho\u001b[49Gks fall back to the queue,\u001b[76Gwhich\r\u001b[2C\u001b[1B(per #1) is curre\u001b[21Gtly a writ\u001b[32G-only \u001b[39Gole. Fallback\u001b[54Gorks; replay do\u001b[70Gsn't\u001b[K\r\u001b[2C\u001b[1Bexist.\u001b[10G\u001b[K\r\u001b[2C\u001b[1B3\u001b[6G\u001b[1mBlocking DuckDB\u001b[22Gins\u001b[26Grt on a tokio worker\u001b[22m — the \u001b[38;5;153m/signal/fold\u001b[39m \u001b[67Gandl\u001b[72Gr emits\u001b[K\r\u001b[2C\u001b[1Bstraight\u001b[12Gthro\u001b[17Ggh the w\u001b[26Grehouse sink with\u001b[44Gno \u001b[38;5;153mspawn_blocking\u001b[39m. Fine at\u001b[K\r\u001b[2C\u001b[1Bhook-traffic\u001b[16Gvolume,\u001b[24Gwrong\u001b[30Gshape\u001b[36Gunder\u001b[42Gbursts.\r\u001b[2C\u001b[1B4\u001b[6G\u001b[1mNo idempotency\u001b[22m — a retried curl or future queue replay double-ins\u001b[73Gts; no\r\u001b[3C\u001b[1Bignal UUID \u001b[16Gr uniqueness constraint.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mNon-gotcha worth noting:\u001b[22m validation is prop\u001b[47Grly single-sourced — the endpoint\r\u001b[2C\u001b[1Bparses\u001b[10Gvia the\u001b[18Gshared \u001b[38;5;153mFromStr\u001b[39m impls in\u001b[42G\u001b[38;5;153mclyffy-telemetry/src/fold.rs\u001b[39m,\u001b[72Gand\r\u001b[2C\u001b[1B\u001b[38;5;153mFoldPhase::ALL: [FoldPhase; 7]\u001b[34G\u001b[39mis\u001b[37Glength-checked\u001b[52Gat\u001b[55Gcompile\u001b[63Gtime,\u001b[69Gso\u001b[72Gthe\u001b[76G400\r\u001b[2C\u001b[1B\"legal set\" message can't dr\u001b[32Gft when variants are add\u001b[57Gd.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mImprovements queued in t\u001b[56G\u001b[22mer (blocked on\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
