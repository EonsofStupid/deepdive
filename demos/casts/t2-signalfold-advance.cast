[267816.990568, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bexist.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mBlocking DuckDB insert on a tokio worker\u001b[47G\u001b[22m— the \u001b[38;5;153m/signal/fold\u001b[39m handler\u001b[74Gemits\r\u001b[2C\u001b[1Bstraight through the\u001b[25Garehouse sink with no \u001b[38;5;153mspawn_blocking\u001b[39m.\u001b[63GFine\u001b[68Gat\r\u001b[2C\u001b[1Bhook-traffic volume, w\u001b[26Gong shape under bursts.\u001b[K\r\u001b[2C\u001b[1B4. \u001b[1mNo idempotency\u001b[22m — a retried curl or\u001b[41Gfuture\u001b[48Gqueue\u001b[54Greplay\u001b[61Gdouble-inserts;\u001b[77Gno\r\u001b[2C\u001b[1Bsignal\u001b[10GUUID\u001b[15Gor\u001b[18Guniqueness\u001b[29Gconstraint.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mNon-gotcha worth noting:\u001b[22m validation\u001b[40Gs\u001b[42Gproperly single-sourced — the\u001b[72Ge\u001b[75Gpoint\r\u001b[2C\u001b[1Bparses via the shared \u001b[38;5;153mFromStr\u001b[39m impls in \u001b[38;5;153mclyffy-telemetry/src/fold.rs\u001b[39m,\u001b[72Gand\u001b[76G\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mFoldPhase::ALL: [FoldPhase; 7]\u001b[39m is length-checked at compile\u001b[63Gtime,\u001b[69Gso\u001b[72Gthe\u001b[76G400\r\u001b[2C\u001b[1B\"legal\u001b[10Gset\"\u001b[15Gmessage\u001b[23Gcan't\u001b[29Gdrift\u001b[35Gwhen\u001b[40Gvariants\u001b[49Gare\u001b[53Gadded.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mImprovements queued in the doc:\u001b[22m boo\u001b[40Gtime queue drainer (blocked on\u001b[K\r\u001b[2C\u001b[1Bid\u001b[6Gmpotency),\u001b[17Gsignal UUID + c\u001b[33Gnflict-ignore semantics, \u001b[38;5;153mspawn_blocking\u001b[73G\u001b[39maround\r\u001b[2C\u001b[1Bthe emit, and\u001b[17Gtest\u001b[22Ggaps\u001b[27G(unknown\u001b[36G\u001b[38;5;153mlane\u001b[39m/\u001b[38;5;153mengine\u001b[48G\u001b[39m400\u001b[52Gpaths,\u001b[59G\u001b[38;5;153msupersedes\r\u001b[2C\u001b[1B\u001b[39mround-trip).\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[267817.005365, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B(per #1)\u001b[12Gis\u001b[15Gcurrently\u001b[25Ga\u001b[27Gwrite-only\u001b[38Ghole.\u001b[44GFallback\u001b[53Gworks;\u001b[60Greplay\u001b[67Gdoesn't\r\u001b[2C\u001b[1Bexist.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mBlocking DuckDB insert on a tokio worker\u001b[47G\u001b[22m— the \u001b[38;5;153m/signal/fold\u001b[39m handler\u001b[74Gemits\r\u001b[2C\u001b[1Bstraight through the\u001b[25Garehouse sink with no \u001b[38;5;153mspawn_blocking\u001b[39m.\u001b[63GFine\u001b[68Gat\r\u001b[2C\u001b[1Bhook-traffic volume, w\u001b[26Gong shape under bursts.\u001b[K\r\u001b[2C\u001b[1B4. \u001b[1mNo idempotency\u001b[22m — a retried curl or\u001b[41Gfuture\u001b[48Gqueue\u001b[54Greplay\u001b[61Gdouble-inserts;\u001b[77Gno\r\u001b[2C\u001b[1Bsignal\u001b[10GUUID\u001b[15Gor\u001b[18Guniqueness\u001b[29Gconstraint.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mNon-gotcha worth noting:\u001b[22m validation\u001b[40Gs\u001b[42Gproperly single-sourced — the\u001b[72Ge\u001b[75Gpoint\r\u001b[2C\u001b[1Bparses via the shared \u001b[38;5;153mFromStr\u001b[39m impls in \u001b[38;5;153mclyffy-telemetry/src/fold.rs\u001b[39m,\u001b[72Gand\u001b[76G\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mFoldPhase::ALL: [FoldPhase; 7]\u001b[39m is length-checked at compile\u001b[63Gtime,\u001b[69Gso\u001b[72Gthe\u001b[76G400\r\u001b[2C\u001b[1B\"legal\u001b[10Gset\"\u001b[15Gmessage\u001b[23Gcan't\u001b[29Gdrift\u001b[35Gwhen\u001b[40Gvariants\u001b[49Gare\u001b[53Gadded.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mImprovements queued in the doc:\u001b[22m boo\u001b[40Gtime queue drainer (blocked on\u001b[K\r\u001b[2C\u001b[1Bid\u001b[6Gmpotency),\u001b[17Gsignal UUID + c\u001b[33Gnflict-ignore semantics, \u001b[38;5;153mspawn_blocking\u001b[73G\u001b[39maround\r\u001b[2C\u001b[1Bthe emit, and\u001b[17Gtest\u001b[22Ggaps\u001b[56Gs,\u001b[59G\u001b[38;5;153msupersedes\u001b[39m\u001b[23;1H\u001b[20;3