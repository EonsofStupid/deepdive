[471.950513, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bdepth, with a\u001b[17Gproposed gate \u001b[32Gest: \u001b[38;5;153m/capabilities\u001b[39m identical\u001b[61Gacross profiles\u001b[K\r\u001b[2C\u001b[1Bmodulo\u001b[10Gmodel fields.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mSurface owns transport, packs own risk-gates\u001b[51G\u001b[22m—\u001b[53GDevPulse\u001b[62G=\u001b[64Gvariant,\u001b[73GBrain\r\u001b[2C\u001b[1BAPI surface owns QUIC/attach/outbox plumbing, capability-packs declare\u001b[K\r\u001b[2C\u001b[1Bwork-item risk classes and branch 2's destructive gate is enforc\u001b[68Gd f\u001b[72Gom\u001b[75Gthose\r\u001b[2C\u001b[1Bdeclarations in the control l\u001b[33Gyer.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BKilled\u001b[10Gand\u001b[14Gnamed:\u001b[21Gapp-only\u001b[30G(both\u001b[36Gflavors),\u001b[46Greduced\u001b[54GLite\u001b[59Gcontract,\r\u001b[2C\u001b[1Btransport-as-pack, dual attachments, handoff-on-close. Ope\u001b[62G h\u001b[65Gndoffs\u001b[72Gto\u001b[75Gthe\r\u001b[2C\u001b[1Bfold: client\u001b[16Gcore/agent\u001b[27Glive DevPulse-si\u001b[44Ge and need the COSTAR gate on \u001b[3mthat\r\u001b[2C\u001b[1B\u001b[23mtree,\u001b[9GIPC frame subs\u001b[24Gt,\u001b[27Gagent update story.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mConfirm the close\u001b[22m,\u001b[22Gand\u001b[26Gthen\u001b[31Gexit\u001b[36Gthis\u001b[41Gsession\u001b[49G—\u001b[51Gthat\u001b[56Gfires\u001b[62G\u001b[38;5;153mbranch_closed\u001b[76G\u001b[39mand\r\u001b[2C\u001b[1Bwakes the source to run \u001b[56Ges.\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
