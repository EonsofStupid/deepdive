[301688.377308, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWiring (not applied — ~/.claude untouched)\r\u001b[2C\u001b[1B\u001b[22mClaude Code's \u001b[38;5;153mstatusLine\u001b[39m takes one command,\u001b[47Gso\u001b[50Gthe\u001b[54Gtwo\u001b[58Gscripts\u001b[66Gcompose\u001b[74Gby\r\u001b[2C\u001b[1Bteeing\u001b[10Gthe same stdin JSON into both (this exac\u001b[51G command was exercised\u001b[74Gabove):\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B{\r\u001b[2C\u001b[1B \u001b[5G\u001b[36m\"statusLine\"\u001b[39m:\u001b[19G{\r\u001b[4C\u001b[1B  \u001b[36m\"type\"\u001b[39m: \u001b[31m\"command\"\u001b[39m,\r\u001b[7C\u001b[1B\u001b[36mcommand\"\u001b[39m: \u001b[31m\"b\u001b[21Gsh -c 'in=$(cat); printf \\\"%s  %s\\\" \\\"$(printf %s \\\"$in\\\" | \r\u001b[2C\u001b[1B~/.claude/statusline-infisical.sh\u001b[37G\\\" \\\"$(printf\u001b[51G%s \u001b[56G$in\\\" | \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[31m/home/hade\u001b[14G/clyffy/landing/study/t1/b/statusline-pxpipe.sh)\\\"'\"\r\u001b[2C\u001b[1B\u001b[39m  }\u001b[K\r\u001b[2C\u001b[1B}\u001b[5G\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B(The\u001b[8Gpxpipe\u001b[15Gscript\u001b[22Gprints\u001b[29Gonly\u001b[34Gits\u001b[38Gown\u001b[42Gsegment\u001b[50G—\u001b[52Gdir/model\u001b[62Gstay\u001b[67Gowned\u001b[73Gby\u001b[76Gthe\r\u001b[2C\u001b[1Bexisting script — which \u001b[56Glean two-comman\u001b[73Gjoin.)\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
[301688.400634, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[2B{\u001b[K\r\u001b[2C\u001b[1B  \u001b[36m\"statusLine\"\u001b[39m: {\u001b[K\r\u001b[2C\u001b[1B    \u001b[36m\"type\"\u001b[39m: \u001b[31m\"command\"\u001b[39m,\u001b[K\r\u001b[6C\u001b[1B\u001b[36m\"command\"\u001b[39m:\u001b[18G\u001b[31m\"bash -c 'in=$(cat); printf \\\"%s  %s\\\" \\\"$(printf %s \\\"$in\\\" | \r\u001b[2C\u001b[1B~/.claude/statusline-infisical.sh)\\\" \\\"$(printf %s \\\"$in\\\" | \r\u001b[2C\u001b[1B/home/hades/clyffy/landing/study/t1/b/statusline-pxpipe.sh)\\\"'\"\r\u001b[4C\u001b[1B\u001b[39m}\u001b[7G\u001b[K\r\u001b[2C\u001b[1B}\u001b[7G\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B(The pxpipe script prints only its own segment — dir/model stay\u001b[67Gowned\u001b[73Gby\u001b[76Gthe\r\u001b[2C\u001b[1Bexisting\u001b[12Gscript\u001b[19G—\u001b[21Gwhich\u001b[27Gis\u001b[30Gwhy\u001b[34Gthe\u001b[38Gcomposition\u001b[50Gis\u001b[53Ga\u001b[55Gclean\u001b[61Gtwo-command\u001b[73Gjoin.)\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BOne\u001b[7Gresidue\u001b[15Gfrom\u001b[20Gtesting:\u001b[29Gthe\u001b[33Gshared\u001b[40Gcache\u001b[46Gcurrently\u001b[56Gholds\u001b[62Gan\u001b[65G\"up\"\u001b[70Gentry\u001b[76G≤5s\r\u001b[2C\u001b[1Bold;\u001b[8Git self-expires, \u001b[26Gothi\u001b[31Gg to clea\u001b[41G.\u001b[K\r\u001b[2C\u001b[1B        \u001b[12G      \u001b[19G \u001b[21G     \u001b[56G\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
