[267127.52624, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[7C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m80\u001b[24G\u001b[38;5;231m.\u001b[38;5;148minto_response\u001b[38;5;231m(),              \r\u001b[7C\u001b[1B\u001b[38;5;77m81\u001b[20G\u001b[38;5;148mErr\u001b[38;5;231m(e)\u001b[27G=> {      \u001b[38G             \r\u001b[7C\u001b[1B\u001b[38;5;77m82\u001b[24G\u001b[38;5;231m(StatusCode::INTERNAL_SERVER_ERROR,\u001b[60G\u001b[38;5;148mformat!\u001b[38;5;231m(\u001b[38;5;186m\"fold \r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;186msignal not recorded: {e}\"\u001b[38;5;231m)).\u001b[38;5;148minto_response\u001b[38;5;231m()\r\u001b[8C\u001b[1B\u001b[38;5;77m3\u001b[20G\u001b[38;5;231m}\u001b[24G                 \r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;231m}\u001b[20G      \u001b[27G  \u001b[30G \r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[12G\u001b[38;5;231m}\u001b[24G                                   \u001b[60G              \r\u001b[6C\u001b[1B\u001b[38;5;77m786\u001b[12G\u001b[38;5;231m                                           \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 787 \u001b[22m \u001b[38;5;242m/// Mirror the CLI: `$CLYFFY_CONFIG` or `<home.root>/clyffy.to\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m     \u001b[22m \u001b[38;5;242mml`, else defaults. Never fails to boot.\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 788 \u001b[22m \u001b[38;5;81mfn\u001b[38;5;231m \u001b[38;5;148mload_config\u001b[38;5;231m() -> ClyffyConfig {\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 789 \u001b[22m     \u001b[38;5;81mlet\u001b[38;5;231m path = std::env::\u001b[38;5;148mvar\u001b[38;5;231m(\u001b[38;5;186m\"CLYFFY_CONFIG\"\u001b[38;5;231m)\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[3G\u001b[39mNow the tests, then the gate:\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;246m●\u001b[3G\u001b[39mReading \u001b[1m2\u001b[22m files, running\u001b[55G\u001b[K\u001b[