[702.750473, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gnever sees a client\u001b[23GMAC. If DevPulse\u001b[40Gever needs di\u001b[54Gcovery-style broadcast\u001b[K\r\u001b[2C\u001b[1Bs\u001b[5Gmantics,\u001b[14Gwe solve\u001b[23Git with\u001b[31Gan mDNS r\u001b[41Gflector, not bridging.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCrypto:\u001b[22m hybrid X25519+ML-KEM\u001b[34G(rustls d\u001b[44Gfault), device-keypair\u001b[67Genrollment\u001b[78Gvia\r\u001b[2C\u001b[1Bthe HTTP cont\u001b[17Gol\u001b[20Gplane, and a \u001b[1mhash-chained tamper-evident session ledger in \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mconnectome\u001b[22m — the\u001b[20Gb\u001b[22Gockch\u001b[28Gin-shaped property you asked for, without consensus\r\u001b[2C\u001b[1Boverhead.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mHonesty gate (no-reward-hacking):\u001b[39G\u001b[22mbefore\u001b[46Gwe\u001b[49Gdeclare\u001b[57Gvictory,\u001b[66Gthe\u001b[70GQUIC\u001b[75Gfast\r\u001b[2C\u001b[1Bpath gets benchmarked against a plain rkyv-over-TCP stream on the same LAN. If\r\u001b[2C\u001b[1Bit can'\u001b[11G hold ~wi\u001b[21Ge-speed on the \u001b[37Gocal path, the fallback ca\u001b[64Gdidate is\u001b[74G\u001b[K\r\u001b[2C\u001b[1Bembedded\u001b[12GWireGuard via NepTUN+smo\u001b[37Gt\u001b[39Gp — kept\u001b[48Galive in the\u001b[61Gnotes, not built.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat this supersedes:\u001b[25G\u001b[22mthe\u001b[29Graw-ethernet/AF_PACKET/AF_XDP/RoCE\u001b[64Gcandidates\r\u001b[2C\u001b[1B(killed by cross-platform\u001b[29Gclien\u001b[35Gs) and literal L2 bridging (killed on \u001b[74Gecurity\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[703.216379, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gthe HTTP control plane, and\u001b[31Ga \u001b[1mhash-chained tamper-evident session ledger in \r\u001b[2C\u001b[1Bconnectome\u001b[14G\u001b[22m— the blockchain-shaped p\u001b[40Goperty you asked for, without\u001b[70Gconsensus\r\u001b[2C\u001b[1Boverhead.\u001b[13G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mHonesty gate (no-reward-hacking):\u001b[22m before we declare victory, the QUIC fast\r\u001b[2C\u001b[1Bpath gets benc\u001b[18Gmarked ag\u001b[30Gst \u001b[34G plain rkyv-over-TCP stream\u001b[62Gon the same LAN. If\r\u001b[2C\u001b[1Bit can't hold\u001b[17G~wire-speed\u001b[29Gon\u001b[32Gthe\u001b[36Glocal\u001b[42Gpath,\u001b[48Gthe\u001b[52Gfallback\u001b[61Gcandidate\u001b[71Gis\r\u001b[2C\u001b[1Bembedded WireGuard via NepTUN+smoltcp — k\u001b[45Gpt alive in\u001b[57Gthe notes, not built.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mWhat this supersedes:\u001b[22m the\u001b[29Graw-ethernet/AF_PACKET/AF_XDP/RoCE candidates\r\u001b[2C\u001b[1B(killed by cross-platform clients) and literal L2 bridging (killed on security\r\u001b[2C\u001b[1Bgrounds).\u001b[13GZeroTier\u001b[22Grejected\u001b[31Gon\u001b[34Glicensing\u001b[44G+\u001b[46Gweight.\u001b[54GNothing\u001b[62Gprior\u001b[68Gin\u001b[71Gthe\u001b[75Gdive\r\u001b[2C\u001b[1Bis overturned.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
