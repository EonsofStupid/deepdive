[686.623123, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;114m●\u001b[3G\u001b[39mAgent\u001b[9G\"Research\u001b[19Gembedded\u001b[28GWG\u001b[31G+\u001b[33GPQ\u001b[36G+\u001b[38GL2\u001b[41Goverlays\"\u001b[51Gfinished\u001b[38;5;246m · 5m 20s\r\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[3G\u001b[39mSpur\u001b[8G2\u001b[10Gis\u001b[13Gback\u001b[18Gtoo\u001b[22G—\u001b[24Gthe\u001b[28Gfull\u001b[33Gpicture\u001b[41Gis\u001b[44Gnow\u001b[48Gon\u001b[51Gthe\u001b[55Gtable,\u001b[62Gand\u001b[66Git's\u001b[71Gdecisive\r\u001b[1B \u001b[3Genough\u001b[10Gto\u001b[13Gpropose the branch decision. Three\u001b[48Gload-bearing fi\u001b[65Gings first:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B1.\u001b[6G\u001b[1mRust embedded-WireGuard is shakier than it looks.\u001b[56G\u001b[22mboringtun\u001b[66Gis\u001b[69Geffectively\r\u001b[2C\u001b[1Borphaned at Cloudflare (\"no active, dedicated maintaine\u001b[59G\"; NordSecurity's\u001b[K\r\u001b[2C\u001b[1BNe\u001b[6GTUN fork\u001b[15Gis the live o\u001b[29Ge). The production-gr\u001b[51Gde \"tunnel\u001b[62Gas a lib\u001b[71Gar\u001b[74G, no\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[687.091214, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2B\u001b[38;5;231m●\u001b[3G\u001b[39mSpur 2 is b\u001b[15Gck too — the\u001b[28Gfull\u001b[33Gpicture\u001b[41Gis now on\u001b[51Gthe table, and it's\u001b[71Gdecisive\r\u001b[2C\u001b[1Benough\u001b[10Gto\u001b[13Gpropose\u001b[21Gthe\u001b[25Gbranch\u001b[32Gdecision.\u001b[42GThree\u001b[48Gload-bearing\u001b[61Gfindings\u001b[70Gfirst:\r\u001b[1B\u001b[K\r\u001b[2C\u001b[1B1. \u001b[1mRust embedded-WireGuard is shakier than it looks.\u001b[22m boringtun is e\u001b[71Gfec\u001b[75Gively\r\u001b[2C\u001b[1Borphaned\u001b[12Gat\u001b[15GCloudflare\u001b[26G(\"no\u001b[31Gactive,\u001b[39Gdedicated\u001b[49Gmaintainer\";\u001b[62GNordSecurity's\r\u001b[2C\u001b[1BNepTUN fork is the live one). The production-grade \"tunnel as a library, no\u001b[K\r\u001b[2C\u001b[1Badmin righ\u001b[14Gs, no TUN device\" impl\u001b[37Gmentations (T\u001b[52Glscal\u001b[58G's tsnet, NetBird\u001b[K\r\u001b[2C\u001b[1Bembed)\u001b[10Gare \u001b[1mGo\u001b[22m.\u001b[18GT\u001b[22GRust\u001b[27Gequivalent (smol\u001b[44Gcp + WG \u001b[53Gngine) is a\u001b[65Gproven \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23m\u001b[K\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[687.177643, "o", "\u001b]0;⠐ dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR brief) then begin\u0007"]
[687.56024, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B\u001b[38;5;231m●\u001b[3G\u001b[39mSpur\u001b[8G2\u001b[10Gis\u001b[13Gback\u001b[18Gtoo\u001b[22G—\u001b[24Gthe\u001b[28Gfull\u001b[33Gpicture\u001b[41Gis\u001b[44Gnow\u001b[48Gon\u001b[51Gthe\u001b[55Gtable,\u001b[62Gand\u001b[66Git's\u001b[71Gdecisive\r\u001b[1B \u001b[3Genough\u001b[10Gto\u001b[13Gpropose the branch decision. Three\u001b[48Gload-bearing fi\u001b[65Gings first:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B1.\u001b[6G\u001b[1mRust embedded-WireGuard is shakier than it looks.\u001b[56G\u001b[22mboringtun\u001b[66Gis\u001b[69Geffectively\r\u001b[2C\u001b[1Borphaned at Cloudflare (\"no active, dedicated maintaine\u001b[59G\"; NordSecurity's\u001b[K\r\u001b[2C\u001b[1BNe\u001b[6GTUN fork\u001b[15Gis the live o\u001b[29Ge). The production-gr\u001b[51Gde \"tunnel\u001b[62Gas a lib\u001b[71Gar\u001b[74G, no\r\u001b[2C\u001b[1Badmin rights, no TUN d\u001b[26Gvic\u001b[30G\" implementations (T\u001b[51Gilscale's tsnet, NetBird\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bembed) are \u001b[1mGo\u001b[22m. The Rust equivalent (smoltcp + WG engin\u001b[58G) is a prov\u001b[70Gn \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23mwith we\u001b[11Gk maintenance —\u001b[27Gwe'd own it.\u001b[K\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[688.015662, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[10B\u001b[K\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[688.118358, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[38;5;231m●\u001b[3G\u001b[39mSpur\u001b[8G2\u001b[10Gis\u001b[13Gback\u001b[18Gtoo\u001b[22G—\u001b[24Gthe\u001b[28Gfull\u001b[33Gpicture\u001b[41Gis\u001b[44Gnow\u001b[48Gon\u001b[51Gthe\u001b[55Gtable,\u001b[62Gand\u001b[66Git's\u001b[71Gdecisive\r\u001b[1B \u001b[3Genough\u001b[10Gto\u001b[13Gpropose the branch decision. Three\u001b[48Gload-bearing fi\u001b[65Gings first:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B1.\u001b[6G\u001b[1mRust embedded-WireGuard is shakier than it looks.\u001b[56G\u001b[22mboringtun\u001b[66Gis\u001b[69Geffectively\r\u001b[2C\u001b[1Borphaned at Cloudflare (\"no active, dedicated maintaine\u001b[59G\"; NordSecurity's\u001b[K\r\u001b[2C\u001b[1BNe\u001b[6GTUN fork\u001b[15Gis the live o\u001b[29Ge). The production-gr\u001b[51Gde \"tunnel\u001b[62Gas a lib\u001b[71Gar\u001b[74G, no\r\u001b[2C\u001b[1Badmin rights, no TUN d\u001b[26Gvic\u001b[30G\" implementations (T\u001b[51Gilscale's tsnet, NetBird\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bembed) are \u001b[1mGo\u001b[22m. The Rust equivalent (smoltcp + WG engin\u001b[58G) is a prov\u001b[70Gn \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23mwith we\u001b[11Gk maintenance —\u001b[27Gwe'd own it.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \r\u001b[2C\u001b[1B\u001b[22m\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[688.14103, "o", "\u001b]0;⠂ dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR brief) then begin\u0007"]
[688.504214, "o", "\u001b[?2026h\u001b[?25l\u001b[H \u001b[3Genough\u001b[10Gto\u001b[13Gpropose the branch decision. Three\u001b[48Gload-bearing fi\u001b[65Gings first:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B1.\u001b[6G\u001b[1mRust embedded-WireGuard is shakier than it looks.\u001b[56G\u001b[22mboringtun\u001b[66Gis\u001b[69Geffectively\r\u001b[2C\u001b[1Borphaned at Cloudflare (\"no active, dedicated maintaine\u001b[59G\"; NordSecurity's\u001b[K\r\u001b[2C\u001b[1BNe\u001b[6GTUN fork\u001b[15Gis the live o\u001b[29Ge). The production-gr\u001b[51Gde \"tunnel\u001b[62Gas a lib\u001b[71Gar\u001b[74G, no\r\u001b[2C\u001b[1Badmin rights, no TUN d\u001b[26Gvic\u001b[30G\" implementations (T\u001b[51Gilscale's tsnet, NetBird\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bembed) are \u001b[1mGo\u001b[22m. The Rust equivalent (smoltcp + WG engin\u001b[58G) is a prov\u001b[70Gn \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23mwith we\u001b[11Gk maintenance —\u001b[27Gwe'd own it.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \r\u001b[2C\u001b[1Banti-pattern\u001b[22m — OpenVPN's own docs, WireGuard's whitepaper rationale, and\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[688.874689, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[10B\u001b[K\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[688.978152, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[K\r\u001b[2C\u001b[1B1.\u001b[6G\u001b[1mRust embedded-WireGuard is shakier than it looks.\u001b[56G\u001b[22mboringtun\u001b[66Gis\u001b[69Geffectively\r\u001b[2C\u001b[1Borphaned at Cloudflare (\"no active, dedicated maintaine\u001b[59G\"; NordSecurity's\u001b[K\r\u001b[2C\u001b[1BNe\u001b[6GTUN fork\u001b[15Gis the live o\u001b[29Ge). The production-gr\u001b[51Gde \"tunnel\u001b[62Gas a lib\u001b[71Gar\u001b[74G, no\r\u001b[2C\u001b[1Badmin rights, no TUN d\u001b[26Gvic\u001b[30G\" implementations (T\u001b[51Gilscale's tsnet, NetBird\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bembed) are \u001b[1mGo\u001b[22m. The Rust equivalent (smoltcp + WG engin\u001b[58G) is a prov\u001b[70Gn \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23mwith we\u001b[11Gk maintenance —\u001b[27Gwe'd own it.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \r\u001b[2C\u001b[1Banti-pattern\u001b[22m — OpenVPN's own docs, WireGuard's whitepaper rationale, and\r\u001b[2C\u001b[1Bzero-trust consensus all\u001b[28Gsay\u001b[32Gr\u001b[34Guted + ACLs; ZeroT\u001b[53Ger (the\u001b[61Gonly serious true-L2\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[689.104111, "o", "\u001b]0;⠐ dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR brief) then begin\u0007"]
[689.448992, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gorphaned\u001b[12Gat\u001b[15GCloudflare\u001b[26G(\"no\u001b[31Gactive,\u001b[39Gdedicated\u001b[49Gmaintainer\";\u001b[62GNordSecurity's\r\u001b[2C\u001b[1BNepTUN fork is the live one). The production-grade \"tunnel as a library, no\u001b[K\r\u001b[2C\u001b[1Badmin righ\u001b[14Gs, no TUN device\" impl\u001b[37Gmentations (T\u001b[52Glscal\u001b[58G's tsnet, NetBird\u001b[K\r\u001b[2C\u001b[1Bembed)\u001b[10Gare \u001b[1mGo\u001b[22m.\u001b[18GT\u001b[22GRust\u001b[27Gequivalent (smol\u001b[44Gcp + WG \u001b[53Gngine) is a\u001b[65Gproven \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23mwith weak maintenance — we'd\u001b[32Gown it.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1manti-pattern\u001b[22m — Ope\u001b[22GVPN's own\u001b[32Gdocs, WireGuard's\u001b[50Gwhitepaper\u001b[61Grationale,\u001b[72Gand\r\u001b[2C\u001b[1Bzero-trust consensus all say routed + ACLs; ZeroTier (the only serious\u001b[74Gtrue-L2\r\u001b[2C\u001b[1Boverlay) also has a commercial-license landmine on its self-hosted\u001b[K\r\u001b[2C\u001b[1Bcontroller. Your DAC\u001b[24Gfabric stays sealed; the bridge\u001b[56Gshould terminate a\u001b[75G\u001b[K\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[689.916342, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3GNe\u001b[6GTUN fork\u001b[15Gis the live o\u001b[29Ge). The production-gr\u001b[51Gde \"tunnel\u001b[62Gas a lib\u001b[71Gar\u001b[74G, no\r\u001b[2C\u001b[1Badmin rights, no TUN d\u001b[26Gvic\u001b[30G\" implementations (T\u001b[51Gilscale's tsnet, NetBird\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bembed) are \u001b[1mGo\u001b[22m. The Rust equivalent (smoltcp + WG engin\u001b[58G) is a prov\u001b[70Gn \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23mwith we\u001b[11Gk maintenance —\u001b[27Gwe'd own it.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \r\u001b[2C\u001b[1Banti-pattern\u001b[22m — OpenVPN's own docs, WireGuard's whitepaper rationale, and\r\u001b[2C\u001b[1Bzero-trust consensus all\u001b[28Gsay\u001b[32Gr\u001b[34Guted + ACLs; ZeroT\u001b[53Ger (the\u001b[61Gonly serious true-L2\r\u001b[2C\u001b[1Boverlay) als\u001b[16G has a commercial-license landmine on its s\u001b[60Glf-host\u001b[68Gd\u001b[K\r\u001b[2C\u001b[1Bcontroller. Your DAC fabri\u001b[30G stays sealed; the bridge \u001b[57Ghou\u001b[61Gd terminate\u001b[73Gat\r\u001b[3C\u001b[1Blyffy's edge.\u001b[K\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[690.066626, "o", "\u001b]0;⠂ dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR brief) then begin\u0007"]
[690.391697, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gadmin rights, no TUN d\u001b[26Gvic\u001b[30G\" implementations (T\u001b[51Gilscale's tsnet, NetBird\u001b[76G\u001b[K\r\u001b[2C\u001b[1Bembed) are \u001b[1mGo\u001b[22m. The Rust equivalent (smoltcp + WG engin\u001b[58G) is a prov\u001b[70Gn \u001b[3mconcept\r\u001b[2C\u001b[1B\u001b[23mwith we\u001b[11Gk maintenance —\u001b[27Gwe'd own it.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \r\u001b[2C\u001b[1Banti-pattern\u001b[22m — OpenVPN's own docs, WireGuard's whitepaper rationale, and\r\u001b[2C\u001b[1Bzero-trust consensus all\u001b[28Gsay\u001b[32Gr\u001b[34Guted + ACLs; ZeroT\u001b[53Ger (the\u001b[61Gonly serious true-L2\r\u001b[2C\u001b[1Boverlay) als\u001b[16G has a commercial-license landmine on its s\u001b[60Glf-host\u001b[68Gd\u001b[K\r\u001b[2C\u001b[1Bcontroller. Your DAC fabri\u001b[30G stays sealed; the bridge \u001b[57Ghou\u001b[61Gd terminate\u001b[73Gat\r\u001b[3C\u001b[1Blyffy's edge.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mPost-quantum is free on the QUIC path.\u001b[45G\u001b[22mX25519+ML-KEM\u001b[59Ghybrid\u001b[66Gis\u001b[69Gdefault\u001b[77Gin\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[690.814718, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[10B\u001b[K\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[690.915973, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1manti-pattern\u001b[22m —\u001b[18GOp\u001b[21GnVPN's own docs,\u001b[38GWireGuard's whitepaper rational\u001b[70G,\u001b[72Gand\u001b[K\r\u001b[2C\u001b[1Bzero-trust co\u001b[17Gs\u001b[20Gsus all say\u001b[32Grouted +\u001b[41GACLs;\u001b[47GZeroTier\u001b[56G(the\u001b[61Gonly\u001b[66Gserious\u001b[74Gtrue-L2\r\u001b[2C\u001b[1Boverlay) also has a commercial-license landmine on its self-hosted\u001b[K\r\u001b[2C\u001b[1Bcontroller. Your DAC fabric stay\u001b[36G seal\u001b[42Gd; the bridg\u001b[55G should \u001b[64Germinate at\r\u001b[2C\u001b[1Bclyffy's edge.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mPost-quantum is free on the QUIC path.\u001b[22m X25519+ML-KEM hybrid is default\u001b[77Gin\r\u001b[2C\u001b[1B2026 TLS/QUIC stacks\u001b[24G(rustls includ\u001b[39Gd). On the W\u001b[52GreGuard path it requires\u001b[77Gthe\r\u001b[2C\u001b[1BRosenpa\u001b[11Gs/PSK-rotation\u001b[26Gdance\u001b[32G(pre-1.0,\u001b[42Gexperimental\u001b[55Geven\u001b[60Gin\u001b[63GNetBird).\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[691.02907, "o", "\u001b]0;⠐ dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR brief) then begin\u0007"]
[691.394306, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Goverlay) also has a commercial-license landmine on its self-hosted\u001b[K\r\u001b[2C\u001b[1Bcontroller. Your DAC fabric stay\u001b[36G seal\u001b[42Gd; the bridg\u001b[55G should \u001b[64Germinate at\r\u001b[2C\u001b[1Bclyffy's edge.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mPost-quantum is free on the QUIC path.\u001b[22m X25519+ML-KEM hybrid is default\u001b[77Gin\r\u001b[2C\u001b[1B2026 TLS/QUIC stacks\u001b[24G(rustls includ\u001b[39Gd). On the W\u001b[52GreGuard path it requires\u001b[77Gthe\r\u001b[2C\u001b[1BRosenpa\u001b[11Gs/PSK-rotation\u001b[26Gdance\u001b[32G(pre-1.0,\u001b[42Gexperimental\u001b[55Geven\u001b[60Gin\u001b[63GNetBird).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mProposed decision\u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B**\"Layer\u001b[12G2\"\u001b[15Gbecomes\u001b[23Gthe\u001b[27Gsecond\u001b[34Glayer\u001b[40Gof\u001b[43Gthe\u001b[47Gconnection\u001b[58G—\u001b[60Ga\u001b[62GQUIC-native\u001b[74Gsecure\u001b[23;1H\u001b[16;4H\u001b[?25h\u001b[?2026l"]
[691.562647, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G2. \u001b[1mL2-bridging a client into a server broadcast domain is a confirmed \r\u001b[2C\u001b[1Banti-pattern\u001b[22m — OpenVPN's own doc\u001b[36G, Wir\u001b[42GGuard's whit\u001b[55Gpaper ra\u001b[64Gionale, and\r\u001b[2C\u001b[1Bzero-trust consensus\u001b[24Gall\u001b[28Gsay\u001b[32Grouted\u001b[39G+\u001b[41GACLs;\u001b[47GZeroTier\u001b[56G(the\u001b[61Gonly\u001b[66Gserious\u001b[74Gtrue-L2\r\u001b[2C\u001b[1Boverlay) also has a commercial-license landmine on its self-hosted\u001b[K\r\u001b[2C\u001b[1Bcontroller. Your DAC\u001b[24Gfabric stays s\u001b[39Galed; the br\u001b[52Gdge should terminate at\u001b[K\r\u001b[2C\u001b[1Bclyffy'\u001b[11G edge.\u001b[K\r\u001b[2C\u001b[1B3.\u001b[6G\u001b[1mPost-quantum is free on the QUIC path.\u001b[45G\u001b[22mX25519+ML-KEM\u001b[59Ghybrid\u001b[66Gis\u001b[69Gdefault\u001b[77Gin\r\u001b[2C\u001b[1B2026 TLS/QUIC stacks\u001b[24G(rustls\u001b[32Gincluded).\u001b[43GOn\u001b[46Gthe\u001b[50GWireGuard\u001b[60Gpath\u001b[65Git\u001b[68Grequires\u001b[77Gthe\r\u001b[2C\u001b[1BRosenpass/PSK-rotation\u001b[26Gdance\u001b[32G(pre-1.0,\u001b[42Gexperimental\u001b[55Geven\u001b[60Gin\u001b[63GNetBird).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mProposed decision\r\u001b[2C\u001b[1B\u001b[22m\u001b[K\r\u001b[2C\u001b[1B**\"Layer\u001b[12G2\"\u001b[15Gbecomes\u001b[23Gthe\u001b[27Gsecond\u001b[34Glayer\u001b[40Gof\u001b[43Gthe\u001b[47Gconnection\u001b[58G—\u001b[60Ga\u001b[62GQUIC-native\u001b[74Gsecure\r\u001b[1B\u001b[K\r\u001b[1B  \u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \r\u001b[1B\u001b[49m\u001b[K\r\u001b[1B\u001b[48;5;37m\u001b[38;5;16m dd:Read ~/.deepdive/dives/devpulse-l2-session/briefs/l2-transport.md (COSTAR \u001b[39m\u001b[49m\u001b[K\r\u001b[1B\u001b[48;5;37m\u001b[38;5;16mbrief) then begin \u001b[49m\u001b[38;5;37m──\r\u001b[1B\u001b[38;5;246m❯ \u001b[39mc\u001b[K\r\u001b[1B\u001b[38;5;37m────────────────────────────────────────────────────────────────────────────────\r\u001b[1B──────────────────\r\u001b[1B\u001b[39m  \u001b[38;5;246m\u001b[2mhades\u001b[22m  \u001b[36mFable 5\u001b[38;5;246m  🔐 Infisical \u001b[32m●\r\u001b[1B\u001b[39m  \u001b[38;5;211m⏵⏵ bypass permissions on\u001b[38;5;246m (shift+tab to cycle)\u001b[39m\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[691.861009, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Goverlay) also has a commercial-license landmine on its self-hosted\u001b[K\r\u001b[2C\u001b[1Bcontroller. Your DAC fabric stay\u001b[36G seal\u001b[42Gd; the bridg\u001b[55G should \u001b[64Germinate at\r\u001b[2C\u001b[1Bclyffy's edge.\u001b[K\r\u001b[2C\u001b[1B3. \u001b[1mPost-quantum is free on the QUIC path.\u001b[22m X25519+ML-KEM hybrid is default\u001b[77Gin\r\u001b[2C\u001b[1B2026 TLS/QUIC stacks\u001b[24G(rustls includ\u001b[39Gd). On the W\u001b[52GreGuard path it requires\u001b[77Gthe\r\u001b[2C\u001b[1BRosenpa\u001b[11Gs/PSK-rotation\u001b[26Gdance\u001b[32G(pre-1.0,\u001b[42Gexperimental\u001b[55Geven\u001b[60Gin\u001b[63GNetBird).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mProposed decision\u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m\"Layer 2\" becomes the second layer of the connection — a QUIC-native secure \r\u001b[2C\u001b[1Bdata plane that the HTTP handshake upgrades into, not literal ethernet \r\u001b[2C\u001b[1Bbridging.\u001b[13G\u001b[22mConcretely:\r\u001b[2C\u001b[1B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
