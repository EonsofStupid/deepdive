[31656.298297, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1mGbps\u001b[22m (it's memcpy, no\u001b[25G a\u001b[28Gwire); QUIC measured\u001b[49G\u001b[1m5.0–5.5 Gbps\u001b[22m at ~10× the CPU\u001b[K\r\u001b[2C\u001b[1Bcost. No QUIC stack \u001b[24Gn ea\u001b[29Gth passes \"≥90%\u001b[45Gof loopback\u001b[57GTCP\" — the \u001b[69Geal\u001b[K\r\u001b[2C\u001b[1Bship/no-ship\u001b[16Ggate\u001b[21Gis\u001b[24Gthe\u001b[28G\u001b[1mLAN leg\u001b[22m,\u001b[37Gwhich\u001b[43Gneeds\u001b[49Gthe\u001b[53Gdevstation\u001b[64Gonline.\u001b[72GHonest\r\u001b[2C\u001b[1Bnumbers and the proposed re-anchor are in \u001b[38;5;153mJOURNAL.md\u001b[39m; the r\u001b[63Gcalibration\u001b[75Gis\r\u001b[2C\u001b[1Byour call.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[38;5;153m\u001b[1mclyffy signal fold\u001b[39m core-dumps\u001b[36G\u001b[22m(SIGABRT)\u001b[46G—\u001b[48Gsignals\u001b[56Gare\u001b[60Gqueued\u001b[67Gto\r\u001b[2C\u001b[1B\u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m;\u001b[40Gthe\u001b[44Gcrash\u001b[50Gis\u001b[53Glogged\u001b[60Gas\u001b[63Ga\u001b[65Gdefect\u001b[72Gfor\u001b[76Gthe\r\u001b[2C\u001b[1Bf\u001b[5Gld's work list.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNot\u001b[7Gexercised:\u001b[18Ga\u001b[20Glive\u001b[25G\u001b[38;5;153m/converse\u001b[35G\u001b[39mturn\u001b[40G(brain\u001b[47Gbooted\u001b[54G\u001b[38;5;153mready\u001b[39m;\u001b[61Gthe\u001b[65Gpath\u001b[70Gis\r\u001b[2C\u001b[1Buntouched by th\u001b[19Gs change\u001b[28G— verify wh\u001b[40Gn convenient).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BWhen you've\u001b[15Gverified\u001b[24Gand\u001b[28Gare\u001b[32Gsatisfied,\u001b[43G\u001b[1mexit this session\u001b[61G\u001b[22m—\u001b[63Gthat\u001b[68Gtriggers\r\u001b[2C\u001b[1Bbranch\u001b[10G4\u001b[12G(deployment-sha\u001b[56Gterminal\u001b[65Gfold\u001b[70Gback\u001b[75Gin\u001b[78Gthe\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[31656.338185, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B1. \u001b[1mThe loopback gate criterion is broken as written\u001b[55G\u001b[22m Loopback\u001b[65GTCP measured\u001b[78G\u001b[1m257\r\u001b[2C\u001b[1BGbps\u001b[22m (it's memcpy, n\u001b[24Gt\u001b[26Ga wire); QUIC measured \u001b[1m5.0–5.5 Gbps\u001b[62G\u001b[22mat ~10× the\u001b[74GCPU\r\u001b[2C\u001b[1Bcost. No QUIC s\u001b[19Gack on \u001b[27Garth passes \"≥90% of loopback TCP\" —\u001b[64Gthe r\u001b[70Gal\u001b[K\r\u001b[2C\u001b[1Bship/no-ship gate is the\u001b[28G\u001b[1mLAN leg\u001b[22m, which \u001b[44Geeds the devs\u001b[58Gation online. Hone\u001b[77Gt\r\u001b[2C\u001b[1Bnumbers and\u001b[15Gthe\u001b[19Gproposed\u001b[28Gre-anchor\u001b[38Gare\u001b[42Gin\u001b[45G\u001b[38;5;153mJOURNAL.md\u001b[39m;\u001b[57Gthe\u001b[61Grecalibration\u001b[75Gis\r\u001b[2C\u001b[1Byour call.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[38;5;153m\u001b[1mclyffy signal fold\u001b[39m core-dumps\u001b[22m (SIGABRT) — signa\u001b[54Gs are\u001b[60Gqueue\u001b[66G to\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m;\u001b[40Gthe\u001b[44Gcrash\u001b[50Gis\u001b[53Glogged\u001b[60Gas\u001b[63Ga\u001b[65Gdefect\u001b[72Gfor\u001b[76Gthe\r\u001b[2C\u001b[1Bfold's\u001b[10Gwork\u001b[15Glist.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNo\u001b[6G exercised: a live \u001b[38;5;153m/converse\u001b[39m turn (brain booted \u001b[38;5;153mready\u001b[39m;\u001b[61Gthe\u001b[65Gpath\u001b[70Gis\r\u001b[2C\u001b[1Buntouched\u001b[13Gby\u001b[16Gthis\u001b[21Gchange\u001b[28G—\u001b[30Gverify\u001b[37Gwhen\u001b[42Gconvenient).\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BWhe\u001b[7G you've verified and\u001b[56G\u001b[1msion\u001b[22m — that triggers\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[31656.875481, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1mTwo things need\u001b[19GYOUR\u001b[24Geyes:\u001b[22m\u001b[K\r\u001b[2C\u001b[1B1. \u001b[1mThe loopback gate criterion is broken as written\u001b[55G\u001b[22m Loopback\u001b[65GTCP measured\u001b[78G\u001b[1m257\r\u001b[2C\u001b[1BGbps\u001b[22m (it's memcpy, n\u001b[24Gt\u001b[26Ga wire); QUIC measured \u001b[1m5.0–5.5 Gbps\u001b[62G\u001b[22mat ~10× the\u001b[74GCPU\r\u001b[2C\u001b[1Bcost. No QUIC s\u001b[19Gack on \u001b[27Garth passes \"≥90% of loopback TCP\" —\u001b[64Gthe r\u001b[70Gal\u001b[K\r\u001b[2C\u001b[1Bship/no-ship gate is the\u001b[28G\u001b[1mLAN leg\u001b[22m, which \u001b[44Geeds the devs\u001b[58Gation online. Hone\u001b[77Gt\r\u001b[2C\u001b[1Bnumbers and\u001b[15Gthe\u001b[19Gproposed\u001b[28Gre-anchor\u001b[38Gare\u001b[42Gin\u001b[45G\u001b[38;5;153mJOURNAL.md\u001b[39m;\u001b[57Gthe\u001b[61Grecalibration\u001b[75Gis\r\u001b[2C\u001b[1Byour call.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[38;5;153m\u001b[1mclyffy signal fold\u001b[39m core-dumps\u001b[22m (SIGABRT) — signa\u001b[54Gs are\u001b[60Gqueue\u001b[66G to\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m;\u001b[40Gthe\u001b[44Gcrash\u001b[50Gis\u001b[53Glogged\u001b[60Gas\u001b[63Ga\u001b[65Gdefect\u001b[72Gfor\u001b[76Gthe\r\u001b[2C\u001b[1Bfold's\u001b[10Gwork\u001b[15Glist.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNo\u001b[6G exercised: a live \u001b[38;5;153m/converse\u001b[39m turn (brain booted \u001b[38;5;153mready\u001b[39m;\u001b[61Gthe\u001b[65Gpath\u001b[70Gis\r\u001b[2C\u001b[1Buntouched\u001b[13Gby\u001b[16Gthis\u001b[21Gchange\u001b[28G—\u001b[30Gverify\u001b[37Gwhen\u001b[42Gconvenient).\r\u001b[2C\u001b[1B    \u001b[8G      \u001b[15G        \u001b[24G   \u001b[56G\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[31656.916194, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mTwo things need\u001b[19GYOUR\u001b[24Geyes:\u001b[22m\u001b[K\r\u001b[2C\u001b[1B1. \u001b[1mThe loopback gate criterion is broken as written\u001b[55G\u001b[22m Loopback\u001b[65GTCP measured\u001b[78G\u001b[1m257\r\u001b[2C\u001b[1BGbps\u001b[22m (it's memcpy, n\u001b[24Gt\u001b[26Ga wire); QUIC measured \u001b[1m5.0–5.5 Gbps\u001b[62G\u001b[22mat ~10× the\u001b[74GCPU\r\u001b[2C\u001b[1Bcost. No QUIC s\u001b[19Gack on \u001b[27Garth passes \"≥90% of loopback TCP\" —\u001b[64Gthe r\u001b[70Gal\u001b[K\r\u001b[2C\u001b[1Bship/no-ship gate is the\u001b[28G\u001b[1mLAN leg\u001b[22m, which \u001b[44Geeds the devs\u001b[58Gation online. Hone\u001b[77Gt\r\u001b[2C\u001b[1Bnumbers and\u001b[15Gthe\u001b[19Gproposed\u001b[28Gre-anchor\u001b[38Gare\u001b[42Gin\u001b[45G\u001b[38;5;153mJOURNAL.md\u001b[39m;\u001b[57Gthe\u001b[61Grecalibration\u001b[75Gis\r\u001b[2C\u001b[1Byour call.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[38;5;153m\u001b[1mclyffy signal fold\u001b[39m core-dumps\u001b[22m (SIGABRT) — signa\u001b[54Gs are\u001b[60Gqueue\u001b[66G to\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m;\u001b[40Gthe\u001b[44Gcrash\u001b[50Gis\u001b[53Glogged\u001b[60Gas\u001b[63Ga\u001b[65Gdefect\u001b[72Gfor\u001b[76Gthe\r\u001b[2C\u001b[1Bfold's\u001b[10Gwork\u001b[15Glist.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNo\u001b[6G exercised: a live \u001b[38;5;153m/converse\u001b[39m turn (brain booted \u001b[38;5;153mready\u001b[39m;\u001b[61Gthe\u001b[65Gpath\u001b[70Gis\r\u001b[2C\u001b[1Buntouched\u001b[13Gby\u001b[16Gthis\u001b[21Gchange\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[31657.059646, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mBench harness\u001b[19G\u001b[22mran\u001b[23Gon\u001b[26Gloopback,\u001b[36Gboth\u001b[41Gmodes.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mTwo things need\u001b[19GYOUR\u001b[24Geyes:\u001b[22m\u001b[K\r\u001b[2C\u001b[1B1. \u001b[1mThe loopback gate criterion is broken as written\u001b[55G\u001b[22m Loopback\u001b[65GTCP measured\u001b[78G\u001b[1m257\r\u001b[2C\u001b[1BGbps\u001b[22m (it's memcpy, n\u001b[24Gt\u001b[26Ga wire); QUIC measured \u001b[1m5.0–5.5 Gbps\u001b[62G\u001b[22mat ~10× the\u001b[74GCPU\r\u001b[2C\u001b[1Bcost. No QUIC s\u001b[19Gack on \u001b[27Garth passes \"≥90% of loopback TCP\" —\u001b[64Gthe r\u001b[70Gal\u001b[K\r\u001b[2C\u001b[1Bship/no-ship gate is the\u001b[28G\u001b[1mLAN leg\u001b[22m, which \u001b[44Geeds the devs\u001b[58Gation online. Hone\u001b[77Gt\r\u001b[2C\u001b[1Bnumbers and\u001b[15Gthe\u001b[19Gproposed\u001b[28Gre-anchor\u001b[38Gare\u001b[42Gin\u001b[45G\u001b[38;5;153mJOURNAL.md\u001b[39m;\u001b[57Gthe\u001b[61Grecalibration\u001b[75Gis\r\u001b[2C\u001b[1Byour call.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[38;5;153m\u001b[1mclyffy signal fold\u001b[39m core-dumps\u001b[22m (SIGABRT) — signa\u001b[54Gs are\u001b[60Gqueue\u001b[66G to\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m;\u001b[40Gthe\u001b[44Gcrash\u001b[50Gis\u001b[53Glogged\u001b[60Gas\u001b[63Ga\u001b[65Gdefect\u001b[72Gfor\u001b[76Gthe\r\u001b[2C\u001b[1Bfold's\u001b[10Gwork\u001b[15Glist.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNo\u001b[6G exercised: a live \u001b[38;5;153m/c\u001b[56Gady\u001b[39m;\u001b[61Gthe\u001b[65Gpath\u001b[70Gis\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
