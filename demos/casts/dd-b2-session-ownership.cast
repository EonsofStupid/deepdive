[349.319806, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[1ma first-class entity from day one\u001b[22m,\u001b[38Geven\u001b[43Gthough\u001b[50Gv1\u001b[53Gpolicy\u001b[60Genforces\u001b[69Gexactly\u001b[77Gone\r\u001b[1B \u001b[3Glive\u001b[8Gattach.\u001b[16GConcretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B- \u001b[38;5;153msession\u001b[39m ←→\u001b[16G\u001b[38;5;153mattachment\u001b[39m ←→\u001b[30G\u001b[38;5;153mdevice\u001b[37G\u001b[39min\u001b[40Gthe\u001b[44Gconnectome\u001b[55Gschema.\u001b[63GV1\u001b[66Gships\u001b[72Gwith\u001b[77Ga\r\u001b[2C\u001b[1Bpolicy\u001b[10Gknob\u001b[15G(\u001b[38;5;153mmax_live_attachments = 1\u001b[39m),\u001b[43Gnot\u001b[47Ga\u001b[49Ghardcoded\u001b[59Gassumption.\u001b[71GEstate\r\u001b[2C\u001b[1Bmoves and\u001b[13Gphone dispatch then become\u001b[40G\u001b[3mpolicy and ceremony changes, not schema \r\u001b[2C\u001b[1Bmigrations\u001b[23m — which is exactly the trap we're avoi\u001b[53Ging by deciding thi\u001b[73G now.\r\u001b[2C\u001b[1B- \u001b[1mAttachment gets a \u001b[38;5;153mrole\u001b[39m field\u001b[22m now: \u001b[38;5;153mprimary\u001b[39m (full data plane — the\u001b[K\r\u001b[2C\u001b[1Bdevstation),\u001b[16G\u001b[38;5;153mdispatcher\u001b[39m (\u001b[29Gontrol-plane\u001b[42Gonly — what the phone is),\u001b[69G\u001b[38;5;153mspectator\r\u001b[2C\u001b[1B\u001b[39m(read-only, reserved). A phone\u001b[34Gdispatch never needs \u001b[56Ghe QUIC\u001b[64Gfast path;\u001b[75Git\r\u001b[2C\u001b[1Bn\u001b[5Geds \u001b[10Ghe HTTP/3 control plane to preflight\u001b[47Gand fire. So \"d\u001b[63Gploy via phone\"\r\u001b[2C\u001b[1Bcosts almost nothing extra \u001b[32G the transport sid\u001b[51G — branch 1's design already\r\u001b[2C\u001b[1Bsplit\u001b[9Gcontrol from data.\u001b[28G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEstate move = detach + attach\u001b[22m, not co\u001b[43Gy. Because\u001b[54Gthe session i\u001b[68G\u001b[K\r\u001b[2C\u001b[1Breconstructable from connectome\u001b[35Galone\u001b[41G(the\u001b[46Greconstruction\u001b[61Grule),\u001b[68Gmoving\u001b[75Gfrom\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
