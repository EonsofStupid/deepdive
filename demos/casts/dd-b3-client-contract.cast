[31483.950656, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gship/no-ship\u001b[16Ggate\u001b[21Gis\u001b[24Gthe\u001b[28G\u001b[1mLAN leg\u001b[22m,\u001b[37Gwhich\u001b[43Gneeds\u001b[49Gthe\u001b[53Gdevstation\u001b[64Gonline.\u001b[72GHonest\r\u001b[2C\u001b[1Bnumbers and the proposed re-anchor are in \u001b[38;5;153mJOURNAL.md\u001b[39m; the r\u001b[63Gcalibration\u001b[75Gis\r\u001b[2C\u001b[1Byour call.\u001b[K\r\u001b[2C\u001b[1B2. \u001b[38;5;153m\u001b[1mclyffy signal fold\u001b[39m core-dumps\u001b[36G\u001b[22m(SIGABRT)\u001b[46G—\u001b[48Gsignals\u001b[56Gare\u001b[60Gqueued\u001b[67Gto\r\u001b[2C\u001b[1B\u001b[38;5;153m~/clyffy/landing/fold-signals.queue\u001b[39m;\u001b[40Gthe\u001b[44Gcrash\u001b[50Gis\u001b[53Glogged\u001b[60Gas\u001b[63Ga\u001b[65Gdefect\u001b[72Gfor\u001b[76Gthe\r\u001b[2C\u001b[1Bf\u001b[5Gld's work list.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BNot\u001b[7Gexercised:\u001b[18Ga\u001b[20Glive\u001b[25G\u001b[38;5;153m/converse\u001b[35G\u001b[39mturn\u001b[40G(brain\u001b[47Gbooted\u001b[54G\u001b[38;5;153mready\u001b[39m;\u001b[61Gthe\u001b[65Gpath\u001b[70Gis\r\u001b[2C\u001b[1Buntouched by th\u001b[19Gs change\u001b[28G— verify wh\u001b[40Gn convenient).\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BWhen you've\u001b[15Gverified\u001b[24Gand\u001b[28Gare\u001b[32Gsatisfied,\u001b[43G\u001b[1mexit this session\u001b[61G\u001b[22m—\u001b[63Gthat\u001b[68Gtriggers\r\u001b[2C\u001b[1Bbranch\u001b[10G4\u001b[12G(deployment-shape),\u001b[32Gthe\u001b[36Glast\u001b[41Gone\u001b[45Gbefore\u001b[52Gthe\u001b[56Gterminal\u001b[65Gfold\u001b[70Gback\u001b[75Gin\u001b[78Gthe\r\u001b[1B \u001b[3Gsource.\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;246m✻\u001b[3GCrunched for 19m 32s\r\u001b[4B\u001b[39m❯ \u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
