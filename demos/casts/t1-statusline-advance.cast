[301318.215341, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[5G\u001b[K\r\u001b[2C\u001b[1B{\u001b[7G\u001b[K\r\u001b[4C\u001b[1B\u001b[36m\"statusLine\"\u001b[39m: {\u001b[K\r\u001b[2C\u001b[1B    \u001b[36m\"type\"\u001b[39m: \u001b[31m\"comma\u001b[22Gd\"\u001b[39m,\u001b[K\r\u001b[2C\u001b[1B    \u001b[36m\"command\"\u001b[39m: \u001b[31m\"bash -c 'in=$(cat); printf \\\"%s  %s\\\" \\\"$(printf %s \\\"$in\\\" | \r\u001b[2C\u001b[1B~/.claude/statusline-infisical.sh)\\\" \\\"$(printf %s \\\"$in\\\" | \r\u001b[2C\u001b[1B/home/hades/clyffy/landing/study/t1/b/statusline-pxpipe.sh)\\\"'\"\r\u001b[4C\u001b[1B\u001b[39m}\r\u001b[2C\u001b[1B}\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B(The\u001b[8Gpxpipe\u001b[15Gscript\u001b[22Gprints\u001b[29Gonly\u001b[34Gits\u001b[38Gown\u001b[42Gsegment\u001b[50G—\u001b[52Gdir/model\u001b[62Gstay\u001b[67Gowned\u001b[73Gby\u001b[76Gthe\r\u001b[2C\u001b[1Bexisting script — which is why the composition is a clean two-command join.)\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BOne\u001b[7Gresidue\u001b[15Gfrom\u001b[20Gtesting:\u001b[29Gthe\u001b[33Gshared\u001b[40Gcache\u001b[46Gcurrently\u001b[56Gholds\u001b[62Gan\u001b[65G\"up\"\u001b[70Gentry\u001b[76G≤5s\r\u001b[1B \u001b[3Gold; it self-expires, nothing to clean.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;246m✻\u001b[3GBrewed for\u001b[14G2m 25s\r\u001b[3B\u001b[39m❯ \u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
