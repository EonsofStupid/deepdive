[267124.399568, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[7C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m44\u001b[12G\u001b[38;5;231m    engine: \u001b[38;5;148mString\u001b[38;5;231m,   \r\u001b[7C\u001b[1B\u001b[38;5;77m45\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// Attribution scope; defaults to `clyffy` (mirrors the `\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mclyffy signal fold` CLI).\u001b[38;5;231m                                     \r\u001b[6C\u001b[1B\u001b[38;5;77m646\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m#[s\u001b[20Grde(default)]\u001b[38;5;231m               \r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[16G\u001b[38;5;231mscop\u001b[23G\u001b[38;5;148mOpt\u001b[27Gon\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[24G\u001b[38;5;242mparen\u001b[30G branch id\u001b[41G(omit on the root/source conversa\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mtion).\u001b[38;5;231m        \u001b[27G       \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[16G\u001b[38;5;242m#[serde(def\u001b[28Gult)]\u001b[38;5;231m                                         \r\u001b[6C\u001b[1B\u001b[38;5;77m650\u001b[12G\u001b[38;5;231m    parent_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[7C\u001b[1B\u001b[38;5;77m51\u001b[16G\u001b[38;5;242m/// The harness session id backing the branch.\r\u001b[7C\u001b[1B\u001b[38;5;77m52\u001b[16G\u001b[38;5;242m#[serde(default)]\u001b[38;5;231m                                         \r\u001b[6C\u001b[1B\u001b[38;5;77m653\u001b[12G\u001b[38;5;231m    session_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[7C\u001b[1B\u001b[38;5;77m54\u001b[16G\u001b[38;5;242m/// Th\u001b[23G \u001b[26Gcision established/superseded — requires `lane`.\r\u001b[7C\u001b[1B\u001b[38;5;77m55\u001b[16G\u001b[38;5;242m#[serde(default)]\u001b[38;5;231m     \r\u001b[7C\u001b[1B\u001b[38;5;77m56\