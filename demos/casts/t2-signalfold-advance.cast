[267124.026819, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[6C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m   \u001b[12G\u001b[38;5;242m(`FoldPhase`/`Fo\u001b[29GdEngine`/`DecisionLane`)\u001b[38;5;231m                     \r\u001b[6C\u001b[1B\u001b[38;5;77m636\u001b[12G\u001b[38;5;242m/// before anythi\u001b[31G touches the warehouse — there is no string\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mly path in.\u001b[38;5;231m                                                   \r\u001b[6C\u001b[1B\u001b[38;5;77m637\u001b[12G\u001b[38;5;242m#[derive(D\u001b[23Gseria\u001b[29Gize)]\u001b[38;5;231m                   \r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[12G\u001b[38;5;81mstruct\u001b[38;5;231m \u001b[38;5;148mFoldReq\u001b[38;5;231m {                                              \r\u001b[6C\u001b[1B\u001b[38;5;77m639\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m///\u001b[20GLifecycle transition — a [`FoldPhase`] tag (e.g. `bran\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mch_open\u001b[20Gd`, `decision_established`).\r\u001b[7C\u001b[1B\u001b[38;5;77m40\u001b[12G\u001b[38;5;231m    phase: \u001b[38;5;148mString\u001b[38;5;231m,\r\u001b[7C\u001b[1B\u001b[38;5;77m41\u001b[20G\u001b[38;5;242mThe fold tree'\u001b[35G node\u001b[41Gid this event belongs\u001b[63Gto\u001b[66G\u001b[38;5;231m        \r\u001b[6C\u001b[1B\u001b[38;5;77m642\u001b[12G\u001b[38;5;231m    branch_id: \u001b[38;5;148mString\u001b[38;5;231m,              \r\u001b[8C\u001b[1B\u001b[38;5;77m3\u001b[16G\u001b[38;5;242m/// Which harness ran the branch — a [`FoldEngine`] tag (e\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242m.g. `claud\u001b[23G`, `codex`).\u001b[38;5;231m                               \r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;231mengine: \u001b[38;5;148mString\u001b[38;5;231m,   \r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[20G\u001b[38;5;242mAttribution \u001b[33Gcope; d\u001b[41Gfaults to\u001b[51G`clyffy` (m\u001b[63Grror