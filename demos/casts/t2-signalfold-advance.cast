[267124.404654, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[8C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m7\u001b[16G\u001b[38;5;231mscope: \u001b[38;5;148mOp\u001b[26Gio\u001b[29G\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[20G\u001b[38;5;242mThe parent branch i\u001b[40G (omi\u001b[46G on the root/source conversa\r\u001b[11C\u001b[1Btion).\u001b[38;5;231m                   \r\u001b[8C\u001b[1B\u001b[38;5;77m9\r\u001b[7C\u001b[1B50\u001b[16G\u001b[38;5;231mparent_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[7C\u001b[1B\u001b[38;5;77m51\u001b[24G\u001b[38;5;242mh\u001b[27Gness session id backi\u001b[49Gg the branch.\u001b[38;5;231m            \r\u001b[6C\u001b[1B\u001b[38;5;77m652\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m#[serde(default)]\r\u001b[7C\u001b[1B\u001b[38;5;77m53\u001b[16G\u001b[38;5;231msession_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;242m/// The decision established/superseded — requires `lane`.\r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[16G\u001b[38;5;242m#[serd\u001b[23G(default)]\u001b[38;5;231m                             \r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[16G\u001b[38;5;231mdecision_id: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mString\u001b[38;5;231m>,\r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[16G\u001b[38;5;242m/// The decision's combine lane — a [`DecisionLane`] tag; \r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mrequires `decis\u001b[28Gon_id`.\u001b[38;5;231m                                       \r\u001b[8C\u001b[1B\u001b[38;5;77m8\r\u001b[8C\u001b[1B9\u001b[16G\u001b[38;5;231mlane: \u001b[38;5;148mOption\u001b[38;5;231m<\u001b[38;5;148mStr\u001b[33Gng\u001b[38;5;231m>,       \r\u001b[7C\u001b[1B\u001b[38;5;77m60\u001b[24G\u001b[38;5;242mpri\u001b[55Gcision overturns.\u001b[38;5;231m  \u001b[49m\u001b[39m\