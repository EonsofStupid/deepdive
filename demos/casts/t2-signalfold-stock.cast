[268509.593597, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B     \u001b[38;5;231m\u001b[2m 779 \u001b[22m \u001b[38;5;197mmod\u001b[38;5;231m tests {\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m80\u001b[12G\u001b[22m    \u001b[38;5;197muse\u001b[38;5;231m super::*;\r\u001b[5C\u001b[1B\u001b[38;5;167m\u001b[48;5;52m 781 -\u001b[38;5;231m    use clyffy_storage::{AnalyticsStore, Value};              \r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 781 +\u001b[38;5;231m    \u001b[38;5;197muse\u001b[38;5;231m clyffy_storage::{AnalyticsStore, Value\u001b[48;5;28m \u001b[38;5;197mas\u001b[38;5;231m Col\u001b[48;5;22m};\u001b[48;5;28m \u001b[38;5;242m// ali\r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;242m\u001b[48;5;28mased: `Value` here is serde_json's\u001b[38;5;231m\u001b[48;5;22m                            \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 782 \u001b[22m \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 783 \u001b[22m     \u001b[38;5;242m/// An `AppState` over a real in-memory DuckDB warehouse (\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m   \u001b[12G\u001b[22m\u001b[38;5;242mschema created on open) — the same\r\u001b[8C\u001b[1B\u001b[38;5;231m\u001b[2m4\u001b[20G\u001b[22m\u001b[38;5;242mtranslate→insert path production uses, no br\u001b[65Gin loaded\r\u001b[11C\u001b[1B (the fold s\u001b[25Gam is brain-ind\u001b[41Gpend\u001b[46Gnt).\r\u001b[5C\u001b[1B\u001b[39m\u001b[K\r\u001b[1B\u001b[38;5;246m●\u001b[3G\u001b[39m\u001b[1mUpdate\u001b[22m(\u001b]8;id=1m2odyr;file:///home/hades/clyffy/landing/study/t2/a/interfaces/clyffy-brain/src/main.rs\u0007interfaces/clyffy-brain/src/main.rs\u001b]8;;\u0007)\u001b[K\u001b[23;1H\u001b[20;3H\u001b[?25h\u001b[?2026l"]
