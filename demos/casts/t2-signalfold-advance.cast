[267127.150582, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[7C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m73\u001b[16G\u001b[38;5;231m \u001b[24G\u001b[38;5;148mJson\u001b[38;5;231m(json!({\r\u001b[7C\u001b[1B\u001b[38;5;77m74\u001b[28G\u001b[38;5;186m\"status\"\u001b[38;5;231m:\u001b[38G\u001b[38;5;186m\"ok\"\u001b[38;5;231m,\r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[16G\u001b[38;5;231m     \u001b[22G      \u001b[38;5;186m\"phase\"\u001b[38;5;231m: phase.\u001b[38;5;148mtag\u001b[38;5;231m(),  \u001b[52G \r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[20G\u001b[38;5;231m      \u001b[27G \u001b[38;5;186m\"branch_id\"\u001b[38;5;231m:\u001b[41Greq.branch_id,\r\u001b[8C\u001b[1B\u001b[38;5;77m7\u001b[24G\u001b[38;5;231m    \u001b[38;5;186m\"engine\"\u001b[38;5;231m: engine.\u001b[38;5;148mtag\u001b[38;5;231m(),\r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[24G\u001b[38;5;231m})),        \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[20G\u001b[38;5;231m)\u001b[28G         \u001b[38G     \r\u001b[7C\u001b[1B\u001b[38;5;77m80\u001b[24G\u001b[38;5;231m.\u001b[38;5;148minto_response\u001b[38;5;231m(),        \r\u001b[7C\u001b[1B\u001b[38;5;77m81\u001b[20G\u001b[38;5;148mErr\u001b[38;5;231m(e)\u001b[27G=> {         \u001b[41G              \r\u001b[7C\u001b[1B\u001b[38;5;77m82\u001b[24G\u001b[38;5;231m(StatusCode:\u001b[37GINTERNAL_SERVER_ERROR,\u001b[60G\u001b[38;5;148mformat!\u001b[38;5;231m(\u001b[38;5;186m\"fold \r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;186msignal not recorded: {e}\"\u001b[38;5;231m)).\u001b[38;5;148minto_response\u001b[38;5;231m()\r\u001b[7C\u001b[1B\u001b[38;5;77m83\u001b[20G\u001b[38;5;231m}\r\u001b[8C\u001b[1B\u001b[38;5;77m4\u001b[16G\u001b[38;5;231m}\u001b[24G                 \r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[12G\u001b[38;5;231m}\u001b[20G      \u001b[27G  \u001b[30G \r\u001b[8C\u001b[1B\u001b[38;5;77m6\u001b[24G\u001b[38;5;231m                                   \u001b[60G              \r\u001b[5C\u001b[1B\u001b[49m\u001b[2m 787 \u001b[