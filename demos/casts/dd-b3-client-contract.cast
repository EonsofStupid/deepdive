[30573.154376, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[6G\u001b[38;5;231m\u001b[2m  1 \u001b[22m\u001b[38;5;242m#!/usr/bin/env bash\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m2\u001b[10G\u001b[22m\u001b[38;5;242m# gen-protocol.sh — regenerate clyffy-protocol's VENDORED FlatBu\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m3\u001b[10G\u001b[22m\u001b[38;5;242m# flatc is a DEV-TIME tool (v25.2.10, matching the flatbuffers c\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m    \u001b[22m\u001b[38;5;242mrate pin), never a build dep.\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m  4 \u001b[22m\u001b[38;5;242m# Deterministic: re-running on an unchanged schema must produce \r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;5;231m\u001b[2m  5 \u001b[22m\u001b[38;5;148mset\u001b[38;5;231m -euo pipefail\u001b[39m\u001b[K\r\u001b[1B     \u001b[38;5;231m\u001b[2m  6 \u001b[11G\u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m  7 \u001b[22mREPO=\u001b[38;5;186m\"\u001b[38;5;231m$(cd \u001b[38;5;186m\"\u001b[38;5;231m$(dirname \u001b[38;5;186m\"\u001b[38;5;231m$0\u001b[38;5;186m\"\u001b[38;5;231m)\u001b[38;5;186m/..\"\u001b[38;5;231m && pwd)\u001b[38;5;186m\"\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;5;231m\u001b[2m  9 \u001b[22mRUST_OUT=\u001b[38;5;186m\"\u001b[38;5;231m$REPO\u001b[38;5;186m/clyffy-protocol/src/gen\"\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 10 \u001b[22mTS_OUT=\u001b[38;5;186m\"\u001b[38;5;231m$REPO\u001b[38;5;186m/clyffy-protocol/gen/ts\"\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;5;246m… +20 lines \u001b[39m\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
