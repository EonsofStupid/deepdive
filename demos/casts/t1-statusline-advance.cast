[301687.705285, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[3G\u001b[39mBoth\u001b[8Gstates\u001b[15Gverified.\u001b[25GDone\u001b[30G—\u001b[32G\u001b[38;5;153mstatusline-pxpipe.sh\u001b[53G\u001b[39mis\u001b[56Gin\u001b[59Gplace\u001b[65Gnext\u001b[70Gto\u001b[73Gthe\r\u001b[2C\u001b[1Breference script.\u001b[K\r\u001b[2B \u001b[3G\u001b[1mWhat it does\u001b[22m\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mStatus:\u001b[13G\u001b[22mreal HTTP\u001b[23Gcheck\u001b[29G—\u001b[31G\u001b[38;5;153mcurl -fsS --max-time 1\u001b[54G\u001b[39mGET\u001b[58Gon\r\u001b[2C\u001b[1B\u001b[38;5;153mhttp://127.0.0.1:47821/\u001b[27G\u001b[39m(the\u001b[32Gdashboard\u001b[42Gis\u001b[45Gpxpipe's\u001b[54Gonly\u001b[59G2xx\u001b[63Groute;\u001b[70G\u001b[38;5;153m/health\u001b[39m,\r\u001b[2C\u001b[1B\u001b[38;5;153m/api/status\u001b[39m etc.\u001b[20Gall 404).\u001b[30GGreen\u001b[36G\u001b[38;5;153m●\u001b[38G\u001b[39mon\u001b[41G2xx,\u001b[46Gred\u001b[50G\u001b[38;5;153m●\u001b[52G\u001b[39motherwise.\u001b[63G\u001b[38;5;153mPXPIPE_STATUS_URL\r\u001b[2C\u001b[1B\u001b[39moverrides, m\u001b[16Gtching\u001b[23Gt\u001b[26G \u001b[38;5;153mINFISICAL_STATUS_URL\u001b[39m pattern.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mTokens saved today:\u001b[22m there's no st\u001b[39Gts\u001b[42GAPI and no precomputed fi\u001b[68Gld in the\u001b[K\r\u001b[2C\u001b[1Bevents, so it sums today's\u001b[30G(UTC)\u001b[36Glines from \u001b[38;5;153m~/.pxpipe/events.jsonl\u001b[39m:\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mbaseline_tokens − (input_tokens + cache_create_tokens + cache_read_tokens)\u001b[39m,\r\u001b[2C\u001b[1Bonly for lines with \u001b[38;5;153mbaseline_probe_status == \"ok\"\u001b[39m, clamped at\u001b[65G0, rendered as\r\u001b[2C\u001b[1B\u001b[38;5;153mk\u001b[39m/\u001b[38;5;153mM\u001b[39m. Omitted entirely if the file \u001b[38Gs missing/unreadable or the sum is 0.\u001b[76GNote\r\u001b[2C\u001b[1Bit's an approximation — it coun