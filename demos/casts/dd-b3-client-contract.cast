[31044.462924, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[6G\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m4\u001b[13G\u001b[22m\u001b[38;5;242m `quic` (quinn). Per stream/connection: first byte = mode (0 \r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m5\u001b[10G\u001b[22m\u001b[38;5;242m//! length-prefixed\u001b[30GIngestFrame buffers. Stream mode: count fram\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m6\u001b[14G\u001b[22m\u001b[38;5;242mat end-of-stream. Ping-pong: reply a\u001b[51G 8-byte\u001b[59Gack after \u001b[70Gvery\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m7\u001b[13G\u001b[22m\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m8\u001b[14G\u001b[22m\u001b[38;5;242m  cargo run --release \u001b[38G clyffy-protocol --\u001b[58Gx\u001b[60Gmple b\u001b[67Gnch_ser\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m9\u001b[13G\u001b[22m\u001b[38;5;242m   cargo run --release -p clyffy-protocol --example bench_ser\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m10\u001b[72G\u001b[22m\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;246m… +182 lines \u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;246m \u001b[3G\u001b[39m\u001b[1mWrite\u001b[22m(\u001b]8;id=4s5f54;file:///home/hades/Projects/clyffy/clyffy-protocol/examples/bench_client.rs\u0007clyffy-protocol/examples/bench_client.rs\u001b]8;;\u0007)\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[31044.497272, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[6G\u001b[38;5;231m\u001b[2m 1 \u001b[22m\u001b[38;5;242m//! bench_client — the drive side of the fast-path transport gate\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m2 \u001b[22m\u001b[38;5;242m/\u001b[11G!\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m3 \u001b[22m\u001b[38;5;242m/\u001b[11G! Sw\u001b[16Geps lan\u001b[24G × mode × \u001b[36Gre\u001b[40Gs\u001b[42G× payload, ≥5 runs after a 3s wa\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m \u001b[22m\u001b[38;5;242mrmup, reports median (min/max)\u001b[39m\u001b[K\r\u001b[7C\u001b[1B\u001b[38;5;231m\u001b[2m \u001b[22m\u001b[38;5;242mmes are pre-built once\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m5 \u001b[22m\u001b[38;5;242m/\u001b[11G! (construction exc\u001b[31Guded\u001b[36Gby\u001b[39Gdesign — identical on ev\u001b[64Gry lane).\u001b[39m\u001b[K\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m7 \u001b[22m\u001b[38;5;242m/\u001b[11G! \u001b[15Gcargo run -\u001b[27Grelease -p clyf\u001b[43Gy-protocol -\u001b[56Gexample bench_clie\r\u001b[6C\u001b[1B\u001b[38;5;231m\u001b[2m  \u001b[22m\u001b[38;5;242mnt --\u001b[15G\\\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 8 \u001b[22m\u001b[38;5;242m//!     <tcp|tls|quic> <host:port> [--streams 16] [--payload 6553\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 9 \u001b[22m\u001b[38;5;242m//!     [--mode stream|pingpong] [--runs 5] [--cc cubic|bbr]\r\u001b[1B\u001b[39m \u001b[3G   \u001b[38;5;246m… +298 lines \u001b[39m\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
