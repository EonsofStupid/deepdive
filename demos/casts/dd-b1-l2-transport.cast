[586.836556, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1m3\u001b[5G ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA virtual ethernet network, self-hosted controller run\u001b[58Ging on c\u001b[67Gyffy (that's\r\u001b[2C\u001b[1Byour \"neutral space\" hosting the\u001b[36Gnetwork itself), cli\u001b[57Gnts on\u001b[64Gall thr\u001b[72Ge OSes,\r\u001b[2C\u001b[1Ba\u001b[5Gtomatic direc\u001b[19G-path when local and rel\u001b[44Gy when remote — the local/networked\r\u001b[2C\u001b[1Bduality is built in. The cost: it's a heavier\u001b[49Gmoving\u001b[56Gpart,\u001b[62Gand\u001b[66Gtrue\u001b[71GL2\u001b[74Ginto\r\u001b[2C\u001b[1Bthe\u001b[7Gcluster\u001b[15Graises\u001b[22Gthe\u001b[26Gquestion\u001b[35Gbelow.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m4. Blockchain — honest answer: not for the channel, yes for one shaped idea.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA blockchain buys \u001b[3mmulti-party consensus among mutually distrusting nodes\u001b[23m. You\r\u001b[2C\u001b[1Bhave \u001b[9Gwo parties you bot\u001b[56Gs\u001b[58Gpure overhead th\u001b[75Gre,\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[586.85252, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3\u001b[5G ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA virtual ethernet network, self-hosted controller run\u001b[58Ging on c\u001b[67Gyffy (that's\r\u001b[2C\u001b[1Byour \"neutral space\" hosting the\u001b[36Gnetwork itself), cli\u001b[57Gnts on\u001b[64Gall thr\u001b[72Ge OSes,\r\u001b[2C\u001b[1Ba\u001b[5Gtomatic direc\u001b[19G-path when local and rel\u001b[44Gy when remote — the local/networked\r\u001b[2C\u001b[1Bduality is built in. The cost: it's a heavier\u001b[49Gmoving\u001b[56Gpart,\u001b[62Gand\u001b[66Gtrue\u001b[71GL2\u001b[74Ginto\r\u001b[2C\u001b[1Bthe\u001b[7Gcluster\u001b[15Graises\u001b[22Gthe\u001b[26Gquestion\u001b[35Gbelow.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m4. Blockchain — honest answer: not for the channel, yes for one shaped idea.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA blockchain buys \u001b[3mmulti-\u001b[56Gy distrusting nodes\u001b[23m. You\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[586.874609, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bself-hosted\u001b[15Gembedding\u001b[25Gis\u001b[28Gthe\u001b[32Gopen\u001b[37Gquestion\u001b[46G—\u001b[48Gthat's\u001b[55Gwhat\u001b[60Gspur\u001b[65G1\u001b[67Gis\u001b[70Gverifying.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3\u001b[5G ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA virtual ethernet network, self-hosted controller run\u001b[58Ging on c\u001b[67Gyffy (that's\r\u001b[2C\u001b[1Byour \"neutral space\" hosting the\u001b[36Gnetwork itself), cli\u001b[57Gnts on\u001b[64Gall thr\u001b[72Ge OSes,\r\u001b[2C\u001b[1Ba\u001b[5Gtomatic direc\u001b[19G-path when local and rel\u001b[44Gy when remote — the local/networked\r\u001b[2C\u001b[1Bduality is built in. The cost: it's a heavier\u001b[49Gmoving\u001b[56Gpart,\u001b[62Gand\u001b[66Gtrue\u001b[71GL2\u001b[74Ginto\r\u001b[2C\u001b[1Bthe\u001b[7Gcluster\u001b[15Graises\u001b[22Gthe\u001b[26Gquestion\u001b[35Gbelow.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m4. Blockchain — honest a\u001b[56Ges for one shaped idea.\u001b[22m\u001b[K\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[586.875104, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Bclient link\u001b[15Gmigrates w\u001b[26Gthout\u001b[32Gtearing the session down. Maturity\u001b[67Gfor\u001b[K\r\u001b[2C\u001b[1Bself-hosted\u001b[15Gembedding\u001b[25Gis\u001b[28Gthe\u001b[32Gopen\u001b[37Gquestion\u001b[46G—\u001b[48Gthat's\u001b[55Gwhat\u001b[60Gspur\u001b[65G1\u001b[67Gis\u001b[70Gverifying.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3\u001b[5G ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA virtual ethernet network, self-hosted controller run\u001b[58Ging on c\u001b[67Gyffy (that's\r\u001b[2C\u001b[1Byour \"neutral space\" hosting the\u001b[36Gnetwork itself), cli\u001b[57Gnts on\u001b[64Gall thr\u001b[72Ge OSes,\r\u001b[2C\u001b[1Ba\u001b[5Gtomatic direc\u001b[19G-path when local and rel\u001b[44Gy when remote — the local/networked\r\u001b[2C\u001b[1Bduality is built in. The cost: it's a heavier\u001b[49Gmoving\u001b[56Gpart,\u001b[62Gand\u001b[66Gtrue\u001b[71GL2\u001b[74Ginto\r\u001b[2C\u001b[1Bthe\u001b[7Gcluster\u001b[15Graises\u001b[22Gthe\u001b[26Gquestion\u001b[35Gbelow.\r\u001b[2C\u001b[1B                        \u001b[56G\u001b[K\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[586.894708, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[3C\u001b[1Bonnectio\u001b[13G that did the \u001b[28Gandshake \u001b[3mis\u001b[44G\u001b[23mtunnel.\u001b[52GB\u001b[54Gnus\u001b[58Gthat matters\u001b[71Gto\u001b[74Gyou\r\u001b[3C\u001b[1Bpecifically: QUIC \u001b[1mconnection migration + multipath\u001b[55G\u001b[22mme\u001b[58Gns a weak/dropp\u001b[74Gng\u001b[K\r\u001b[2C\u001b[1Bclient\u001b[10Glink\u001b[15Gmigrates\u001b[24Gwithout\u001b[32Gtearing\u001b[40Gthe\u001b[44Gsession\u001b[52Gdown.\u001b[58GMaturity\u001b[67Gfor\r\u001b[2C\u001b[1Bself-hosted embedding is the open question — that's what spur 1 is verifying.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA virtual\u001b[13Geth\u001b[17Grnet net\u001b[26Gork, self-hosted controller running on clyffy (that's\r\u001b[2C\u001b[1Byour \"neutral space\"\u001b[24Ghosting the network itself), clients on all three\u001b[74GOSes,\r\u001b[2C\u001b[1Bautomatic di\u001b[16Gect-pa\u001b[24G when local and relay\u001b[46Gwhen\u001b[51Gremote\u001b[58G—\u001b[60Gthe\u001b[64Glocal/networked\r\u001b[2C\u001b[1Bduality\u001b[11Gis\u001b[14Gbuilt\u001b[20Gin.\u001b[24GThe\u001b[56Gpart,\u001b[62Gand\u001b[66Gtrue\u001b[71GL2\u001b[74Ginto\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[586.90636, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1Ban HTTP/3 connect\u001b[21Gon. Your vision\u001b[37G— \"connection start\u001b[58Gas HTTP and\u001b[K\r\u001b[2C\u001b[1Bimmediate\u001b[13Gy becomes the bridge\" — is not a metaphor\u001b[55Gh\u001b[57Gre;\u001b[61Gthe same QUIC\u001b[K\r\u001b[3C\u001b[1Bonnectio\u001b[13G that did the \u001b[28Gandshake \u001b[3mis\u001b[44G\u001b[23mtunnel.\u001b[52GB\u001b[54Gnus\u001b[58Gthat matters\u001b[71Gto\u001b[74Gyou\r\u001b[3C\u001b[1Bpecifically: QUIC \u001b[1mconnection migration + multipath\u001b[55G\u001b[22mme\u001b[58Gns a weak/dropp\u001b[74Gng\u001b[K\r\u001b[2C\u001b[1Bclient\u001b[10Glink\u001b[15Gmigrates\u001b[24Gwithout\u001b[32Gtearing\u001b[40Gthe\u001b[44Gsession\u001b[52Gdown.\u001b[58GMaturity\u001b[67Gfor\r\u001b[2C\u001b[1Bself-hosted embedding is the open question — that's what spur 1 is verifying.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BA virtual\u001b[13Geth\u001b[17Grnet net\u001b[26Gork, self-hosted controller running on clyffy (that's\r\u001b[2C\u001b[1Byour \"neutral space\"\u001b[24Ghos\u001b[56Gents on all three\u001b[74GOSes,\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[586.930336, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1moption.\u001b[22m\u001b[K\r\u001b[2C\u001b[1BThis \u001b[9Gs the\u001b[15Gg\u001b[17Gnuinely cutt\u001b[30Gn\u001b[32G-edge one: the IETF standardized\u001b[65Gtunneling\u001b[75G\u001b[3minside\r\u001b[2C\u001b[1B\u001b[23man HTTP/3 connect\u001b[21Gon. Your vision\u001b[37G— \"connection start\u001b[58Gas HTTP and\u001b[K\r\u001b[2C\u001b[1Bimmediate\u001b[13Gy becomes the bridge\" — is not a metaphor\u001b[55Gh\u001b[57Gre;\u001b[61Gthe same QUIC\u001b[K\r\u001b[3C\u001b[1Bonnectio\u001b[13G that did the \u001b[28Gandshake \u001b[3mis\u001b[44G\u001b[23mtunnel.\u001b[52GB\u001b[54Gnus\u001b[58Gthat matters\u001b[71Gto\u001b[74Gyou\r\u001b[3C\u001b[1Bpecifically: QUIC \u001b[1mconnection migration + multipath\u001b[55G\u001b[22mme\u001b[58Gns a weak/dropp\u001b[74Gng\u001b[K\r\u001b[2C\u001b[1Bclient\u001b[10Glink\u001b[15Gmigrates\u001b[24Gwithout\u001b[32Gtearing\u001b[40Gthe\u001b[44Gsession\u001b[52Gdown.\u001b[58GMaturity\u001b[67Gfor\r\u001b[2C\u001b[1Bself-hosted embedding is the open question — that's what spur 1 is verifying.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3. ZeroTier-style true-L2 overlay — the only candidate that is literally layer\r\u001b[2C\u001b[1B2.\u001b[22m  \u001b[8G        \u001b[17G      \u001b[24G   \u001b[56G\u001b[K\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
[587.019036, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[1m2. MASQUE / CONNECT-IP over HTTP/3 — the literal \"HTTP becomes the tunnel\" \r\u001b[2C\u001b[1Boption.\u001b[11G\u001b[22m\u001b[K\r\u001b[2C\u001b[1BThis is the genuinely\u001b[25Gcutting-edge one: the IETF standardized tu\u001b[68Gneling\u001b[75G\u001b[3minside\r\u001b[2C\u001b[1B\u001b[23man HTTP/3 connection. You\u001b[29G vision\u001b[37G— \"c\u001b[42Gnnection starts as\u001b[61GHTTP \u001b[67Gnd\u001b[70G\u001b[K\r\u001b[2C\u001b[1Bimmediately becomes\u001b[27Gbri\u001b[31Gge\" —\u001b[37Gis\u001b[40Gnot\u001b[44Ga metaphor here; \u001b[62Ghe same QUIC\u001b[K\r\u001b[2C\u001b[1Bconnection that did the handshake \u001b[3mis\u001b[23m the tunnel. Bonus that\u001b[63Gmatters to you\r\u001b[2C\u001b[1Bspecifically: QUIC \u001b[1mconnection migration + multipath\u001b[22m means a weak/d\u001b[70Gopping\r\u001b[2C\u001b[1Bclient link\u001b[15Gmigrates w\u001b[26Gthout\u001b[32Gtearing the session down. Maturity\u001b[67Gfor\u001b[K\r\u001b[2C\u001b[1Bself-hosted\u001b[15Gembedding\u001b[25Gis\u001b[28Gthe\u001b[32Gopen\u001b[37Gquestion\u001b[46G—\u001b[48Gthat's\u001b[55Gwhat\u001b[60Gspur\u001b[65G1\u001b[67Gis\u001b[70Gverifying.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1m3\u001b[5G ZeroTier-style true-L\u001b[56Ge that is literally layer\u001b[22m\u001b[23;1H\u001b[16;3H\u001b[?25h\u001b[?2026l"]
