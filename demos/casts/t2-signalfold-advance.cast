[267122.077767, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[1B     \u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;242mtrics` warehouse: opened up front and\u001b[38;5;231m                         \r\u001b[5C\u001b[1B\u001b[38;5;77m 176 +\u001b[38;5;231m    \u001b[38;5;242m// shared BOTH ways — into the brain actor (`Platform::boo\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;242mt_with_metrics`) and into the\u001b[38;5;231m                                 \r\u001b[5C\u001b[1B\u001b[38;5;77m 177 +\u001b[38;5;231m    \u001b[38;5;242m// `/signal/fold` sink. The organ-as-service seam: while c\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mlyffy-brain runs it holds the DuckDB\u001b[38;5;231m                          \r\u001b[6C\u001b[1B\u001b[38;5;77m178\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m//\u001b[19Gsingle-writer lock, so hooks/CLI land their fold signal\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242ms THROUGH the\u001b[26Gdaemon instead \u001b[42Gf failing\u001b[38;5;231m                       \r\u001b[6C\u001b[1B\u001b[38;5;77m179\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m// against a\u001b[29Glocked file. If the warehouse can't open, /si\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mgnal\u001b[17Gfold 503s honestly and\u001b[40Gt\u001b[44Gactor\u001b[38;5;231m                         \r\u001b[6C\u001b[1B\u001b[38;5;77m180\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m// f\u001b[21Glls back \u001b[31Go booting its own handle (surfacing the sam\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242me failure in /healthz).\u001b[38;5;231m                                       \r\u001b[6C\u001b[1B\u001b[38;5;77m181\u001b[12G\u001b[38;5;231m    \u001b[38;5;81mlet\u001b[38;5;231m metrics = \u001b[38;5;197mmatch\u001b[38;5;231m \u001b[38;5;148mopen_metrics\u001b[38;5;231m(&cfg)\u001b[55G{\r\u001b[7C\u001b[1B\u001b[38;5;77m82\u001b[16G\u001b[38;5;231m    \u001b[38;5;148mOk\u001b[38;5;231m(m) => \u