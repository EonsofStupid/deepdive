[267119.366728, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[11C\u001b[1B\u001b[38;5;242mhread-safe in-process model, or the ring\r\u001b[8C\u001b[1B\u001b[38;5;231m\u001b[2m1\u001b[16G\u001b[22m\u001b[38;5;242m// proxy) + one persistent session/history (the always-war\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m     \u001b[22m \u001b[38;5;242mm context).\r\u001b[8C\u001b[1B\u001b[38;5;231m\u001b[2m2\u001b[16G\u001b[22m\u001b[38;5;81mlet\u001b[20G\u001b[38;5;231mstate = Arc::\u001b[38;5;148mnew\u001b[38;5;231m(RwLock::\u001b[38;5;148mnew\u001b[38;5;231m(BrainState::Loading));\r\u001b[5C\u001b[1B\u001b[38;5;246m...\u001b[39m\u001b[K\r\u001b[8C\u001b[1B\u001b[38;5;231m\u001b[2m5\u001b[20G\u001b[22m\u001b[38;5;81mlet\u001b[24G\u001b[38;5;231mstate = state.\u001b[38;5;148mclone\u001b[38;5;231m();\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 196 \u001b[22m         std::thread::Builder::\u001b[38;5;148mnew\u001b[38;5;231m()\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;231m\u001b[2m 197 \u001b[22m             .\u001b[38;5;148mname\u001b[38;5;231m(\u001b[38;5;186m\"clyffy-brain-actor\"\u001b[38;5;231m.\u001b[38;5;148minto\u001b[38;5;231m())\u001b[39m\u001b[K\r\u001b[5C\u001b[1B\u001b[38;5;167m\u001b[48;5;52m 183 -\u001b[38;5;231m            .spawn(move || brain_actor(cfg, brain_rx, state, b\r\u001b[5C\u001b[1B\u001b[38;5;167m     -\u001b[38;5;231mackend))                                                      \r\u001b[5C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m 198 +\u001b[38;5;231m            .\u001b[38;5;148mspawn\u001b[38;5;231m(\u001b[38;5;197mmove\u001b[38;5;231m || \u001b[38;5;148mbrain_actor\u001b[38;5;231m(cfg, brain_rx, state, b\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;231mackend\u001b[48;5;28m, metrics\u001b[48;5;22m))                                             \r\u001b[6C\u001b[1B\u001b[49m\u001b[2m199\u001b[12G\u001b[22m            .\u001b[38;5;148mexpect\u001b[38;5;231m(\u001b[38;5;186m\"spawn brain actor\"\u001b[38;5;231m);\r\u0