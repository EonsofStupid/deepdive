[351.712982, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[3mmigrations\u001b[23m — which is exactly the trap we're avoi\u001b[53Ging by deciding thi\u001b[73G now.\r\u001b[2C\u001b[1B- \u001b[1mAttachment gets a \u001b[38;5;153mrole\u001b[39m field\u001b[22m now: \u001b[38;5;153mprimary\u001b[39m (full data plane — the\u001b[K\r\u001b[2C\u001b[1Bdevstation),\u001b[16G\u001b[38;5;153mdispatcher\u001b[39m (\u001b[29Gontrol-plane\u001b[42Gonly — what the phone is),\u001b[69G\u001b[38;5;153mspectator\r\u001b[2C\u001b[1B\u001b[39m(read-only, reserved). A phone\u001b[34Gdispatch never needs \u001b[56Ghe QUIC\u001b[64Gfast path;\u001b[75Git\r\u001b[2C\u001b[1Bn\u001b[5Geds \u001b[10Ghe HTTP/3 control plane to preflight\u001b[47Gand fire. So \"d\u001b[63Gploy via phone\"\r\u001b[2C\u001b[1Bcosts almost nothing extra \u001b[32G the transport sid\u001b[51G — branch 1's design already\r\u001b[2C\u001b[1Bsplit\u001b[9Gcontrol from data.\u001b[28G\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEstate move = detach + attach\u001b[22m, not co\u001b[43Gy. Because\u001b[54Gthe session i\u001b[68G\u001b[K\r\u001b[2C\u001b[1Breconstructable from connectome\u001b[35Galone\u001b[41G(the\u001b[46Greconstruction\u001b[61Grule),\u001b[68Gmoving\u001b[75Gfrom\r\u001b[2C\u001b[1Bdevstation to the Windows box is: \u001b[38Gld attachment \u001b[53Gnds,\u001b[58Gn\u001b[60Gw device\u001b[69Gattaches,\r\u001b[2C\u001b[1Boutbox \u001b[11Gepl\u001b[15Gys from \u001b[3mthat device's\u001b[23m last-se\u001b[45Gn cursor. Per-attachment cursors,\u001b[K\r\u001b[2C\u001b[1Bnot per-session —\u001b[21Gthat's the one schem\u001b[42G detail \u001b[51Gh\u001b[53G e\u001b[56Gtat\u001b[60G move forces.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mQR ceremony\u001b[22m:\u001b[18Gthe QR encodes a short-liv\u001b[45Gd\u001b[47Gbootstrap token + clyffy's\u001b[K\r\u001b[2C\u001b[1Bendpoint + key fingerprin\u001b[29G. Phone scans\u001b[43G→ hits\u001b[54GHTTP control plane →\r\u001b[2C\u001b[1Benrolls its own d\u001b[21Gvice keypair (branch 1's enr\u001b[50Gllment\u001b[57Gflow,\u001b[63Gun\u001b[66Ghanged)\u001b[74G→\u001b[76Ggets\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[352.181399, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G- \u001b[1mAttachment gets a \u001b[38;5;153mrole\u001b[39m field\u001b[22m now: \u001b[38;5;153mprimary\u001b[39m (full data plane — the\u001b[K\r\u001b[2C\u001b[1Bdevstation), \u001b[38;5;153mdispatcher\u001b[39m (control-plane only\u001b[47G— what the\u001b[59Gho\u001b[64Gis), \u001b[38;5;153mspectator\r\u001b[2C\u001b[1B\u001b[39m(read-only, reserved). A phone disp\u001b[39Gtch \u001b[44Gever\u001b[49Gneeds the QUIC\u001b[64Gfast\u001b[69Gpath; it\u001b[K\r\u001b[2C\u001b[1Bne\u001b[6Gds the HTTP/3 control\u001b[29Gla\u001b[34Gto \u001b[38Greflight and fire. So \"deploy vi\u001b[71G phone\"\r\u001b[2C\u001b[1Bcost\u001b[9Galmost nothing extra o\u001b[32G the\u001b[37Gt\u001b[39Ganspor\u001b[47Gsi\u001b[50Ge — branch 1's design\u001b[72Galready\r\u001b[2C\u001b[1Bsplit\u001b[9Gcontrol from data.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEstate move = detach + attach\u001b[22m,\u001b[36Gnot\u001b[40Gcopy.\u001b[46GBecause\u001b[54Gthe\u001b[58Gsession\u001b[66Gis\r\u001b[2C\u001b[1Breconstructable from connectome al\u001b[38Gne (the\u001b[46Gr\u001b[49Gon\u001b[52Gtruction rule), moving\u001b[75Gfrom\r\u001b[2C\u001b[1Bd\u001b[5Gvsta\u001b[10Gion to the Wind\u001b[26Gws box is: \u001b[38Gld\u001b[41Ga\u001b[43Gtachment ends, new device attaches,\u001b[K\r\u001b[2C\u001b[1Boutbox replays from \u001b[3mthat device's\u001b[37G\u001b[23mlast-seen cursor. Per-attachment cursor\r\u001b[2C\u001b[1Bno\u001b[6G per-session — that's the one schema d\u001b[45Gtail the estate move forces.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mQR ceremony\u001b[22m: the QR encod\u001b[31Gs a short-liv\u001b[45Gd boo\u001b[51Gstrap token + clyffy's\r\u001b[2C\u001b[1Bendpoint + key\u001b[18Gfingerprint. Phone scans → hits \u001b[51Ghe HTTP co\u001b[62Gtrol plane →\r\u001b[4C\u001b[1Brolls its own device keypair (branch 1's enrollment flow, unchanged) →\u001b[76Ggets\r\u001b[2C\u001b[1Ba \u001b[38;5;153mdispatcher\u001b[39m attachment. Preflight = dry-run \u001b[49Geport over the control plane\u001b[K\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
