[584.389411, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;231m●\u001b[39m A default, B as a per-user option — that completes the decision set. (I'm\u001b[K\r\u001b[2C\u001b[1Bignoring\u001b[12Gthe\u001b[16Gstray\u001b[22G\"keep\u001b[28Gdriving\u001b[36Gthe\u001b[40Gtail\u001b[45G/\u001b[47Gbuild.rs\"\u001b[57Gfragment\u001b[66Gthat\u001b[71Grode\u001b[76Galong\r\u001b[1B \u001b[3Gin th\u001b[9Gt paste —\u001b[19Git's from ano\u001b[33Gher\u001b[37Gwindow\u001b[44Gand b\u001b[50Glongs to a differen\u001b[70G lane,\u001b[77Gnot\r\u001b[2C\u001b[1Bthis branc\u001b[14G.)\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1BWr\u001b[6Gting the close\u001b[21Gnow:\u001b[26Gextending\u001b[36Gthe\u001b[40Gdecision\u001b[49Gnotes\u001b[55Gwith\u001b[60Gyour\u001b[65Gwords\u001b[71Gand\u001b[75Gthe\r\u001b[2C\u001b[1Bbuild\u001b[9Gnotes,\u001b[16Gthen\u001b[21Gyou\u001b[25Gconfirm.\r\u001b[2C\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;246m●\u001b[3G\u001b[39m\u001b[1mUpdate\u001b[22m(\u001b]8;id=1fbl8uj;file:///home/hades/.deepdive/dives/devpulse-l2-session/DECISIONS.md\u0007.deepdive/dives/devpulse-l2-session/DECISIONS.md\u001b]8;;\u0007)\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
[584.441893, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[6G\u001b[38;5;77m\u001b[48;5;22m 171 +\u001b[38;5;231m- Deferred ceremonies (schema-ready, not built in v1): estate \r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;231mmove, QR/bootstrap-token dispatch,                            \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G \u001b[5G \u001b[38;5;77m\u001b[48;5;22m 172 +\u001b[38;5;231m  spectator role.                                             \u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;5;77m\u001b[48;5;22m 173 +\u001b[38;5;231m- Open handoff to branch 3 (client-contract): the control-plan\u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B  \u001b[6G\u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;231me endpoint set this implies — attach/                         \u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;5;77m\u001b[48;5;22m 174 +\u001b[38;5;231m  resume (with per-stream seqs), preflight, bypass arm/disarm,\r\u001b[5C\u001b[1B\u001b[38;5;77m     +\u001b[38;5;231m work-item submit — plus the                                  \r\u001b[2C\u001b[1B\u001b[49m\u001b[39m   \u001b[38;5;77m\u001b[48;5;22m 175 +\u001b[38;5;231m  client-visible ack/backpressure semantics and outbox replay \u001b[75G\u001b[49m\u001b[39m\u001b[K\r\u001b[2C\u001b[1B   \u001b[38;5;77m\u001b[48;5;22m     +\u001b[38;5;231mprotocol.                                                     \r\u001b[5C\u001b[1B\u001b[38;5;77m 176 +\u001b[38;5;231m                                                              \r\u001b[1B\u001b[49m\u001b[39m \u001b[3G   \u001b[38;5;77m\u001b[48;5;22m 177 +\u001b[38;5;231m---                                                           \u001b[49m\u001b[39m\u001b[23;1H\u001b[19;3H\u001b[?25h\u001b[?2026l"]
