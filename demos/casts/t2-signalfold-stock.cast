[270604.924992, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B\u001b[38;5;153mopen_metrics_warehouse(config)\u001b[39m and added\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mPlatform::boot_with_warehouse(config, Arc<Analytics>)\u001b[39m;\u001b[58G\u001b[38;5;153mPlatform::boot\u001b[73G\u001b[39mis\r\u001b[2C\u001b[1Bunchanged in signature and delegates, so the CLI path is untouched.\u001b[K\r\u001b[2C\u001b[1B- T\u001b[7Ge en\u001b[12Gpoint therefore works while the\u001b[44Gmodel is s\u001b[55Gill loading, and\u001b[72Gunder\u001b[78Gthe\r\u001b[2C\u001b[1Bring backend —\u001b[18Gw\u001b[20Gich is the point of\u001b[44Gorgan-a\u001b[52G-\u001b[54Gervice path for hooks. If\u001b[K\r\u001b[2C\u001b[1Bthe warehouse can't open (another\u001b[37Gwri\u001b[41Ger\u001b[44Gholds the lock),\u001b[61Gthe daemon still\u001b[K\r\u001b[2C\u001b[1Bboots and \u001b[38;5;153m/signal/fold\u001b[39m answers 503; th\u001b[42G in-process\u001b[54Gbrain then\u001b[65Gf\u001b[67Glls back to\r\u001b[2C\u001b[1B\u001b[38;5;153mPlatform::boot\u001b[39m, which surface\u001b[34Gthe sam\u001b[43Gstorage erro\u001b[56G as\u001b[60Gbefore.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[1mTests\u001b[9G\u001b[22m(in\u001b[13G\u001b[38;5;153mmain.rs\u001b[39m,\u001b[22Greal\u001b[27Gin-memory\u001b[37GDuckDB,\u001b[45Gno\u001b[48Gbrain\u001b[54Gload):\u001b[61Gvalid\u001b[67Gsignal\u001b[74G→\u001b[76Grow\r\u001b[2C\u001b[1Bverified in \u001b[38;5;153mfold_signals\u001b[39m colu\u001b[33Gn-by-column; unknow\u001b[54Gph\u001b[57Gse → 400 nami\u001b[71Gg the\u001b[K\r\u001b[2C\u001b[1Bl\u001b[5Ggal set \u001b[3mand\u001b[23m a \u001b[38;5;153mcount(*) = 0\u001b[39m asserti\u001b[40Gn that \u001b[48Gothi\u001b[53Gg w\u001b[58G inserted; \u001b[38;5;153mlane\u001b[39m without\r\u001b[2C\u001b[1B\u001b[38;5;153mdecision_id\u001b[39m →\u001b[17G400.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153mclyffy-brain\u001b[16G\u001b[39mgained\u001b[23G\u001b[38