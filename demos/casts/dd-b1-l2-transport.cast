[695.159726, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[1m\"Layer 2\" becomes the second layer of the connection — a QUIC-native secure \r\u001b[2C\u001b[1Bdata plane that the HTTP handshake\u001b[38Gupgrades i\u001b[49Gto, not literal ethernet \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mbridging.\u001b[22m Concretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1BHTTP/3 (\u001b[38;5;153mclyffy.local:8787\u001b[39m, mDNS discovery\u001b[45G— unchanged contract).\u001b[K\r\u001b[2C\u001b[1BEnrollment/auth happens there, then th\u001b[42G \u001b[3msame connection\u001b[23m opens dedicated\r\u001b[2C\u001b[1Bst\u001b[6Geams + unreliable datagrams\u001b[34Gas the fast path: rkyv zero-copy frames,\u001b[75Gno\r\u001b[2C\u001b[1BJSON, no per-request\u001b[24Goverhe\u001b[31Gd.\u001b[34GThis is the\u001b[46Gli\u001b[49Geral \"goes from HTTP to the\u001b[K\r\u001b[2C\u001b[1Bbridge imm\u001b[14Gdiately\" — no s\u001b[30Gcond \u001b[36Gandshake,\u001b[46Gno system VPN\u001b[60Gconfig, no admin\r\u001b[2C\u001b[1Bp\u001b[5Gompts, identical on\u001b[25GLinux/Windows/Mac because i\u001b[53G's\u001b[56Gall\u001b[60Gin-process\u001b[71GRust\u001b[K\r\u001b[2C\u001b[1B(quinn/qu\u001b[13Gche + rustls).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mLocal vs networked is the same identity, different path.\u001b[62G\u001b[22mLocal:\u001b[69Gdirect\u001b[76GQUIC\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[695.584409, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[13B\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[695.688653, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3G\u001b[1mdata plane that the HTTP handshake\u001b[38Gupgrades i\u001b[49Gto, not literal ethernet \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mbridging.\u001b[22m Concretely:\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\u001b[2C\u001b[1B-\u001b[5G\u001b[1mOne QUIC connection, two personalities.\u001b[45G\u001b[22mDevPulse\u001b[54Ghits\u001b[59Gthe\u001b[63GBrain\u001b[69GAPI\u001b[73Gover\r\u001b[2C\u001b[1BHTTP/3 (\u001b[38;5;153mclyffy.local:8787\u001b[39m, mDNS discovery\u001b[45G— unchanged contract).\u001b[K\r\u001b[2C\u001b[1BEnrollment/auth happens there, then th\u001b[42G \u001b[3msame connection\u001b[23m opens dedicated\r\u001b[2C\u001b[1Bst\u001b[6Geams + unreliable datagrams\u001b[34Gas the fast path: rkyv zero-copy frames,\u001b[75Gno\r\u001b[2C\u001b[1BJSON, no per-request\u001b[24Goverhe\u001b[31Gd.\u001b[34GThis is the\u001b[46Gli\u001b[49Geral \"goes from HTTP to the\u001b[K\r\u001b[2C\u001b[1Bbridge imm\u001b[14Gdiately\" — no s\u001b[30Gcond \u001b[36Gandshake,\u001b[46Gno system VPN\u001b[60Gconfig, no admin\r\u001b[2C\u001b[1Bp\u001b[5Gompts, identical on\u001b[25GLinux/Windows/Mac because i\u001b[53G's\u001b[56Gall\u001b[60Gin-process\u001b[71GRust\u001b[K\r\u001b[2C\u001b[1B(quinn/qu\u001b[13Gche + rustls).\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mLocal vs networked is the same identity, different path.\u001b[62G\u001b[22mLocal:\u001b[69Gdirect\u001b[76GQUIC\r\u001b[2C\u001b[1Bover the LAN at full speed. Networked: QUIC connection migration\u001b[K\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
