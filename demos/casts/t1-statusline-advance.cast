[301795.393676, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[2C\u001b[1B3. \u001b[1mHEAD is a trap.\u001b[22m pxpipe's own event log shows \u001b[38;5;153mHEAD / → 404\u001b[39m while \u001b[38;5;153mGET / → \u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[38;5;153m200\u001b[39m. If\u001b[11Ganyone \"optimizes\" the check \u001b[41Go\u001b[43G\u001b[38;5;153mcurl -I\u001b[39m, it repor\u001b[61Gs permanently\u001b[75Gdown.\r\u001b[2C\u001b[1BWorth\u001b[9Ga\u001b[11Gcomment\u001b[19Gin\u001b[22Gthe\u001b[26Gscript\u001b[33Gor\u001b[36Ga\u001b[38Gnote\u001b[43Gin\u001b[46Gthe\u001b[50Gbaseline:\u001b[60Gthe\u001b[64Gcheck\u001b[70Gmust\u001b[75Gstay\r\u001b[2C\u001b[1BGET.\u001b[K\r\u001b[2C\u001b[1B4. \u001b[1m\"Today\" is UTC.\u001b[22m \u001b[38;5;153mts\u001b[39m is UTC and I match\u001b[44G\u001b[38;5;153mdate -u +%F\u001b[39m, so on this box\u001b[72G(UTC−4)\r\u001b[2C\u001b[1Bthe counter\u001b[15Gvisibly resets\u001b[30Gat\u001b[33G8pm\u001b[37Glocal.\u001b[44GEither\u001b[51Gaccept\u001b[58Git\u001b[61Gor\u001b[64Gcompute\u001b[72Gthe\r\u001b[2C\u001b[1Blocal-day → UTC range.\u001b[K\r\u001b[2C\u001b[1B5. \u001b[1mLinear scan of events.jsonl.\u001b[22m 27 l\u001b[41Ges today, but grep+jq\u001b[63Gov\u001b[66Gr\u001b[68Gthe whole\r\u001b[2C\u001b[1Bfile is O(file). Months\u001b[27Gof heavy piping → the <100ms budge\u001b[62G dies quietly.\u001b[K\r\u001b[2C\u001b[1BCheap b\u001b[11Gund:\u001b[16G\u001b[38;5;153mtail -c 2M\u001b[39m befor\u001b[33G the gr\u001b[41Gp, or make\u001b[52Gpxpipe\u001b[59Grotate\u001b[66Gthe\u001b[70Gfile\u001b[75Gdaily\r\u001b[2C\u001b[1B(rotation is the right\u001b[26Gl\u001b[29Gg-term answer anyway).\u001b[K\r\u001b[2C\u001b[1B6. \u001b[1mWedged-proxy stall.\u001b[22m Connection-r\u001b[39Gfused\u001b[45Gi\u001b[48Ginstant,\u001b[57Gbut a hung proxy\u001b[K\r\u001b[2C\u001b[1B(accepting, not answering) costs the full 1s curl cap onc\u001b[62Gper 5s wind\u001b[74Gw —\u001b[K\r\u001b[2C\u001b[1Bvisible status\u001b[18Gine stutt\u001b[29G. Improvement: r\u001b[46Gfresh\u001b[52Gthe\u001b[56Gcache\u001b[62Gin\u001b[65Ga\u001b[67Gbackgrounded\r\u001b[2C\u001b[1Bsubshell\u001b[12Gand\u001b[16Galways\u001b[23Grender\u001b[30Glast-known\u001b[41Gstate.\u001b[23;1H\u001b[20;38H\u001b[?25h\u001b[?2026l"]
