[700.943082, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gtearing the \u001b[16Gession; hole-punching/relay v\u001b[46Ga an iroh/noq-style layer or a\u001b[K\r\u001b[2C\u001b[1Br\u001b[5Glay on s\u001b[14Grv\u001b[17Gr1 when direct fa\u001b[35Gls. We\u001b[42Gk-connect\u001b[52Gon survivability is\u001b[72Ga\u001b[K\r\u001b[2C\u001b[1B\u001b[3mprotocol property\u001b[23m, not bolted on — which tees up branch 2 (clyff\u001b[68G-owned\r\u001b[2C\u001b[1Bsessions) perfectly.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEdge termination.\u001b[22m The\u001b[27Gtunnel\u001b[34Glands\u001b[40Gon\u001b[43Gclyffy-01's\u001b[55GLAN\u001b[59Gface;\u001b[65Gthe\u001b[69GDAC\u001b[73Gfabric\r\u001b[2C\u001b[1Bnever sees a client\u001b[23GMAC. If DevPulse\u001b[40Gever needs di\u001b[54Gcovery-style broadcast\u001b[K\r\u001b[2C\u001b[1Bs\u001b[5Gmantics,\u001b[14Gwe solve\u001b[23Git with\u001b[31Gan mDNS r\u001b[41Gflector, not bridging.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCrypto:\u001b[22m hybrid X25519+ML-KEM\u001b[34G(rustls d\u001b[44Gfault), device-keypair\u001b[67Genrollment\u001b[78Gvia\r\u001b[2C\u001b[1Bthe HTTP cont\u001b[17Gol\u001b[20Gplane, and a \u001b[1mhash-chained tamper-evident session ledger in \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mconnectome\u001b[22m — the\u001b[20Gb\u001b[22Gockch\u001b[28Gin-shaped property you asked for, without consensus\r\u001b[2C\u001b[1Boverhead.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mHonesty gate (no-reward-hacking):\u001b[39G\u001b[22mbefore\u001b[46Gwe\u001b[49Gdeclare\u001b[57Gvictory,\u001b[66Gthe\u001b[70GQUIC\u001b[75Gfast\r\u001b[2C\u001b[1Bpath gets benchmarked against a plain rkyv-over-TCP stream on the same LAN. If\r\u001b[2C\u001b[1B\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mEdge termination\u001b[39m                                                          \u001b[49m\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
[701.340847, "o", "\u001b[?2026h\u001b[?25l\u001b[H\u001b[3Gr\u001b[5Glay on s\u001b[14Grv\u001b[17Gr1 when direct fa\u001b[35Gls. We\u001b[42Gk-connect\u001b[52Gon survivability is\u001b[72Ga\u001b[K\r\u001b[2C\u001b[1B\u001b[3mprotocol property\u001b[23m, not bolted on — which tees up branch 2 (clyff\u001b[68G-owned\r\u001b[2C\u001b[1Bsessions) perfectly.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mEdge termination.\u001b[22m The\u001b[27Gtunnel\u001b[34Glands\u001b[40Gon\u001b[43Gclyffy-01's\u001b[55GLAN\u001b[59Gface;\u001b[65Gthe\u001b[69GDAC\u001b[73Gfabric\r\u001b[2C\u001b[1Bnever sees a client\u001b[23GMAC. If DevPulse\u001b[40Gever needs di\u001b[54Gcovery-style broadcast\u001b[K\r\u001b[2C\u001b[1Bs\u001b[5Gmantics,\u001b[14Gwe solve\u001b[23Git with\u001b[31Gan mDNS r\u001b[41Gflector, not bridging.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mCrypto:\u001b[22m hybrid X25519+ML-KEM\u001b[34G(rustls d\u001b[44Gfault), device-keypair\u001b[67Genrollment\u001b[78Gvia\r\u001b[2C\u001b[1Bthe HTTP cont\u001b[17Gol\u001b[20Gplane, and a \u001b[1mhash-chained tamper-evident session ledger in \u001b[22m\u001b[K\r\u001b[2C\u001b[1B\u001b[1mconnectome\u001b[22m — the\u001b[20Gb\u001b[22Gockch\u001b[28Gin-shaped property you asked for, without consensus\r\u001b[2C\u001b[1Boverhead.\u001b[K\r\u001b[2C\u001b[1B- \u001b[1mHonesty gate (no-reward-hacking):\u001b[39G\u001b[22mbefore\u001b[46Gwe\u001b[49Gdeclare\u001b[57Gvictory,\u001b[66Gthe\u001b[70GQUIC\u001b[75Gfast\r\u001b[2C\u001b[1Bpath gets benchmarked against a plain rkyv-over-TCP stream on the same LAN. If\r\u001b[2C\u001b[1Bit can'\u001b[11G hold ~wi\u001b[21Ge-speed on the \u001b[37Gocal path, the fallback ca\u001b[64Gdidate is\u001b[74G\u001b[K\u001b[23;1H\u001b[19;4H\u001b[?25h\u001b[?2026l"]
