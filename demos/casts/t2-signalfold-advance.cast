[267124.360861, "o", "\u001b[?2026h\u001b[?25l\u001b[H\r\u001b[6C\u001b[1B\u001b[38;5;77m\u001b[48;5;22m636\u001b[12G\u001b[38;5;242m/// before anything touches the warehouse — there is no string\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mly path in.\u001b[38;5;231m                                                   \r\u001b[6C\u001b[1B\u001b[38;5;77m637\u001b[12G\u001b[38;5;242m#[derive(Deserialize)]\r\u001b[8C\u001b[1B\u001b[38;5;77m8\u001b[12G\u001b[38;5;81mstruct\u001b[38;5;231m \u001b[38;5;148mFoldReq\u001b[38;5;231m {      \r\u001b[8C\u001b[1B\u001b[38;5;77m9\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m/// Lifecycle transition — a [`FoldPhase`] tag (e.g. `bran\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mch_opened`, `decision_es\u001b[37Gablished`).\u001b[38;5;231m                          \r\u001b[6C\u001b[1B\u001b[38;5;77m640\u001b[12G\u001b[38;5;231m    phase: \u001b[38;5;148mString\u001b[38;5;231m,                  \r\u001b[8C\u001b[1B\u001b[38;5;77m1\u001b[16G\u001b[38;5;242m/// The fold tree's node id this event belongs to.\r\u001b[8C\u001b[1B\u001b[38;5;77m2\u001b[16G\u001b[38;5;231mbranch_id: \u001b[38;5;148mString\u001b[38;5;231m,                                \r\u001b[8C\u001b[1B\u001b[38;5;77m3\u001b[16G\u001b[38;5;242m/// Which harness ran the branch — a [`FoldEngine`] tag (e\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242m.g. `claude`,\u001b[26G`cod\u001b[31Gx`).\u001b[38;5;231m                                       \r\u001b[6C\u001b[1B\u001b[38;5;77m644\u001b[12G\u001b[38;5;231m    engine: \u001b[38;5;148mString\u001b[38;5;231m,    \r\u001b[8C\u001b[1B\u001b[38;5;77m5\u001b[16G\u001b[38;5;242m/// Attribution scope; defaults to `clyffy` (mirrors the `\r\u001b[6C\u001b[1B\u001b[38;5;77m   \u001b[12G\u001b[38;5;242mclyffy signal fold`\u001b[32GCLI).\u001b[38;5;231m                                     \r\u001b[6C\u001b[1B\u001b[38;5;77m646\u001b[12G\u001b[38;5;231m    \u001b[38;5;242m#[serde(de\u0